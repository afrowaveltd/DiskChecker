<Window x:Class="DiskChecker.UI.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="DiskChecker - Diagnóza Disků 🖴" 
        Height="700" 
        Width="1300"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="35"/>
        </Grid.RowDefinitions>

        <!-- ========== HEADER/TOOLBAR ========== -->
        <Border Grid.Row="0" Background="#FFFFFF" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Logo Area -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0">
                    <TextBlock Text="🖴" FontSize="28" Margin="0,0,10,0" VerticalAlignment="Center"/>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="DiskChecker" FontSize="18" FontWeight="Bold" Foreground="#007ACC"/>
                        <TextBlock Text="Profesionální Diagnóza Disků" FontSize="10" Foreground="#999999" Margin="0,-3,0,0"/>
                    </StackPanel>
                </StackPanel>

                <!-- Navigation Menu -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,20,0">
                    <Button Content="🏠 Home" 
                            Command="{Binding NavigateToDiskSelectionCommand}"
                            Background="Transparent" Foreground="#333333"
                            Padding="15,20" BorderThickness="0"
                            FontSize="11" FontWeight="SemiBold" Cursor="Hand"
                            ToolTip="Vrátit se na výběr disku"/>
                    
                    <Button Content="🧪 Surface Test" 
                            Command="{Binding NavigateToSurfaceTestCommand}"
                            Background="Transparent" Foreground="#333333"
                            Padding="15,20" BorderThickness="0"
                            FontSize="11" FontWeight="SemiBold" Cursor="Hand"
                            ToolTip="Spustit test povrchu disku"/>
                    
                    <Button Content="🔧 SMART Check" 
                            Command="{Binding NavigateToSmartCheckCommand}"
                            Background="Transparent" Foreground="#333333"
                            Padding="15,20" BorderThickness="0"
                            FontSize="11" FontWeight="SemiBold" Cursor="Hand"
                            ToolTip="Zobrazit SMART data"/>
                    
                    <Button Content="📄 Reports" 
                            Command="{Binding NavigateToReportCommand}"
                            Background="Transparent" Foreground="#333333"
                            Padding="15,20" BorderThickness="0"
                            FontSize="11" FontWeight="SemiBold" Cursor="Hand"
                            ToolTip="Zobrazit reporty"/>
                    
                    <Button Content="📚 History" 
                            Command="{Binding NavigateToHistoryCommand}"
                            Background="Transparent" Foreground="#333333"
                            Padding="15,20" BorderThickness="0"
                            FontSize="11" FontWeight="SemiBold" Cursor="Hand"
                            ToolTip="Historie testů"/>
                    
                    <Separator Background="#E0E0E0" Width="1" Margin="5,10"/>
                    
                    <Button Content="⚙️ Settings" 
                            Command="{Binding NavigateToSettingsCommand}"
                            Background="Transparent" Foreground="#666666"
                            Padding="15,20" BorderThickness="0"
                            FontSize="11" FontWeight="SemiBold" Cursor="Hand"
                            ToolTip="Nastavení aplikace"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ========== CONTENT AREA ========== -->
        <Border Grid.Row="1" Background="#F5F5F5" Margin="0">
            <ContentControl Content="{Binding CurrentContent}"/>
        </Border>

        <!-- ========== STATUS BAR ========== -->
        <StatusBar Grid.Row="2" Background="#FFFFFF" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0">
            <Grid Width="{Binding RelativeSource={RelativeSource AncestorType=StatusBar}, Path=ActualWidth}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="{Binding StatusMessage}" 
                          Foreground="#666666" VerticalAlignment="Center" Margin="10,0"/>
                
                <TextBlock Grid.Column="1" Text="v1.0.0" 
                          Foreground="#999999" VerticalAlignment="Center" Margin="10,0"/>
            </Grid>
        </StatusBar>
    </Grid>
</Window>
