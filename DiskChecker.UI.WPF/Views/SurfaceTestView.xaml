<UserControl x:Class="DiskChecker.UI.WPF.Views.SurfaceTestView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:oxy="http://oxyplot.org/wpf"
             xmlns:local="clr-namespace:DiskChecker.UI.WPF.Behaviors"
             xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1000"
             Background="{DynamicResource ThemeBackgroundBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ============ HEADER ============ -->
        <Border Grid.Row="0" Background="{DynamicResource ThemePanelBrush}" BorderBrush="{DynamicResource ThemeBorderBrush}" BorderThickness="0,0,0,1" Padding="20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,0,0">
                    <TextBlock Text="🖴 Test Povrchu Disku" 
                               FontSize="24" FontWeight="Bold" Foreground="#1a1a1a" Margin="0,0,0,10"/>
                    <TextBlock Text="{Binding SelectedDriveInfo}" 
                               FontSize="14" Foreground="#666666" Margin="0,0,0,5"/>
                    <TextBlock Text="{Binding CurrentPhase}" 
                               FontSize="12" Foreground="#007ACC" FontWeight="SemiBold"/>
                </StackPanel>

                <!-- Mini Speed Gauge -->
                <Grid Grid.Column="1" VerticalAlignment="Center" Margin="20,0,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Canvas Grid.Row="0" Width="140" Height="80">
                        <Path Stroke="#B0B0B0" StrokeThickness="5" Data="M 15,70 A 60,60 0 0 1 125,70"/>
                        <Line X1="70" Y1="70" X2="70" Y2="25" Stroke="#DC3545" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round">
                            <Line.RenderTransform>
                                <RotateTransform Angle="{Binding WriteNeedleAngle}" CenterX="70" CenterY="70"/>
                            </Line.RenderTransform>
                        </Line>
                        <Line X1="70" Y1="70" X2="70" Y2="32" Stroke="#28A745" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round">
                            <Line.RenderTransform>
                                <RotateTransform Angle="{Binding ReadNeedleAngle}" CenterX="70" CenterY="70"/>
                            </Line.RenderTransform>
                        </Line>
                        <Ellipse Width="8" Height="8" Fill="#333333" Canvas.Left="66" Canvas.Top="66"/>
                        <TextBlock Text="0" FontSize="9" Foreground="#999999" Canvas.Left="10" Canvas.Top="67"/>
                        <TextBlock Text="{Binding GaugeMaxMbps}" FontSize="9" Foreground="#999999" Canvas.Left="110" Canvas.Top="67"/>
                    </Canvas>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,4,0,0">
                        <TextBlock Text="🔴" Foreground="#DC3545" Margin="0,0,4,0" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding CurrentWriteThroughputMbps, Converter={StaticResource MbpsConverter}}" 
                                   FontSize="10" FontWeight="SemiBold" Foreground="#DC3545" Margin="0,0,12,0"/>
                        <TextBlock Text="🟢" Foreground="#28A745" Margin="0,0,4,0" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding CurrentReadThroughputMbps, Converter={StaticResource MbpsConverter}}" 
                                   FontSize="10" FontWeight="SemiBold" Foreground="#28A745"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <!-- ============ DISK SELECTION ============ -->
        <Border Grid.Row="1" Background="{DynamicResource ThemePanelBrush}" BorderBrush="{DynamicResource ThemeBorderBrush}" BorderThickness="0,0,0,1" Margin="20,0,20,15" Padding="12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <TextBlock Grid.Column="0" Text="💾" FontSize="20" VerticalAlignment="Center" Margin="0,0,15,0"/>
                
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="{Binding SelectedDrive.Name}" FontSize="13" FontWeight="Bold" Foreground="#333333"/>
                    <TextBlock Text="{Binding SelectedDrive.Path}" FontSize="11" Foreground="#999999" Margin="0,2,0,0"/>
                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                        <TextBlock Text="Disk:" FontSize="11" Foreground="#666666" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <ComboBox Width="320"
                                  ItemsSource="{Binding AvailableDrives}"
                                  DisplayMemberPath="Name"
                                  SelectedItem="{Binding SelectedDrive}"
                                  FontSize="11"
                                  IsEnabled="{Binding IsTestRunning, Converter={StaticResource InvertBoolConverter}}"/>
                        <Button Content="↻" Command="{Binding ReloadAvailableDrivesCommand}" Style="{StaticResource ActionButtonStyle}" Background="#5F6B7A" Foreground="White" Margin="8,0,0,0" Padding="10,6"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                        <TextBlock Text="Režim:" FontSize="11" Foreground="#666666" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <ComboBox Width="320"
                                  ItemsSource="{Binding AvailableRunModes}"
                                  DisplayMemberPath="Label"
                                  SelectedValuePath="Value"
                                  SelectedValue="{Binding SelectedRunMode}"
                                  FontSize="11"/>
                    </StackPanel>
                    <TextBlock Text="{Binding SystemDiskProtectionMessage}" FontSize="11" Foreground="#B35A00" Margin="0,4,0,0" TextWrapping="Wrap"/>
                </StackPanel>
                
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="15,0,0,0">
                    <Button Content="▶️ START" 
                            Command="{Binding StartTestCommand}"
                            IsEnabled="{Binding IsTestRunning, Converter={StaticResource InvertBoolConverter}}"
                            Style="{StaticResource ActionButtonStyle}"
                            Background="#28A745" Foreground="White" 
                            Padding="12,8" Margin="0,0,8,0"
                            FontSize="11"/>
                    <Button Content="⏹️ STOP" 
                            Command="{Binding StopTestCommand}"
                            IsEnabled="{Binding IsTestRunning}"
                            Style="{StaticResource ActionButtonStyle}"
                            Background="#DC3545" Foreground="White"
                            Padding="12,8" Margin="0,0,8,0"
                            FontSize="11"/>

                    <Button Content="🖨️ CERTIFIKÁT A4"
                             Command="{Binding PrintCertificateCommand}"
                             IsEnabled="{Binding CanPrintCertificate}"
                             Style="{StaticResource ActionButtonStyle}"
                             Background="#6C63FF" Foreground="White"
                             Padding="12,8"
                             FontSize="11"
                             ToolTip="Vytisknout barevný A4 certifikát po kompletním testu"/>
                     
                     <Button Content="🏷️ ŠTÍTEK"
                             Command="{Binding PrintLabelCommand}"
                             IsEnabled="{Binding CanPrintLabel}"
                             Style="{StaticResource ActionButtonStyle}"
                             Background="#FF6B35" Foreground="White"
                             Padding="12,8" Margin="8,0,0,0"
                             FontSize="11"
                             ToolTip="Vytisknout štítek pro disk (různé velikosti)"/>
                 </StackPanel>
            </Grid>
        </Border>

        <!-- ============ MAIN VISUALIZATION AREA ============ -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="20,0,20,20">
                <!-- Block Visualization Area -->
                <Border Background="{DynamicResource ThemePanelBrush}" BorderBrush="{DynamicResource ThemeBorderBrush}" BorderThickness="1" Padding="15" Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="📊 Vizualizace Povrchu Disku" 
                                   FontSize="13" FontWeight="Bold" Foreground="#333333" Margin="0,0,0,15"/>
                        
                        <!-- Legend -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                            <Border Background="#4A90E2" Width="16" Height="16" Margin="0,0,8,0"/>
                            <TextBlock Text="Zápis (Write)" FontSize="11" Foreground="#666666" Margin="0,0,20,0" VerticalAlignment="Center"/>
                            
                            <Border Background="#28A745" Width="16" Height="16" Margin="0,0,8,0"/>
                            <TextBlock Text="Čtení (Read)" FontSize="11" Foreground="#666666" Margin="0,0,20,0" VerticalAlignment="Center"/>
                            
                            <Border Background="#FFC107" Width="16" Height="16" Margin="0,0,8,0"/>
                            <TextBlock Text="Probíhá" FontSize="11" Foreground="#666666" Margin="0,0,20,0" VerticalAlignment="Center"/>
                            
                            <Border Background="#DC3545" Width="16" Height="16" Margin="0,0,8,0"/>
                            <TextBlock Text="Chyba" FontSize="11" Foreground="#666666" VerticalAlignment="Center"/>
                            
                            <Border Background="#E0E0E0" Width="16" Height="16" Margin="20,0,8,0"/>
                            <TextBlock Text="Netestováno" FontSize="11" Foreground="#666666" VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- Blocks Grid - New approach with custom DefragGridPanel -->
                        <Border Background="White" BorderBrush="#E0E0E0" BorderThickness="1" Padding="0" Margin="0,0,0,10" MinHeight="150">
                            <!-- ItemsControl with custom DefragGridPanel for dynamic layout -->
                            <ItemsControl ItemsSource="{Binding Blocks}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <local:DefragGridPanel/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="#D0D0D0" BorderThickness="0.5" Margin="0">
                                            <Border.Background>
                                                <MultiBinding Converter="{StaticResource StatusToColorConverter}">
                                                    <Binding Path="Status"/>
                                                    <Binding Path="IsAllocated"/>
                                                </MultiBinding>
                                            </Border.Background>
                                            <ToolTip Content="{Binding Index, Converter={StaticResource BlockLabelConverter}}"/>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Border>

                        <TextBlock FontSize="10" Foreground="#999999" Margin="0,5,0,0">
                            <Run Text="Aktivní pole: "/>
                            <Run Text="{Binding ActiveBlockCount}"/>
                            <Run Text=" / 1000 • 1 pole ≈ "/>
                            <Run Text="{Binding BytesPerVisualizedBlock, Converter={StaticResource BytesToStringConverter}}"/>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- Progress Bar -->
                <Border Background="{DynamicResource ThemePanelBrush}" BorderBrush="{DynamicResource ThemeBorderBrush}" BorderThickness="1" Padding="15" Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="📈 Průběh Testu" FontSize="13" FontWeight="Bold" Foreground="#333333" Margin="0,0,0,10"/>
                        
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            
                            <ProgressBar Grid.Column="0" Value="{Binding ProgressPercent}" 
                                        Maximum="100" Height="24" 
                                        Background="#E0E0E0" Foreground="#4A90E2"/>
                            
                            <TextBlock Grid.Column="1" Text="{Binding ProgressPercent, Converter={StaticResource PercentageConverter}}" 
                                      FontSize="12" FontWeight="Bold" Foreground="#333333" 
                                      VerticalAlignment="Center" Margin="15,0,0,0"/>
                        </Grid>

                        <!-- Progress Stats -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Zapsáno:" FontSize="11" Foreground="#666666"/>
                                <TextBlock Text="{Binding WriteBytesProcessed, Converter={StaticResource BytesToStringConverter}}" 
                                          FontSize="12" FontWeight="Bold" Foreground="#4A90E2"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="12,0,0,0">
                                <TextBlock Text="Ověřeno:" FontSize="11" Foreground="#666666"/>
                                <TextBlock Text="{Binding ReadBytesProcessed, Converter={StaticResource BytesToStringConverter}}" 
                                          FontSize="12" FontWeight="Bold" Foreground="#28A745"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2" Margin="12,0,0,0">
                                <TextBlock Text="Zpracováno celkem:" FontSize="11" Foreground="#666666"/>
                                <TextBlock Text="{Binding BytesProcessed, Converter={StaticResource BytesToStringConverter}}" 
                                          FontSize="12" FontWeight="Bold" Foreground="#333333"/>
                            </StackPanel>

                            <StackPanel Grid.Column="3" Margin="12,0,0,0">
                                <TextBlock Text="Uplynulo:" FontSize="11" Foreground="#666666"/>
                                <TextBlock Text="{Binding ElapsedTime, Converter={StaticResource TimeSpanConverter}}" 
                                          FontSize="12" FontWeight="Bold" Foreground="#333333"/>
                            </StackPanel>

                            <StackPanel Grid.Column="4" HorizontalAlignment="Right" Margin="12,0,0,0">
                                <TextBlock Text="Zbývá:" FontSize="11" Foreground="#666666"/>
                                <TextBlock Text="{Binding EstimatedTimeRemaining, Converter={StaticResource TimeSpanConverter}}" 
                                          FontSize="12" FontWeight="Bold" Foreground="#333333"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Speed Graph -->
                <Border Background="{DynamicResource ThemePanelBrush}" BorderBrush="{DynamicResource ThemeBorderBrush}" BorderThickness="1" Padding="15">
                    <StackPanel>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" Text="⚡ Rychlost Přenosu (MB/s)" 
                                      FontSize="13" FontWeight="Bold" Foreground="#333333"/>
                            
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <TextBlock Text="Aktuálně:" FontSize="11" Foreground="#666666" Margin="0,0,8,0"/>
                                <TextBlock Text="{Binding CurrentThroughputMbps, Converter={StaticResource MbpsConverter}}" 
                                          FontSize="12" FontWeight="Bold" Foreground="#007ACC"/>
                            </StackPanel>
                        </Grid>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" Text="Rozsah:" VerticalAlignment="Center" FontSize="11" Foreground="#666666" Margin="0,0,8,0"/>
                            <ComboBox Grid.Column="1"
                                      Width="190"
                                      ItemsSource="{Binding AvailableGraphTimeRanges}"
                                      DisplayMemberPath="Label"
                                      SelectedValuePath="Value"
                                      SelectedValue="{Binding SelectedGraphTimeRange}"
                                      Margin="0,0,12,0"/>

                            <ComboBox Grid.Column="2"
                                      Width="220"
                                      ItemsSource="{Binding AvailableGraphOverlayModes}"
                                      DisplayMemberPath="Label"
                                      SelectedValuePath="Value"
                                      SelectedValue="{Binding SelectedGraphOverlayMode}"
                                      Margin="0,0,8,0"/>

                            <Button Grid.Column="3"
                                    Content="📥 Načíst referenční overlay"
                                    Command="{Binding LoadReferenceOverlayCommand}"
                                    Style="{StaticResource ActionButtonStyle}"
                                    Background="#5F6B7A"
                                    Foreground="White"
                                    HorizontalAlignment="Left"/>
                        </Grid>

                        <Border Background="#F9F9F9" Height="260" BorderBrush="#E0E0E0" BorderThickness="1">
                            <oxy:PlotView Model="{Binding SpeedPlotModel}"/>
                        </Border>

                        <StackPanel Margin="0,8,0,0">
                            <TextBlock Text="{Binding WriteSpeedStats}" FontSize="11" Foreground="#4A90E2"/>
                            <TextBlock Text="{Binding ReadSpeedStats}" FontSize="11" Foreground="#28A745"/>
                        </StackPanel>

                        <TextBlock Text="{Binding ReferenceOverlayStatus}" FontSize="11" Foreground="#666666" Margin="0,6,0,0"/>

                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                            <TextBlock Text="Průměr:" FontSize="11" Foreground="#666666" Margin="0,0,8,0"/>
                            <TextBlock Text="{Binding AverageThroughputMbps, Converter={StaticResource MbpsConverter}}" 
                                      FontSize="12" FontWeight="Bold" Foreground="#333333"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- ============ STATISTICS ============ -->
        <Border Grid.Row="3" Background="{DynamicResource ThemePanelBrush}" Margin="20,20,20,10" BorderBrush="{DynamicResource ThemeBorderBrush}" 
                BorderThickness="1" Padding="15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="❌ Chyb" FontSize="11" Foreground="#666666" Margin="0,0,0,5"/>
                    <TextBlock Text="{Binding ErrorCount}" FontSize="18" FontWeight="Bold" Foreground="#DC3545"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="15,0">
                    <TextBlock Text="💾 Celk. Data" FontSize="11" Foreground="#666666" Margin="0,0,0,5"/>
                    <TextBlock Text="{Binding TotalBytes, Converter={StaticResource BytesToStringConverter}}" 
                              FontSize="16" FontWeight="Bold" Foreground="#333333"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Margin="15,0">
                    <TextBlock Text="🔵 Fáze" FontSize="11" Foreground="#666666" Margin="0,0,0,5"/>
                    <TextBlock Text="{Binding CurrentPhase}" FontSize="14" FontWeight="Bold" Foreground="#007ACC"/>
                </StackPanel>

                <StackPanel Grid.Column="3" HorizontalAlignment="Right">
                    <TextBlock Text="📊 Vzorky" FontSize="11" Foreground="#666666" Margin="0,0,0,5"/>
                    <TextBlock Text="{Binding SpeedSamples.Count}" FontSize="18" FontWeight="Bold" Foreground="#28A745"/>
                </StackPanel>

                <StackPanel Grid.Column="4" Margin="15,0,0,0">
                    <TextBlock Text="📄 Certifikát" FontSize="11" Foreground="#666666" Margin="0,0,0,5"/>
                    <TextBlock Text="{Binding CertificateStatus}" FontSize="12" FontWeight="SemiBold" Foreground="#6C63FF" TextWrapping="Wrap"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ============ STATUS BAR ============ -->
        <TextBlock Grid.Row="4" Text="{Binding StatusMessage}" 
                   Background="#F0F0F0" Padding="20,8" 
                   FontSize="11" Foreground="#666666"
                   TextTrimming="CharacterEllipsis"/>
    </Grid>
</UserControl>
