<UserControl x:Class="DiskChecker.UI.WPF.Views.DiskSelectionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="1000"
             Background="{DynamicResource ThemeBackgroundBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ========== HEADER ========== -->
        <Border Grid.Row="0" Background="{DynamicResource ThemePanelBrush}" BorderBrush="{DynamicResource ThemeBorderBrush}" BorderThickness="0,0,0,1" Padding="20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,0,5">
                    <TextBlock Text="💾 Vyberte Disk pro Testování" 
                               FontSize="28" FontWeight="Bold" Foreground="#1a1a1a" Margin="0,0,0,5"/>
                    <TextBlock Text="Zvolte disk, který chcete diagnostikovat" 
                               FontSize="13" Foreground="#666666"/>
                    <TextBlock Text="{Binding LoadingState}" FontSize="11" Foreground="#5F6B7A" Margin="0,4,0,0"/>
                    <ProgressBar Height="8" IsIndeterminate="True" Margin="0,6,200,0" Background="#E6EAF0" Foreground="#004B93">
                        <ProgressBar.Style>
                            <Style TargetType="ProgressBar">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ProgressBar.Style>
                    </ProgressBar>
                </StackPanel>

                <Button Grid.Column="1"
                        Content="🔄 Reload disků"
                        Command="{Binding ReloadDisksCommand}"
                        Style="{StaticResource ActionButtonStyle}"
                        Background="#004B93"
                        Foreground="White"
                        VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- ========== DASHBOARD ========== -->
        <Grid Grid.Row="1" Margin="20,12,20,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="3*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{DynamicResource ThemePanelBrush}" BorderBrush="{DynamicResource ThemeBorderBrush}" BorderThickness="1" Padding="14" Margin="0,0,10,0">
                <StackPanel>
                    <TextBlock Text="⚙️ Rychlý SMART report systémového disku" FontSize="13" FontWeight="Bold" Foreground="#333333" Margin="0,0,0,10"/>
                    <TextBlock Text="{Binding SystemDiskName}" FontSize="12" FontWeight="SemiBold" Foreground="#1A1A1A" Margin="0,0,0,6"/>
                    <TextBlock Text="{Binding SystemDiskGrade, StringFormat=Známka: {0}}" FontSize="12" Foreground="#007ACC" Margin="0,0,0,4"/>
                    <TextBlock Text="{Binding SystemDiskTemperature, StringFormat=Teplota: {0}}" FontSize="12" Foreground="#333333" Margin="0,0,0,4"/>
                    <TextBlock Text="{Binding SystemDiskSummary}" FontSize="11" Foreground="#666666" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Background="{DynamicResource ThemePanelBrush}" BorderBrush="{DynamicResource ThemeBorderBrush}" BorderThickness="1" Padding="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="🕒 Poslední testy" FontSize="13" FontWeight="Bold" Foreground="#333333" Margin="0,0,0,8"/>

                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding RecentTests}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              RowHeaderWidth="0"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Datum" Binding="{Binding TestDate, StringFormat={}{0:dd.MM HH:mm}}" Width="130"/>
                            <DataGridTextColumn Header="Disk" Binding="{Binding DriveName}" Width="*"/>
                            <DataGridTextColumn Header="Typ" Binding="{Binding TestType}" Width="120"/>
                            <DataGridTextColumn Header="Známka" Binding="{Binding Grade}" Width="80"/>
                            <DataGridTextColumn Header="Skóre" Binding="{Binding Score, StringFormat={}{0:F1}}" Width="80"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>

        <!-- ========== DISK LIST ========== -->
        <Border Grid.Row="2" Background="{DynamicResource ThemePanelBrush}" BorderBrush="{DynamicResource ThemeBorderBrush}" BorderThickness="1" Margin="20,0,20,20">
            <ListBox ItemsSource="{Binding DiskCards}" 
                     SelectedItem="{Binding SelectedDiskCard}"
                     Background="#FFFFFF" BorderThickness="0"
                     ScrollViewer.VerticalScrollBarVisibility="Auto">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Background="#FAFAFA" Padding="14" Margin="0,6" 
                                BorderBrush="#E0E0E0" BorderThickness="1" Cursor="Hand">
                            <Border.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="📦 Archivovat historii disku"
                                              Command="{Binding DataContext.ArchiveDiskFromTileCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                              CommandParameter="{Binding}"/>
                                </ContextMenu>
                            </Border.ContextMenu>
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="#FFFFFF"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected}" Value="True">
                                            <Setter Property="Background" Value="#E8F5FF"/>
                                            <Setter Property="BorderBrush" Value="#007ACC"/>
                                            <Setter Property="BorderThickness" Value="2"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="50"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Icon -->
                                <TextBlock Grid.Column="0" Text="💾" FontSize="32" 
                                          VerticalAlignment="Center" HorizontalAlignment="Center"/>

                                <!-- Info -->
                                <StackPanel Grid.Column="1" Margin="20,0,20,0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding DisplayName}" FontSize="15" 
                                              FontWeight="Bold" Foreground="#1a1a1a" Margin="0,0,0,5"/>
                                    <TextBlock Text="{Binding DisplayPath}" FontSize="11" 
                                              Foreground="#999999" Margin="0,0,0,4"/>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="SMART " FontSize="11" Foreground="#666666"/>
                                        <TextBlock Text="{Binding GradeText}" FontSize="11" FontWeight="Bold" Foreground="#004B93" Margin="2,0,12,0"/>
                                        <TextBlock Text="{Binding DataSourceText}" FontSize="10" Foreground="#7A8794" Margin="0,0,12,0"/>
                                        <TextBlock Text="🌡 " FontSize="11" Foreground="#666666"/>
                                        <TextBlock Text="{Binding TemperatureText}" FontSize="11" Foreground="#333333" Margin="2,0,12,0"/>
                                        <TextBlock Text="⏱ " FontSize="11" Foreground="#666666"/>
                                        <TextBlock Text="{Binding PowerOnHoursText}" FontSize="11" Foreground="#333333"/>
                                    </StackPanel>
                                </StackPanel>

                                <!-- Size -->
                                <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="20,0,0,0">
                                    <TextBlock Text="{Binding CapacityText}" 
                                              FontSize="14" FontWeight="Bold" Foreground="#007ACC" TextAlignment="Right"/>
                                    <TextBlock Text="Celková velikost" FontSize="10" Foreground="#999999" TextAlignment="Right"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>

        <!-- ========== ACTION BUTTONS ========== -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="20,0,20,20">
            <Button Content="🧪 Test Povrchu" 
                    Command="{Binding NavigateToSurfaceTestCommand}"
                    IsEnabled="{Binding SelectedDrive, Converter={StaticResource NotNullConverter}}"
                    Background="#004B93" Foreground="White" 
                    Padding="20,12" Margin="0,0,12,0"
                    FontSize="13" Width="200">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsSurfaceActionActive}" Value="True">
                                <Setter Property="BorderThickness" Value="2"/>
                                <Setter Property="BorderBrush" Value="#F7C600"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
            
            <Button Content="🔧 SMART Check" 
                    Command="{Binding NavigateToSmartCheckCommand}"
                    IsEnabled="{Binding SelectedDrive, Converter={StaticResource NotNullConverter}}"
                    Background="#F7C600" Foreground="#1A1A1A"
                    Padding="20,12" Margin="0,0,12,0"
                    FontSize="13" Width="200">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsSmartActionActive}" Value="True">
                                <Setter Property="BorderThickness" Value="2"/>
                                <Setter Property="BorderBrush" Value="#004B93"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>

            <Button Content="📊 Detail Disku" 
                    Command="{Binding NavigateToDiskDetailCommand}"
                    IsEnabled="{Binding SelectedDrive, Converter={StaticResource NotNullConverter}}"
                    Background="#005A2B" Foreground="White"
                    Padding="20,12"
                    FontSize="13" Width="200">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsDetailActionActive}" Value="True">
                                <Setter Property="BorderThickness" Value="2"/>
                                <Setter Property="BorderBrush" Value="#F7C600"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </StackPanel>

        <!-- ========== STATUS BAR ========== -->
        <TextBlock Grid.Row="4" Text="{Binding StatusMessage}" 
                   Background="#F0F0F0" Padding="20,8" 
                   FontSize="11" Foreground="#666666"
                   TextTrimming="CharacterEllipsis"/>
    </Grid>
</UserControl>