<Application x:Class="DiskChecker.UI.WPF.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:DiskChecker.UI.WPF"
             xmlns:converters="clr-namespace:DiskChecker.UI.WPF.Converters"
             Startup="Application_Startup"
             Exit="Application_Exit">
    <Application.Resources>
        <!-- Theme palette (inspired by Česká pošta) -->
        <SolidColorBrush x:Key="ThemeBackgroundBrush" Color="#F6F1E3"/>
        <SolidColorBrush x:Key="ThemePanelBrush" Color="#FFFBF4"/>
        <SolidColorBrush x:Key="ThemeCardBrush" Color="#FFF8EA"/>
        <SolidColorBrush x:Key="ThemeBorderBrush" Color="#D9CBA6"/>
        <SolidColorBrush x:Key="ThemePrimaryBrush" Color="#004B93"/>
        <SolidColorBrush x:Key="ThemeAccentBrush" Color="#F7C600"/>

        <!-- Value Converters -->
        <converters:BytesToStringConverter x:Key="BytesToStringConverter"/>
        <converters:PercentageConverter x:Key="PercentageConverter"/>
        <converters:MbpsConverter x:Key="MbpsConverter"/>
        <converters:BlockLabelConverter x:Key="BlockLabelConverter"/>
        <converters:BlockCountLabelConverter x:Key="BlockCountLabelConverter"/>
        <converters:InvertBoolConverter x:Key="InvertBoolConverter"/>
        <converters:NotNullConverter x:Key="NotNullConverter"/>
        <converters:StatusToColorConverter x:Key="StatusToColorConverter"/>
        <converters:TimeSpanConverter x:Key="TimeSpanConverter"/>

        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Opacity" Value="1"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.9"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Opacity" Value="0.78"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.45"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Application.Resources>
</Application>
