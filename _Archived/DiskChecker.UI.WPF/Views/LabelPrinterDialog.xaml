<Window x:Class="DiskChecker.UI.WPF.Views.LabelPrinterDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Tisk Štítku Disku" 
        WindowStartupLocation="CenterOwner"
        SizeToContent="WidthAndHeight"
        Background="{DynamicResource ThemeBackgroundBrush}"
        Foreground="{DynamicResource ThemeForegroundBrush}"
        ShowInTaskbar="False"
        WindowStyle="ToolWindow">
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0" 
                   Text="Vyberte Velikost Štítku"
                   FontSize="18"
                   FontWeight="Bold"
                   Foreground="#1a1a1a"
                   Margin="0,0,0,15"/>

        <!-- Options -->
        <StackPanel Grid.Row="1" Margin="0,0,0,20">
            <RadioButton x:Name="rbMinimal" 
                         GroupName="LabelSize"
                         Margin="0,0,0,10"
                         FontSize="12">
                <StackPanel Orientation="Vertical" Margin="5,0,0,0">
                    <TextBlock Text="📋 Minimální (A10, 105x148mm)" 
                              FontWeight="Bold"
                              Foreground="#1a1a1a"/>
                    <TextBlock Text="Datum, známka, ID disku"
                              FontSize="11"
                              Foreground="#666666"
                              Margin="0,2,0,0"/>
                </StackPanel>
            </RadioButton>

            <RadioButton x:Name="rbSmall"
                         GroupName="LabelSize"
                         Margin="0,0,0,10"
                         FontSize="12">
                <StackPanel Orientation="Vertical" Margin="5,0,0,0">
                    <TextBlock Text="🏷️ Malý (A9, 74x105mm)"
                              FontWeight="Bold"
                              Foreground="#1a1a1a"/>
                    <TextBlock Text="Známka, teplota, základní údaje"
                              FontSize="11"
                              Foreground="#666666"
                              Margin="0,2,0,0"/>
                </StackPanel>
            </RadioButton>

            <RadioButton x:Name="rbStandard"
                         GroupName="LabelSize"
                         IsChecked="True"
                         Margin="0,0,0,10"
                         FontSize="12">
                <StackPanel Orientation="Vertical" Margin="5,0,0,0">
                    <TextBlock Text="⭐ Standardní (A7, 74x52mm) - Doporučeno"
                              FontWeight="Bold"
                              Foreground="#1a1a1a"/>
                    <TextBlock Text="Nejčastější velikost - teplota, čtení, rychlost"
                              FontSize="11"
                              Foreground="#666666"
                              Margin="0,2,0,0"/>
                </StackPanel>
            </RadioButton>

            <RadioButton x:Name="rbLarge"
                         GroupName="LabelSize"
                         Margin="0,0,0,10"
                         FontSize="12">
                <StackPanel Orientation="Vertical" Margin="5,0,0,0">
                    <TextBlock Text="📊 Velký (A5, 148x210mm)"
                              FontWeight="Bold"
                              Foreground="#1a1a1a"/>
                    <TextBlock Text="Detailní info s grafy a metriky"
                              FontSize="11"
                              Foreground="#666666"
                              Margin="0,2,0,0"/>
                </StackPanel>
            </RadioButton>

            <RadioButton x:Name="rbA4"
                         GroupName="LabelSize"
                         Margin="0,0,0,0"
                         FontSize="12">
                <StackPanel Orientation="Vertical" Margin="5,0,0,0">
                    <TextBlock Text="📄 Kompletní Report (A4)"
                              FontWeight="Bold"
                              Foreground="#1a1a1a"/>
                    <TextBlock Text="Úplný certifikát s historií a všemi údaji"
                              FontSize="11"
                              Foreground="#666666"
                              Margin="0,2,0,0"/>
                </StackPanel>
            </RadioButton>
        </StackPanel>

        <!-- Info -->
        <Border Grid.Row="2"
                Background="#E3F2FD"
                BorderBrush="#004B93"
                BorderThickness="1"
                CornerRadius="4"
                Padding="10"
                Margin="0,0,0,20">
            <TextBlock Text="💡 Tip: Standardní velikost lze tisknutí rovnou po testu. Větší štítky vyžadují větší tiskárnu."
                      Foreground="#004B93"
                      TextWrapping="Wrap"
                      FontSize="11"/>
        </Border>

        <!-- Buttons -->
        <Grid Grid.Row="3" Margin="0,20,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="1"
                    Content="Storno"
                    Click="CancelButton_Click"
                    Style="{StaticResource ActionButtonStyle}"
                    Background="#999999"
                    Foreground="White"
                    Padding="15,10"
                    Margin="0,0,10,0"
                    Width="80"/>

            <Button Grid.Column="2"
                    Content="Tisk"
                    Click="PrintButton_Click"
                    Style="{StaticResource ActionButtonStyle}"
                    Background="#004B93"
                    Foreground="White"
                    Padding="15,10"
                    Width="80"/>
        </Grid>
    </Grid>
</Window>
