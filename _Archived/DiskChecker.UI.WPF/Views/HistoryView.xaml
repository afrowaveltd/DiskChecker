<UserControl x:Class="DiskChecker.UI.WPF.Views.HistoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:oxy="http://oxyplot.org/wpf"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="1000"
             Background="#F5F5F5">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#FFFFFF" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="20">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="📚 Historie Testů" FontSize="24" FontWeight="Bold" Foreground="#1a1a1a" VerticalAlignment="Center"/>
                <Button Content="🔄 Obnovit"
                        Command="{Binding RefreshHistoryCommand}"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource InvertBoolConverter}}"
                        Style="{StaticResource ActionButtonStyle}"
                        Background="#004B93"
                        Foreground="White"
                        Padding="12,8"
                        Margin="20,0,0,0"
                        FontWeight="Bold"
                        Cursor="Hand"/>
                <Button Content="📄 Export CSV"
                        Command="{Binding ExportToCsvCommand}"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource InvertBoolConverter}}"
                        Style="{StaticResource ActionButtonStyle}"
                        Background="#005A2B"
                        Foreground="White"
                        Padding="12,8"
                        Margin="10,0,0,0"
                        FontWeight="Bold"
                        Cursor="Hand"/>
                <ComboBox ItemsSource="{Binding UniqueDrives}"
                          SelectedItem="{Binding SelectedDriveFilter}"
                          Width="200"
                          Margin="10,0,0,0"
                          VerticalAlignment="Center">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" TextTrimming="CharacterEllipsis"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1" Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="{Binding ShowDriveDetailWidth}"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#FFFFFF" BorderBrush="#E0E0E0" BorderThickness="1" Padding="10">
                <DataGrid ItemsSource="{Binding HistoryItems}"
                          SelectedItem="{Binding SelectedItem}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          GridLinesVisibility="Horizontal"
                          HeadersVisibility="Column"
                          RowHeaderWidth="0"
                          Background="White"
                          BorderThickness="0"
                          SelectionMode="Single"
                          SelectionUnit="FullRow">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Datum" Binding="{Binding TestDate, StringFormat={}{0:dd.MM.yyyy HH:mm}}" Width="140"/>
                        <DataGridTextColumn Header="Disk" Binding="{Binding DriveName}" Width="*"/>
                        <DataGridTextColumn Header="Sériové číslo" Binding="{Binding SerialNumber}" Width="150"/>
                        <DataGridTextColumn Header="Typ testu" Binding="{Binding TestType}" Width="100"/>
                        <DataGridTextColumn Header="Známka" Binding="{Binding Grade}" Width="70"/>
                        <DataGridTextColumn Header="Skóre" Binding="{Binding Score, StringFormat={}{0:F1}}" Width="70"/>
                        <DataGridTextColumn Header="Chyby" Binding="{Binding ErrorCount}" Width="70"/>
                    </DataGrid.Columns>
                    <DataGrid.InputBindings>
                        <MouseBinding MouseAction="LeftDoubleClick" 
                                      Command="{Binding ShowDriveHistoryCommand}"
                                      CommandParameter="{Binding SelectedItem.DriveName}"/>
                    </DataGrid.InputBindings>
                </DataGrid>
            </Border>

            <Border Grid.Column="1" Background="#FFFFFF" BorderBrush="#E0E0E0" BorderThickness="1" Padding="15" Margin="10,0,0,0" Width="400" CornerRadius="4" 
                    Visibility="{Binding ShowDriveDetail, Converter={StaticResource BoolToVisibilityConverter}}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="📊 Historie disku" FontSize="16" FontWeight="Bold" Foreground="#1a1a1a"/>
                        <Button Content="✕ Zavřít"
                                Command="{Binding CloseDriveDetailCommand}"
                                Background="Transparent"
                                Foreground="#666666"
                                BorderThickness="0"
                                Margin="150,0,0,0"
                                Cursor="Hand"/>
                    </StackPanel>

                    <Border Grid.Row="1" Background="#F5F5F5" Padding="10" Margin="0,0,0,10" CornerRadius="4">
                        <TextBlock Text="{Binding DriveSummary}" Foreground="#333333" FontSize="11" TextWrapping="Wrap"/>
                    </Border>

                    <oxy:PlotView Grid.Row="2" Model="{Binding TrendPlotModel}" Background="White"/>

                    <TextBlock Grid.Row="3" Text="{Binding StatusMessage}" Foreground="#666666" FontSize="10" Margin="0,10,0,0" TextWrapping="Wrap"/>
                </Grid>
            </Border>
        </Grid>

        <TextBlock Grid.Row="2"
                   Text="{Binding StatusMessage}"
                   Background="#F0F0F0"
                   Padding="20,8"
                   FontSize="11"
                   Foreground="#666666"
                   TextTrimming="CharacterEllipsis"/>
    </Grid>
</UserControl>