<UserControl x:Class="DiskChecker.UI.WPF.Views.ReportView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:oxy="http://oxyplot.org/wpf"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="1000"
             Background="#F5F5F5">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#FFFFFF" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="20">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="📄 Reporty Testů" FontSize="24" FontWeight="Bold" Foreground="#1a1a1a" VerticalAlignment="Center"/>
                <Button Content="🔄 Obnovit"
                        Command="{Binding RefreshReportCommand}"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource InvertBoolConverter}}"
                        Style="{StaticResource ActionButtonStyle}"
                        Background="#004B93"
                        Foreground="White"
                        Padding="12,8"
                        Margin="20,0,0,0"
                        FontWeight="Bold"
                        Cursor="Hand"/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1" Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="{Binding ShowTestDetailWidth}"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <UniformGrid Grid.Row="0" Columns="4" Margin="0,0,0,10">
                    <Border Background="#FFFFFF" BorderBrush="#E0E0E0" BorderThickness="1" Padding="12" Margin="0,0,8,0">
                        <StackPanel>
                            <TextBlock Text="Celkem testů" Foreground="#666666" FontSize="11"/>
                            <TextBlock Text="{Binding TotalTests}" FontSize="20" FontWeight="Bold" Foreground="#1a1a1a"/>
                        </StackPanel>
                    </Border>
                    <Border Background="#FFFFFF" BorderBrush="#E0E0E0" BorderThickness="1" Padding="12" Margin="0,0,8,0">
                        <StackPanel>
                            <TextBlock Text="SMART testy" Foreground="#666666" FontSize="11"/>
                            <TextBlock Text="{Binding SmartCheckTests}" FontSize="20" FontWeight="Bold" Foreground="#004B93"/>
                        </StackPanel>
                    </Border>
                    <Border Background="#FFFFFF" BorderBrush="#E0E0E0" BorderThickness="1" Padding="12" Margin="0,0,8,0">
                        <StackPanel>
                            <TextBlock Text="Surface testy" Foreground="#666666" FontSize="11"/>
                            <TextBlock Text="{Binding SurfaceTests}" FontSize="20" FontWeight="Bold" Foreground="#005A2B"/>
                        </StackPanel>
                    </Border>
                    <Border Background="#FFFFFF" BorderBrush="#E0E0E0" BorderThickness="1" Padding="12">
                        <StackPanel>
                            <TextBlock Text="Průměrné skóre" Foreground="#666666" FontSize="11"/>
                            <TextBlock Text="{Binding AverageScore, StringFormat={}{0:F1}}" FontSize="20" FontWeight="Bold" Foreground="#1a1a1a"/>
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <Border Grid.Row="1" Background="#E3F2FD" BorderBrush="#004B93" BorderThickness="1" Padding="10" Margin="0,0,0,10" CornerRadius="4">
                    <TextBlock Text="💡 Klikněte na řádek v tabulce pro zobrazení detailu testu včetně grafu rychlosti."
                               Foreground="#004B93" FontSize="11" TextWrapping="Wrap"/>
                </Border>

                <Border Grid.Row="2" Background="#FFFFFF" BorderBrush="#E0E0E0" BorderThickness="1" Padding="10">
                    <DataGrid ItemsSource="{Binding RecentTests}"
                              SelectedItem="{Binding SelectedTest}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              GridLinesVisibility="Horizontal"
                              HeadersVisibility="Column"
                              RowHeaderWidth="0"
                              Background="White"
                              BorderThickness="0"
                              SelectionMode="Single"
                              SelectionUnit="FullRow">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Datum" Binding="{Binding TestDate, StringFormat={}{0:dd.MM.yyyy HH:mm}}" Width="140"/>
                            <DataGridTextColumn Header="Disk" Binding="{Binding DriveName}" Width="*"/>
                            <DataGridTextColumn Header="Typ" Binding="{Binding TestType}" Width="120"/>
                            <DataGridTextColumn Header="Známka" Binding="{Binding Grade}" Width="70"/>
                            <DataGridTextColumn Header="Skóre" Binding="{Binding Score, StringFormat={}{0:F1}}" Width="70"/>
                            <DataGridTextColumn Header="Chyby" Binding="{Binding ErrorCount}" Width="70"/>
                        </DataGrid.Columns>
                        <DataGrid.InputBindings>
                            <MouseBinding MouseAction="LeftDoubleClick" 
                                          Command="{Binding ShowTestDetailCommand}"
                                          CommandParameter="{Binding SelectedTest.TestId}"/>
                        </DataGrid.InputBindings>
                    </DataGrid>
                </Border>
            </Grid>

            <Border Grid.Column="1" Background="#FFFFFF" BorderBrush="#E0E0E0" BorderThickness="1" Padding="15" Margin="10,0,0,0" Width="450" CornerRadius="4" 
                    Visibility="{Binding ShowTestDetail, Converter={StaticResource BoolToVisibilityConverter}}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="📊 Detail Testu" FontSize="16" FontWeight="Bold" Foreground="#1a1a1a"/>
                        <Button Content="✕ Zavřít"
                                Command="{Binding CloseTestDetailCommand}"
                                Background="Transparent"
                                Foreground="#666666"
                                BorderThickness="0"
                                Margin="130,0,0,0"
                                Cursor="Hand"/>
                    </StackPanel>

                    <Border Grid.Row="1" Background="#F5F5F5" Padding="10" Margin="0,0,0,10" CornerRadius="4">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{Binding TestDetailInfo}" Foreground="#333333" FontSize="11" TextWrapping="Wrap"/>
                            <TextBlock Grid.Column="1" Text="{Binding TestDetailStats}" Foreground="#333333" FontSize="11" TextWrapping="Wrap" Margin="10,0,0,0"/>
                        </Grid>
                    </Border>

                    <oxy:PlotView Grid.Row="2" Model="{Binding SpeedPlotModel}" Background="White"/>

                    <TextBlock Grid.Row="3" Text="{Binding StatusMessage}" Foreground="#666666" FontSize="10" Margin="0,10,0,0" TextWrapping="Wrap"/>
                </Grid>
            </Border>
        </Grid>

        <TextBlock Grid.Row="2"
                   Text="{Binding StatusMessage}"
                   Background="#F0F0F0"
                   Padding="20,8"
                   FontSize="11"
                   Foreground="#666666"
                   TextTrimming="CharacterEllipsis"/>
    </Grid>
</UserControl>