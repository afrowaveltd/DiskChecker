<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="using:DiskChecker.UI.Avalonia.Converters"
             x:Class="DiskChecker.UI.Avalonia.App"
             xmlns:local="using:DiskChecker.UI.Avalonia"
             RequestedThemeVariant="Light">
             <!-- "Light" ThemeVariant for consistent light theme -->

    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>
  
    <Application.Styles>
        <FluentTheme />
        <StyleInclude Source="avares://DiskChecker.UI.Avalonia/Styles/CommonStyles.axaml"/>
    </Application.Styles>
    
    <Application.Resources>
        <!-- Theme palette (light, high contrast) -->
        <SolidColorBrush x:Key="ThemeBackgroundBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="ThemePanelBrush" Color="#F8F9FA"/>
        <SolidColorBrush x:Key="ThemeCardBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="ThemeBorderBrush" Color="#DEE2E6"/>
        <SolidColorBrush x:Key="ThemePrimaryBrush" Color="#004B93"/>
        <SolidColorBrush x:Key="ThemeAccentBrush" Color="#F7C600"/>
        
        <!-- Text colors for contrast -->
        <SolidColorBrush x:Key="ThemeTextPrimaryBrush" Color="#1A1A1A"/>
        <SolidColorBrush x:Key="ThemeTextSecondaryBrush" Color="#495057"/>
        <SolidColorBrush x:Key="ThemeTextMutedBrush" Color="#6C757D"/>
        
        <!-- Converters -->
        <converters:BooleanToBrushConverter x:Key="BooleanToBrushConverter"/>
        <converters:InverseBooleanConverter x:Key="InverseBooleanConverter"/>
        <converters:EnumToBooleanConverter x:Key="EnumToBooleanConverter"/>
        <!-- Simple NotNull converter used in views -->
        <converters:NotNullConverter x:Key="NotNullConverter"/>
    </Application.Resources>
</Application>