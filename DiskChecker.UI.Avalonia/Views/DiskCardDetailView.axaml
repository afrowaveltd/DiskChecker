<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:DiskChecker.UI.Avalonia.ViewModels"
             xmlns:converters="using:DiskChecker.UI.Avalonia.Converters"
             xmlns:dg="clr-namespace:Avalonia.Controls;assembly=Avalonia.Controls.DataGrid"
             x:Class="DiskChecker.UI.Avalonia.Views.DiskCardDetailView"
             Background="{DynamicResource ThemeBackgroundBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ========== HEADER ========== -->
        <Border Grid.Row="0" Background="{DynamicResource ThemePanelBackgroundBrush}"
                BorderBrush="{DynamicResource ThemeBorderBrush}"
                BorderThickness="0,0,0,1" Padding="16,10" MinHeight="60">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="📋 Detail Karty Disku" Classes="PageTitle"/>
                    <TextBlock Text="Kompletní historie testů a zdraví disku" Classes="PageSubtitle"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="📄 Generovat certifikát"
                            Command="{Binding GenerateCertificateCommand}"
                            IsEnabled="{Binding HasTestSessions}"
                            Background="{DynamicResource ThemeSuccessBrush}" Foreground="White"
                            FontWeight="Bold" Padding="12,6" Margin="0,0,8,0"
                            Cursor="Hand"/>
                    <Button Content="🧭 Interní prohlížeč"
                            Command="{Binding OpenCertificateViewerCommand}"
                            IsEnabled="{Binding HasTestSessions}"
                            Background="{DynamicResource ThemeInfoBrush}" Foreground="White"
                            FontWeight="Bold" Padding="12,6" Margin="0,0,8,0"
                            Cursor="Hand"/>
                    <Button Content="🏠 Zpět na přehled"
                            Command="{Binding NavigateBackCommand}"
                            Background="{DynamicResource ThemeSecondaryBackgroundBrush}" Foreground="{DynamicResource ThemeTextPrimaryBrush}"
                            BorderBrush="{DynamicResource ThemeBorderBrush}"
                            FontWeight="Bold" Padding="12,6"
                            Cursor="Hand"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ========== DISK INFO ========== -->
        <Border Grid.Row="1" Background="{DynamicResource ThemeSecondaryBackgroundBrush}" Margin="16,10,16,0" Padding="12" CornerRadius="8"
                BorderBrush="{DynamicResource ThemeBorderBrush}" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <!-- Basic Info -->
                <StackPanel Grid.Column="0">
                    <TextBlock Text="💾 Informace o disku" FontSize="14" FontWeight="Bold" Margin="0,0,0,10"/>
                    
                    <Grid Margin="0,3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Model:" FontSize="11" Foreground="{DynamicResource ThemeTextMutedBrush}"/>
                        <TextBlock Grid.Column="1" Text="{Binding Card.ModelName}" FontSize="12" FontWeight="Bold"/>
                    </Grid>
                    <Grid Margin="0,3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Sériové č.:" FontSize="11" Foreground="{DynamicResource ThemeTextMutedBrush}"/>
                        <TextBlock Grid.Column="1" Text="{Binding Card.SerialNumber}" FontSize="11" FontFamily="Consolas"/>
                    </Grid>
                    <Grid Margin="0,3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Kapacita:" FontSize="11" Foreground="{DynamicResource ThemeTextMutedBrush}"/>
                        <TextBlock Grid.Column="1" Text="{Binding Card.CapacityText}" FontSize="11"/>
                    </Grid>
                    <Grid Margin="0,3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Typ disku:" FontSize="11" Foreground="{DynamicResource ThemeTextMutedBrush}"/>
                        <TextBlock Grid.Column="1" Text="{Binding Card.DiskType}" FontSize="11"/>
                    </Grid>
                    <Grid Margin="0,3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Počet testů:" FontSize="11" Foreground="{DynamicResource ThemeTextMutedBrush}"/>
                        <TextBlock Grid.Column="1" Text="{Binding Card.TestCount}" FontSize="11" FontWeight="Bold"/>
                    </Grid>
                </StackPanel>

                <!-- Separator -->
                <Separator Grid.Column="1" Background="{DynamicResource ThemeBorderBrush}" Margin="20,0"/>

                <!-- Grade & Score -->
                <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="Celkové hodnocení" FontSize="11" Foreground="{DynamicResource ThemeTextMutedBrush}" HorizontalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,5">
                        <TextBlock Text="{Binding Card.OverallGrade}" FontSize="42" FontWeight="Bold"
                                   Foreground="{Binding GradeColor}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="Skóre: " FontSize="12"/>
                        <TextBlock Text="{Binding Card.OverallScore, StringFormat={}{0:F0}}" FontSize="12" FontWeight="Bold"/>
                        <TextBlock Text="%" FontSize="12"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ========== TABS ========== -->
        <TabControl Grid.Row="2" Margin="20,15,20,15">
            <!-- Test History Tab -->
            <TabItem Header="📊 Historie testů">
                <Grid Margin="10">
                    <DataGrid ItemsSource="{Binding TestSessions}"
                              SelectedItem="{Binding SelectedSession}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              FontSize="12">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Datum" Binding="{Binding TestedAt, StringFormat={}{0:dd.MM.yyyy HH:mm}}" Width="130"/>
                            <DataGridTextColumn Header="Typ testu" Binding="{Binding TestType}" Width="120"/>
                            <DataGridTextColumn Header="Známka" Binding="{Binding Grade}" Width="60"/>
                            <DataGridTextColumn Header="Skóre" Binding="{Binding Score, StringFormat={}{0:F0}}" Width="60"/>
                            <dg:DataGridTemplateColumn Header="Signály" Width="170">
                                <dg:DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Background="{Binding DiagnosticBadgeBackground}"
                                                CornerRadius="999"
                                                Padding="10,4"
                                                HorizontalAlignment="Left"
                                                VerticalAlignment="Center">
                                            <TextBlock Text="{Binding DiagnosticBadgeText}"
                                                       Foreground="{Binding DiagnosticBadgeForeground}"
                                                       FontSize="10"
                                                       FontWeight="Bold"/>
                                        </Border>
                                    </DataTemplate>
                                </dg:DataGridTemplateColumn.CellTemplate>
                            </dg:DataGridTemplateColumn>
                            <DataGridTextColumn Header="Flagy" Binding="{Binding DiagnosticFlagsText}" Width="120"/>
                            <DataGridTextColumn Header="Sektory" Binding="{Binding SectorsTested}" Width="80"/>
                            <DataGridTextColumn Header="Chyby" Binding="{Binding ErrorCount}" Width="60"/>
                            <DataGridTextColumn Header="Teplota" Binding="{Binding Temperature, StringFormat={}{0}°C}" Width="80"/>
                            <DataGridTextColumn Header="Throttle" Binding="{Binding ThermalThrottlingText}" Width="90"/>
                            <DataGridTextColumn Header="Trvání" Binding="{Binding Duration, StringFormat={}{0} min}" Width="70"/>
                            <DataGridTextColumn Header="Poznámky" Binding="{Binding Notes}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- SMART History Tab -->
            <TabItem Header="📈 SMART trend">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Vývoj SMART atributů v čase" FontSize="11" Foreground="{DynamicResource ThemeTextMutedBrush}" Margin="0,0,0,10"/>

                    <DataGrid Grid.Row="1" ItemsSource="{Binding SmartHistory}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              FontSize="12">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Datum" Binding="{Binding TestedAt, StringFormat={}{0:dd.MM.yyyy HH:mm}}" Width="130"/>
                            <DataGridTextColumn Header="Známka" Binding="{Binding Grade}" Width="65"/>
                            <DataGridTextColumn Header="Skóre" Binding="{Binding Score, StringFormat={}{0:F0}}" Width="65"/>
                            <DataGridTextColumn Header="Teplota" Binding="{Binding Temperature, StringFormat={}{0}°C}" Width="80"/>
                            <DataGridTextColumn Header="Provozní hodiny" Binding="{Binding PowerOnHours}" Width="110"/>
                            <DataGridTextColumn Header="Reallocated" Binding="{Binding ReallocatedSectors}" Width="90"/>
                            <DataGridTextColumn Header="Pending" Binding="{Binding PendingSectors}" Width="70"/>
                            <DataGridTextColumn Header="Uncorrectable" Binding="{Binding ReadErrors}" Width="95"/>
                            <DataGridTextColumn Header="Media errors" Binding="{Binding ReallocEvents}" Width="90"/>
                            <DataGridTextColumn Header="Poznámky" Binding="{Binding Notes}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <TabItem Header="🧾 SMART snapshot">
                <Grid Margin="10" RowDefinitions="Auto,Auto,Auto,Auto,Auto,*">
                    <Border Grid.Row="0" Background="{DynamicResource ThemeSecondaryBackgroundBrush}" Padding="10" CornerRadius="6" Margin="0,0,0,10">
                        <StackPanel Spacing="8">
                            <Border Background="{Binding SelectedSessionDiagnosticBadgeBackground}" CornerRadius="999" Padding="10,4" HorizontalAlignment="Left">
                                <TextBlock Text="{Binding SelectedSessionDiagnosticBadgeText}" FontSize="11" FontWeight="Bold"
                                           Foreground="{Binding SelectedSessionDiagnosticBadgeForeground}"/>
                            </Border>
                            <TextBlock Text="{Binding SelectedSessionDiagnosticSummary}" TextWrapping="Wrap" FontSize="11" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="1" Background="{DynamicResource ThemeSecondaryBackgroundBrush}" Padding="10" CornerRadius="6" Margin="0,0,0,10"
                            IsVisible="{Binding HasSelectedSessionDiagnosticHighlights}">
                        <TextBlock Text="{Binding SelectedSessionDiagnosticHighlights}" TextWrapping="Wrap" FontFamily="Consolas" FontSize="11"/>
                    </Border>

                    <Border Grid.Row="2" Background="{DynamicResource ThemeSecondaryBackgroundBrush}" Padding="10" CornerRadius="6" Margin="0,0,0,10">
                        <TextBlock Text="{Binding SelectedSessionSmartSummary}" TextWrapping="Wrap" FontFamily="Consolas" FontSize="11"/>
                    </Border>

                    <Border Grid.Row="3" Background="{DynamicResource ThemeSecondaryBackgroundBrush}" Padding="10" CornerRadius="6" Margin="0,0,0,10">
                        <TextBlock Text="{Binding SelectedSessionDegradationSummary}" TextWrapping="Wrap" FontFamily="Consolas" FontSize="11"/>
                    </Border>

                    <Border Grid.Row="4" Background="{DynamicResource ThemeSecondaryBackgroundBrush}" Padding="10" CornerRadius="6" Margin="0,0,0,10">
                        <TextBlock Text="{Binding SelectedSessionErrorSummary}" TextWrapping="Wrap" FontFamily="Consolas" FontSize="11"/>
                    </Border>

                    <Border Grid.Row="5" Background="{DynamicResource ThemeSecondaryBackgroundBrush}" Padding="10" CornerRadius="6">
                         <TextBox Text="{Binding SelectedSessionSmartJson}"
                                  IsReadOnly="True"
                                  AcceptsReturn="True"
                                  TextWrapping="NoWrap"
                                  FontFamily="Consolas"
                                  FontSize="11"
                                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                  Watermark="Vyberte test se SMART snapshotem"/>
                     </Border>
                 </Grid>
             </TabItem>

            <!-- Notes Tab -->
            <TabItem Header="📝 Poznámky">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBox Grid.Row="0"
                             Text="{Binding Notes}"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             Watermark="Zadejte poznámky k tomuto disku..."
                             FontSize="12"
                             Padding="10"/>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                        <Button Content="💾 Uložit poznámky"
                                Command="{Binding SaveNotesCommand}"
                                Background="{DynamicResource ThemeSuccessBrush}" Foreground="White"
                                FontWeight="Bold" Padding="12,6" Cursor="Hand"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- Disk Info Tab -->
            <TabItem Header="📄 Informace">
                <Grid Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left: Device Info -->
                    <StackPanel Grid.Column="0" Margin="0,0,10,0">
                        <TextBlock Text="Zařízení" FontSize="14" FontWeight="Bold" Margin="0,0,0,10"/>
                        
                        <Border Background="{DynamicResource ThemeSecondaryBackgroundBrush}" Padding="10" CornerRadius="4" Margin="0,0,0,10">
                            <StackPanel>
                                <Grid Margin="0,2">
                                    <TextBlock Grid.Column="0" Text="Cesta:" FontSize="11" Foreground="{DynamicResource ThemeTextMutedBrush}" Width="120"/>
                                    <TextBlock Text="{Binding Card.DevicePath}" FontSize="11" FontFamily="Consolas"/>
                                </Grid>
                                <Grid Margin="0,2">
                                    <TextBlock Text="Firmware:" FontSize="11" Foreground="{DynamicResource ThemeTextMutedBrush}" Width="120"/>
                                    <TextBlock Text="{Binding Card.FirmwareVersion}" FontSize="11"/>
                                </Grid>
                                <Grid Margin="0,2">
                                    <TextBlock Text="Vyrobce:" FontSize="11" Foreground="{DynamicResource ThemeTextMutedBrush}" Width="120"/>
                                    <TextBlock Text="{Binding Card.Manufacturer}" FontSize="11"/>
                                </Grid>
                                <Grid Margin="0,2">
                                    <TextBlock Text="Vytvořeno:" FontSize="11" Foreground="{DynamicResource ThemeTextMutedBrush}" Width="120"/>
                                    <TextBlock Text="{Binding Card.CreatedAt, StringFormat={}{0:dd.MM.yyyy HH:mm}}" FontSize="11"/>
                                </Grid>
                                <Grid Margin="0,2">
                                    <TextBlock Text="Aktualizováno:" FontSize="11" Foreground="{DynamicResource ThemeTextMutedBrush}" Width="120"/>
                                    <TextBlock Text="{Binding Card.UpdatedAt, StringFormat={}{0:dd.MM.yyyy HH:mm}}" FontSize="11"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- Right: Statistics -->
                    <StackPanel Grid.Column="1" Margin="10,0,0,0">
                        <TextBlock Text="Statistiky" FontSize="14" FontWeight="Bold" Margin="0,0,0,10"/>
                        
                        <Border Background="{DynamicResource ThemeSecondaryBackgroundBrush}" Padding="10" CornerRadius="4">
                            <StackPanel>
                                <Grid Margin="0,3">
                                    <TextBlock Text="Celkem testů:" FontSize="11" Foreground="{DynamicResource ThemeTextMutedBrush}" Width="140"/>
                                    <TextBlock Text="{Binding Card.TestCount}" FontSize="11" FontWeight="Bold"/>
                                </Grid>
                                <Grid Margin="0,3">
                                    <TextBlock Text="Průměrné skóre:" FontSize="11" Foreground="{DynamicResource ThemeTextMutedBrush}" Width="140"/>
                                    <TextBlock Text="{Binding AverageScore, StringFormat={}{0:F1}}" FontSize="11"/>
                                </Grid>
                                <Grid Margin="0,3">
                                    <TextBlock Text="Poslední známka:" FontSize="11" Foreground="{DynamicResource ThemeTextMutedBrush}" Width="140"/>
                                    <TextBlock Text="{Binding Card.OverallGrade}" FontSize="11" FontWeight="Bold"/>
                                </Grid>
                                <Grid Margin="0,3">
                                    <TextBlock Text="Nejlepší známka:" FontSize="11" Foreground="{DynamicResource ThemeTextMutedBrush}" Width="140"/>
                                    <TextBlock Text="{Binding BestGrade}" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource ThemeSuccessBrush}"/>
                                </Grid>
                                <Grid Margin="0,3">
                                    <TextBlock Text="Nejhorší známka:" FontSize="11" Foreground="{DynamicResource ThemeTextMutedBrush}" Width="140"/>
                                    <TextBlock Text="{Binding WorstGrade}" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource ThemeDangerBrush}"/>
                                </Grid>
                                <Grid Margin="0,3">
                                    <TextBlock Text="Celkem test. sektorů:" FontSize="11" Foreground="{DynamicResource ThemeTextMutedBrush}" Width="140"/>
                                    <TextBlock Text="{Binding TotalSectorsTested}" FontSize="11"/>
                                </Grid>
                                <Grid Margin="0,3">
                                    <TextBlock Text="Celkem chyb:" FontSize="11" Foreground="{DynamicResource ThemeTextMutedBrush}" Width="140"/>
                                    <TextBlock Text="{Binding TotalErrors}" FontSize="11"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- ========== STATUS BAR ========== -->
        <Border Grid.Row="3" Classes="StatusBar" Padding="16,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="{Binding StatusMessage}" Classes="StatusText"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Panel IsVisible="{Binding IsLoading}">
                        <TextBlock Text="⏳ Načítám..." FontSize="10" Foreground="{DynamicResource ThemeWarningBrush}"/>
                    </Panel>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>