<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:DiskChecker.UI.Avalonia.ViewModels"
             xmlns:dg="clr-namespace:Avalonia.Controls;assembly=Avalonia.Controls.DataGrid"
             x:Class="DiskChecker.UI.Avalonia.Views.HistoryView"
             Background="{DynamicResource ThemeBackgroundBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ========== HEADER ========== -->
        <Border Grid.Row="0" 
                Classes="PageHeader">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel>
                    <TextBlock Text="{Binding L[HistoryView.TestHistory]}" Classes="PageTitle"/>
                    <TextBlock Text="{Binding L[HistoryView.AllTestsOverview]}" Classes="PageSubtitle"/>
                    <TextBlock Text="{Binding StatusMessage}" Classes="PageMetaText" Margin="0,2,0,0"/>
                </StackPanel>
                <Button Grid.Column="1"
                        Content="{Binding L[Common.Back]}"
                        Command="{Binding GoBackCommand}"
                        Background="{DynamicResource ThemeSecondaryBackgroundBrush}"
                        Foreground="{DynamicResource ThemeTextPrimaryBrush}"
                        BorderBrush="{DynamicResource ThemeBorderBrush}"
                        VerticalAlignment="Center"
                        CornerRadius="6"
                        Padding="14,8"
                        FontWeight="SemiBold"/>
            </Grid>
        </Border>

        <!-- ========== FILTERS ========== -->
        <Border Grid.Row="1" Padding="16,8">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button Content="{Binding L[HistoryView.Refresh]}"
                            Command="{Binding RefreshCommand}"
                            Background="{DynamicResource ThemePrimaryBrush}"
                            Foreground="White"
                            CornerRadius="6"
                            Padding="10,6"
                            FontWeight="SemiBold"/>
                    <Button Content="{Binding L[HistoryView.ClearHistory]}"
                            Command="{Binding ClearHistoryCommand}"
                            Background="{DynamicResource ThemeSecondaryBackgroundBrush}"
                            Foreground="{DynamicResource ThemeTextPrimaryBrush}"
                            BorderBrush="{DynamicResource ThemeBorderBrush}"
                            CornerRadius="6"
                            Padding="10,6"/>
                </StackPanel>
                
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="{Binding L[HistoryView.Filter]}" FontSize="10" 
                              Foreground="{DynamicResource ThemeTextMutedBrush}"
                              VerticalAlignment="Center"/>
                    <ComboBox ItemsSource="{Binding FilterOptions}"
                              SelectedIndex="{Binding SelectedFilterIndex}"
                              Background="{DynamicResource ThemeCardBackgroundBrush}"
                              BorderBrush="{DynamicResource ThemeBorderBrush}"
                              Padding="8,4"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ========== DATA GRID ========== -->
        <Border Grid.Row="2" 
               Background="{DynamicResource ThemeCardBackgroundBrush}"
               BorderBrush="{DynamicResource ThemeBorderBrush}"
               BorderThickness="1"
               Margin="16,0"
               CornerRadius="8">
            <dg:DataGrid ItemsSource="{Binding FilteredTests}"
                        SelectedItem="{Binding SelectedTest}"
                        IsReadOnly="True"
                        HeadersVisibility="Column"
                        AutoGenerateColumns="False"
                        GridLinesVisibility="Horizontal"
                        Background="Transparent"
                        BorderThickness="0"
                        SelectionMode="Single">
                <dg:DataGrid.Columns>
                    <dg:DataGridTextColumn Header="{Binding L[HistoryView.Date]}" Binding="{Binding TestDate, StringFormat='{}{0:dd.MM.yyyy HH:mm}'}" Width="130"/>
                    <dg:DataGridTextColumn Header="{Binding L[HistoryView.Disk]}" Binding="{Binding DiskName}" Width="*"/>
                    <dg:DataGridTextColumn Header="{Binding L[HistoryView.Type]}" Binding="{Binding TestType}" Width="90"/>
                    <dg:DataGridTemplateColumn Header="{Binding L[HistoryView.Grade]}" Width="70">
                        <dg:DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border Background="{Binding Grade, Converter={StaticResource GradeToColorConverter}}"
                                       CornerRadius="4" Padding="6,2">
                                    <TextBlock Text="{Binding Grade}" 
                                              FontWeight="Bold"
                                              FontSize="11"
                                              Foreground="White"
                                              HorizontalAlignment="Center"/>
                                </Border>
                            </DataTemplate>
                        </dg:DataGridTemplateColumn.CellTemplate>
                    </dg:DataGridTemplateColumn>
                    <dg:DataGridTextColumn Header="{Binding L[HistoryView.Score]}" Binding="{Binding Score, StringFormat='{}{0}%'}" Width="60"/>
                    <dg:DataGridTextColumn Header="{Binding L[HistoryView.Errors]}" Binding="{Binding ErrorCount}" Width="60"/>
                    <dg:DataGridTemplateColumn Header="{Binding L[HistoryView.Actions]}" Width="80">
                        <dg:DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="{Binding L[HistoryView.Detail]}"
                                        Command="{Binding $parent[DataGrid].DataContext.ViewDetailsCommand}"
                                        CommandParameter="{Binding}"
                                        Background="{DynamicResource ThemeSecondaryBackgroundBrush}"
                                        Foreground="{DynamicResource ThemeTextPrimaryBrush}"
                                        BorderBrush="{DynamicResource ThemeBorderBrush}"
                                        FontSize="9"
                                        Padding="6,2"
                                        CornerRadius="4"/>
                            </DataTemplate>
                        </dg:DataGridTemplateColumn.CellTemplate>
                    </dg:DataGridTemplateColumn>
                </dg:DataGrid.Columns>
            </dg:DataGrid>
        </Border>

        <!-- ========== STATUS BAR ========== -->
        <Border Grid.Row="3" Classes="StatusBar">
            <StackPanel Orientation="Horizontal" Margin="16,0" Spacing="8">
                <TextBlock FontSize="10" Foreground="{DynamicResource ThemeTextMutedBrush}" VerticalAlignment="Center">
                    <Run Text="{Binding L[HistoryView.TotalTests]}" />
                    <Run Text="{Binding Tests.Count}" FontWeight="Bold"/>
                </TextBlock>
                <TextBlock Text="|" Foreground="{DynamicResource ThemeTextMutedBrush}" VerticalAlignment="Center"/>
                <TextBlock FontSize="10" Foreground="{DynamicResource ThemeTextMutedBrush}" VerticalAlignment="Center">
                    <Run Text="{Binding L[HistoryView.AvgScore]}" />
                    <Run Text="{Binding AverageScore, StringFormat='{}{0:F1}%'}" FontWeight="Bold"/>
                </TextBlock>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>