<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:DiskChecker.UI.Avalonia.ViewModels"
             x:Class="DiskChecker.UI.Avalonia.Views.AnalysisView"
             Background="{DynamicResource ThemeBackgroundBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ========== HEADER ========== -->
        <Border Grid.Row="0" 
                Classes="PageHeader">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel>
                    <TextBlock Text="{Binding L[AnalysisView.SurfaceAnalysis]}" Classes="PageTitle"/>
                    <TextBlock Text="{Binding L[AnalysisView.ComplexCheck]}" Classes="PageSubtitle"/>
                    <TextBlock Text="{Binding StatusMessage}" Classes="PageMetaText" Margin="0,2,0,0"/>
                </StackPanel>
                <Button Grid.Column="1"
                        Content="{Binding L[Common.Back]}"
                        Command="{Binding $parent[UserControl].DataContext.NavigationService.NavigateToDiskSelectionCommand}"
                        Background="{DynamicResource ThemeSecondaryBackgroundBrush}"
                        Foreground="{DynamicResource ThemeTextPrimaryBrush}"
                        BorderBrush="{DynamicResource ThemeBorderBrush}"
                        VerticalAlignment="Center"
                        CornerRadius="6"
                        Padding="14,8"
                        FontWeight="SemiBold"/>
            </Grid>
        </Border>

        <!-- ========== MAIN CONTENT ========== -->
        <Grid Grid.Row="1" Margin="16" ColumnDefinitions="1*,2*">
            
            <!-- ========== CONTROLS PANEL ========== -->
            <Border Grid.Column="0" 
                   Background="{DynamicResource ThemeCardBackgroundBrush}"
                   BorderBrush="{DynamicResource ThemeBorderBrush}"
                   BorderThickness="1"
                   CornerRadius="8"
                   Padding="16"
                   Margin="0,0,8,0">
                <StackPanel Spacing="12">
                    <TextBlock Text="{Binding L[AnalysisView.TestSettings]}" 
                              FontSize="14" FontWeight="Bold" 
                              Foreground="{DynamicResource ThemeTextPrimaryBrush}"
                              Margin="0,0,0,8"/>

                    <Border Background="{DynamicResource ThemePanelBackgroundBrush}" 
                           CornerRadius="6" Padding="10">
                        <StackPanel Spacing="8">
                            <CheckBox Content="{Binding L[AnalysisView.QuickTest]}" 
                                      IsChecked="True"
                                      FontSize="11"/>
                            <CheckBox Content="{Binding L[AnalysisView.DetailedAnalysis]}" 
                                      IsChecked="False"
                                      FontSize="11"/>
                            <CheckBox Content="{Binding L[AnalysisView.AutoFix]}" 
                                      IsChecked="False"
                                      FontSize="11"/>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="{Binding L[AnalysisView.TestPriority]}" 
                              FontSize="12" FontWeight="SemiBold"
                              Foreground="{DynamicResource ThemeTextPrimaryBrush}"
                              Margin="0,8,0,4"/>
                    
                    <ComboBox SelectedIndex="1" 
                              HorizontalAlignment="Stretch"
                              Background="{DynamicResource ThemeCardBackgroundBrush}"
                              BorderBrush="{DynamicResource ThemeBorderBrush}"
                              Padding="10,6">
                        <ComboBoxItem Content="{Binding L[AnalysisView.LowPriority]}"/>
                        <ComboBoxItem Content="{Binding L[AnalysisView.Normal]}"/>
                        <ComboBoxItem Content="{Binding L[AnalysisView.HighPriority]}"/>
                    </ComboBox>

                    <Border Height="1" Background="{DynamicResource ThemeBorderBrush}" Margin="0,8"/>

                    <StackPanel Spacing="8">
                        <Button Content="{Binding L[AnalysisView.StartAnalysis]}"
                                Command="{Binding StartAnalysisCommand}"
                                IsEnabled="{Binding IsAnalyzing, Converter={StaticResource InverseBooleanConverter}}"
                                Background="{DynamicResource ThemeSuccessBrush}"
                                Foreground="White"
                                FontWeight="SemiBold"
                                HorizontalAlignment="Stretch"
                                CornerRadius="6"
                                Padding="12,10">
                            <Button.Styles>
                                <Style Selector="Button:pointerover">
                                    <Setter Property="Opacity" Value="0.9"/>
                                </Style>
                            </Button.Styles>
                        </Button>

                        <Button Content="{Binding L[AnalysisView.StopAnalysis]}"
                                Command="{Binding CancelAnalysisCommand}"
                                IsEnabled="{Binding IsAnalyzing}"
                                Background="{DynamicResource ThemeDangerBrush}"
                                Foreground="White"
                                FontWeight="SemiBold"
                                HorizontalAlignment="Stretch"
                                CornerRadius="6"
                                Padding="12,10">
                            <Button.Styles>
                                <Style Selector="Button:pointerover">
                                    <Setter Property="Opacity" Value="0.9"/>
                                </Style>
                            </Button.Styles>
                        </Button>
                    </StackPanel>

                    <!-- Quick Stats -->
                    <Border Background="{DynamicResource ThemePanelBackgroundBrush}" 
                           CornerRadius="6" Padding="10" Margin="0,8,0,0">
                        <StackPanel>
                            <TextBlock Text="{Binding L[AnalysisView.QuickStats]}" 
                                      FontSize="11" FontWeight="SemiBold"
                                      Foreground="{DynamicResource ThemeTextPrimaryBrush}"
                                      Margin="0,0,0,6"/>
                            <Grid ColumnDefinitions="*,*">
                                <StackPanel>
                                    <TextBlock Text="{Binding L[AnalysisView.Tests]}" FontSize="9" Foreground="{DynamicResource ThemeTextMutedBrush}"/>
                                    <TextBlock Text="0" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource ThemePrimaryBrush}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="{Binding L[AnalysisView.Errors]}" FontSize="9" Foreground="{DynamicResource ThemeTextMutedBrush}"/>
                                    <TextBlock Text="0" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource ThemeSuccessBrush}"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <!-- ========== PROGRESS AND RESULTS ========== -->
            <Grid Grid.Column="1" Margin="8,0,0,0" RowDefinitions="Auto,*">
                
                <!-- Progress Section -->
                <Border Grid.Row="0" 
                       Background="{DynamicResource ThemeCardBackgroundBrush}"
                       BorderBrush="{DynamicResource ThemeBorderBrush}"
                       BorderThickness="1"
                       CornerRadius="8"
                       Padding="16"
                       Margin="0,0,0,8">
                    <StackPanel Spacing="8">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0" Text="{Binding L[AnalysisView.Progress]}" 
                                      FontSize="14" FontWeight="Bold"
                                      Foreground="{DynamicResource ThemeTextPrimaryBrush}"/>
                            <TextBlock Grid.Column="1" 
                                      Text="{Binding ProgressPercentage, StringFormat='{}{0}%'}"
                                      FontSize="14" FontWeight="Bold"
                                      Foreground="{DynamicResource ThemePrimaryBrush}"/>
                        </Grid>
                        
                        <ProgressBar Value="{Binding ProgressPercentage}" 
                                    Minimum="0" Maximum="100" 
                                    Height="10"
                                    CornerRadius="5"
                                    Background="{DynamicResource ThemeBorderLightBrush}"
                                    Foreground="{DynamicResource ThemePrimaryBrush}"/>
                        
                        <TextBlock Text="{Binding L[AnalysisView.PercentDone]}"
                                  HorizontalAlignment="Center" FontSize="10"
                                  Foreground="{DynamicResource ThemeTextMutedBrush}"/>
                    </StackPanel>
                </Border>

                <!-- Results Section -->
                <Border Grid.Row="1" 
                       Background="{DynamicResource ThemeCardBackgroundBrush}"
                       BorderBrush="{DynamicResource ThemeBorderBrush}"
                       BorderThickness="1"
                       CornerRadius="8"
                       Padding="16">
                    <Grid RowDefinitions="Auto,*">
                        <TextBlock Grid.Row="0" Text="{Binding L[AnalysisView.TestResults]}" 
                                  FontSize="14" FontWeight="Bold"
                                  Foreground="{DynamicResource ThemeTextPrimaryBrush}"
                                  Margin="0,0,0,10"/>

                        <ScrollViewer Grid.Row="1">
                            <ItemsControl ItemsSource="{Binding TestResults}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{DynamicResource ThemePanelBackgroundBrush}"
                                               CornerRadius="6"
                                               Padding="12"
                                               Margin="0,0,0,8">
                                            <Grid RowDefinitions="Auto,Auto">
                                                <Grid Grid.Row="0" ColumnDefinitions="*,Auto">
                                                    <TextBlock Grid.Column="0" 
                                                              Text="{Binding TestId}" 
                                                              FontWeight="SemiBold"
                                                              FontSize="11"/>
                                                    <TextBlock Grid.Column="1" 
                                                              Text="{Binding ErrorCount, StringFormat='{}{0}'}" 
                                                              Foreground="{DynamicResource ThemeTextMutedBrush}"
                                                              FontSize="10"/>
                                                </Grid>
                                                <TextBlock Grid.Row="1" 
                                                          Text="{Binding Notes}" 
                                                          FontSize="10"
                                                          Foreground="{DynamicResource ThemeTextSecondaryBrush}"
                                                          TextWrapping="Wrap"
                                                          Margin="0,4,0,0"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <!-- ========== STATUS BAR ========== -->
        <Border Grid.Row="2" Classes="StatusBar">
            <TextBlock Text="{Binding StatusMessage}" 
                      Classes="StatusText"
                      Margin="16,0"/>
        </Border>
    </Grid>
</UserControl>