<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:DiskChecker.UI.Avalonia.ViewModels"
             x:Class="DiskChecker.UI.Avalonia.Views.ReportView"
             Background="{DynamicResource ThemeBackgroundBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ========== HEADER ========== -->
        <Border Grid.Row="0" Background="{DynamicResource ThemePanelBackgroundBrush}" BorderBrush="{DynamicResource ThemeBorderBrush}" BorderThickness="0,0,0,1" Padding="16,10" MinHeight="60">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="📊 Reporty" Classes="PageTitle"/>
                    <TextBlock Text="Historie všech testů" Classes="PageSubtitle"/>
                    <TextBlock Text="{Binding StatusMessage}" Classes="PageMetaText" Margin="0,2,0,0"/>
                </StackPanel>

                <Button Grid.Column="1"
                        Content="🏠 Zpět"
                        Command="{Binding NavigateBackCommand}"
                        Background="{DynamicResource ThemeSecondaryBackgroundBrush}" Foreground="{DynamicResource ThemeTextPrimaryBrush}"
                        BorderBrush="{DynamicResource ThemeBorderBrush}"
                        VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- ========== MAIN CONTENT ========== -->
        <Grid Grid.Row="1" Margin="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>

            <!-- ========== REPORT LIST ========== -->
            <Border Grid.Column="0" Background="{DynamicResource ThemePanelBackgroundBrush}" BorderBrush="{DynamicResource ThemeBorderBrush}" BorderThickness="1" Margin="0,0,8,0" Padding="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="📋 Seznam testů" FontSize="15" FontWeight="Bold" Foreground="{DynamicResource ThemeTextPrimaryBrush}" Margin="0,0,0,8"/>

                    <!-- Vyhledávací pole -->
                    <TextBox Grid.Row="1" 
                             Text="{Binding SearchText}" 
                             Watermark="🔍 Vyhledat podle názvu, sériového čísla, modelu, grade nebo data..."
                             Margin="0,0,0,8"
                             Background="{DynamicResource ThemeSecondaryBackgroundBrush}"
                             Foreground="{DynamicResource ThemeTextPrimaryBrush}"
                             BorderBrush="{DynamicResource ThemeBorderBrush}"/>

                    <DataGrid Grid.Row="2" 
                              ItemsSource="{Binding FilteredReports}" 
                              SelectedItem="{Binding SelectedReport}"
                              IsReadOnly="True"
                              CanUserResizeColumns="True"
                              CanUserSortColumns="True"
                              GridLinesVisibility="Horizontal"
                              Background="{DynamicResource ThemePanelBackgroundBrush}"
                              Foreground="{DynamicResource ThemeTextPrimaryBrush}"
                              RowBackground="{DynamicResource ThemePanelBackgroundBrush}"
                              FontSize="11">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Datum" 
                                               Binding="{Binding TestDate, StringFormat='{}{0:dd.MM.yyyy HH:mm}'}" 
                                               Width="120"/>
                            
                            <DataGridTextColumn Header="Sériové číslo" 
                                               Binding="{Binding SerialNumber}" 
                                               Width="140"/>
                            
                            <DataGridTextColumn Header="Model" 
                                               Binding="{Binding DeviceName}" 
                                               Width="130"/>
                            
                            <DataGridTextColumn Header="Typ" 
                                               Binding="{Binding Title}" 
                                               Width="*"/>
                            
                            <DataGridTextColumn Header="Skóre" 
                                               Binding="{Binding Score, StringFormat='{}{0:F0}'}" 
                                               Width="55"/>
                            
                            <DataGridTextColumn Header="Grade" 
                                               Binding="{Binding Grade}" 
                                               Width="50"/>
                            
                            <DataGridTextColumn Header="Chyby" 
                                               Binding="{Binding ErrorCount}" 
                                               Width="55"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <!-- ========== REPORT DETAILS ========== -->
            <Grid Grid.Column="1" Margin="8,0,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="{DynamicResource ThemePanelBackgroundBrush}" BorderBrush="{DynamicResource ThemeBorderBrush}" BorderThickness="1" Margin="0,0,0,8" Padding="12">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            
                            <Border Grid.Column="0" Background="{Binding SelectedReport.Grade, Converter={StaticResource GradeToColorConverter}}" 
                                    CornerRadius="4" Padding="6,3" Margin="0,0,10,0">
                                <TextBlock Text="{Binding SelectedReport.Grade}" FontSize="14" FontWeight="Bold" Foreground="White"/>
                            </Border>
                            
                            <TextBlock Grid.Column="1" Text="{Binding SelectedReport.Title}" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource ThemeTextPrimaryBrush}" VerticalAlignment="Center"/>
                            
                            <TextBlock Grid.Column="2" Text="{Binding SelectedReport.Score, StringFormat='{}{0:F0}/100'}" 
                                       FontSize="14" FontWeight="Bold" Foreground="{DynamicResource ThemeTextPrimaryBrush}" VerticalAlignment="Center"/>
                        </Grid>
                        
                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <TextBlock Grid.Column="0" Text="Disk:" FontWeight="Bold" Margin="0,0,5,0"/>
                            <TextBlock Grid.Column="1" Text="{Binding SelectedReport.SerialNumber}" Margin="0,0,20,0" TextTrimming="CharacterEllipsis"/>
                            
                            <TextBlock Grid.Column="2" Text="Model:" FontWeight="Bold" Margin="0,0,5,0"/>
                            <TextBlock Grid.Column="3" Text="{Binding SelectedReport.DeviceName}" TextTrimming="CharacterEllipsis"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Grid.Row="1" Background="{DynamicResource ThemePanelBackgroundBrush}" BorderBrush="{DynamicResource ThemeBorderBrush}" BorderThickness="1" Margin="0,0,0,8" Padding="12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="📈 Metriky" FontSize="15" FontWeight="Bold" Foreground="{DynamicResource ThemeTextPrimaryBrush}" Margin="0,0,0,10"/>

                        <UniformGrid Grid.Row="1" Columns="2" Rows="3">
                            <Border Background="{DynamicResource ThemeSecondaryBackgroundBrush}" Margin="2" Padding="10">
                                <StackPanel>
                                    <TextBlock Text="Průměr zápisu" FontSize="12" Foreground="{DynamicResource ThemeTextMutedBrush}"/>
                                    <TextBlock Text="{Binding SelectedReport.AvgWriteSpeed, StringFormat='{}{0:F2} MB/s'}" 
                                               FontSize="16" FontWeight="Bold" Foreground="{DynamicResource ThemeTextPrimaryBrush}"/>
                                </StackPanel>
                            </Border>
                            
                            <Border Background="{DynamicResource ThemeSecondaryBackgroundBrush}" Margin="2" Padding="10">
                                <StackPanel>
                                    <TextBlock Text="Průměr čtení" FontSize="12" Foreground="{DynamicResource ThemeTextMutedBrush}"/>
                                    <TextBlock Text="{Binding SelectedReport.AvgReadSpeed, StringFormat='{}{0:F2} MB/s'}" 
                                               FontSize="16" FontWeight="Bold" Foreground="{DynamicResource ThemeTextPrimaryBrush}"/>
                                </StackPanel>
                            </Border>
                            
                            <Border Background="{DynamicResource ThemeSecondaryBackgroundBrush}" Margin="2" Padding="10">
                                <StackPanel>
                                    <TextBlock Text="Počet chyb" FontSize="12" Foreground="{DynamicResource ThemeTextMutedBrush}"/>
                                    <TextBlock Text="{Binding SelectedReport.ErrorCount}" 
                                               FontSize="16" FontWeight="Bold" Foreground="{DynamicResource ThemeTextPrimaryBrush}"/>
                                </StackPanel>
                            </Border>
                            
                            <Border Background="{DynamicResource ThemeSecondaryBackgroundBrush}" Margin="2" Padding="10">
                                <StackPanel>
                                    <TextBlock Text="Sériové číslo" FontSize="12" Foreground="{DynamicResource ThemeTextMutedBrush}"/>
                                    <TextBlock Text="{Binding SelectedReport.SerialNumber}" 
                                               FontSize="12" FontWeight="Bold" Foreground="{DynamicResource ThemeTextPrimaryBrush}" TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                            </Border>
                        </UniformGrid>
                    </Grid>
                </Border>

                <StackPanel Grid.Row="2" Orientation="Horizontal">
                    <Button Content="📖 Zobrazit v aplikaci" 
                            Command="{Binding ViewGeneratedReportCommand}"
                            Background="{DynamicResource ThemeSecondaryBackgroundBrush}" Foreground="{DynamicResource ThemeTextPrimaryBrush}"
                            BorderBrush="{DynamicResource ThemeBorderBrush}"
                            Padding="14,8" Margin="0,0,8,0"/>

                    <Button Content="📑 Plný report" 
                            Command="{Binding OpenFullReportCommand}"
                            IsEnabled="{Binding SelectedReport, Converter={StaticResource NotNullConverter}}"
                            Background="{DynamicResource ThemeInfoBrush}" Foreground="White" 
                            Padding="14,8" Margin="0,0,8,0"/>

                    <Button Content="💾 Exportovat" 
                            Command="{Binding ExportReportCommand}"
                            IsEnabled="{Binding SelectedReport, Converter={StaticResource NotNullConverter}}"
                            Background="{DynamicResource ThemePrimaryBrush}" Foreground="White" 
                            Padding="14,8" Margin="0,0,8,0"/>
                    
                    <Button Content="🗑️ Smazat" 
                            Command="{Binding DeleteReportCommand}"
                            IsEnabled="{Binding SelectedReport, Converter={StaticResource NotNullConverter}}"
                            Background="{DynamicResource ThemeDangerBrush}" Foreground="White" 
                            Padding="14,8"/>
                </StackPanel>
            </Grid>
        </Grid>

        <!-- ========== STATUS BAR ========== -->
        <Border Grid.Row="2"
                Classes="StatusBar"
                Padding="16,6">
            <TextBlock Text="{Binding StatusMessage}" 
                       Classes="StatusText"
                       TextTrimming="CharacterEllipsis"/>
        </Border>

        <!-- ========== LOADING OVERLAY ========== -->
        <Border Grid.Row="0" Grid.RowSpan="3"
                Background="#CC000000"
                IsVisible="{Binding IsLoading}"
                ZIndex="1000">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <Border Background="{DynamicResource ThemePanelBackgroundBrush}" 
                        BorderBrush="{DynamicResource ThemeBorderBrush}" 
                        BorderThickness="2" 
                        CornerRadius="8" 
                        Padding="40,30">
                    <StackPanel Spacing="15">
                        <TextBlock Text="⏳ Zpracovávám..." 
                                   FontSize="18" 
                                   FontWeight="Bold" 
                                   HorizontalAlignment="Center"
                                   Foreground="{DynamicResource ThemeTextPrimaryBrush}"/>
                        
                        <ProgressBar IsIndeterminate="{Binding IsProgressIndeterminate}" 
                                     Minimum="0"
                                     Maximum="100"
                                     Value="{Binding LoadingProgress}"
                                     Width="300" 
                                     Height="8"
                                     Foreground="{DynamicResource ThemePrimaryBrush}"/>

                        <TextBlock Text="{Binding LoadingProgress, StringFormat='{}{0}%'}"
                                   FontSize="12"
                                   HorizontalAlignment="Center"
                                   Foreground="{DynamicResource ThemeTextPrimaryBrush}"/>
                        
                        <TextBlock Text="{Binding StatusMessage}" 
                                   FontSize="13" 
                                   HorizontalAlignment="Center"
                                   Foreground="{DynamicResource ThemeTextMutedBrush}"
                                   TextWrapping="Wrap"
                                   MaxWidth="350"
                                   TextAlignment="Center"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>