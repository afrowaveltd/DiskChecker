<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="DiskChecker.UI.Avalonia.Views.CertificateView"
             Background="{DynamicResource ThemeBackgroundBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{DynamicResource ThemePanelBackgroundBrush}"
                BorderBrush="{DynamicResource ThemeBorderBrush}"
                BorderThickness="0,0,0,1" Padding="16,10" MinHeight="60">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0">
                    <TextBlock Text="📄 Certifikát disku" Classes="PageTitle"/>
                    <TextBlock Text="Přehled výsledků konkrétního testu" Classes="PageSubtitle"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <CheckBox Content="ČB tisk" IsChecked="{Binding IsBlackAndWhiteMode}" VerticalAlignment="Center"/>
                    <Button Content="💾 Uložit PDF" Command="{Binding ExportPdfCommand}"
                            Background="{DynamicResource ThemeSuccessBrush}" Foreground="White" FontWeight="Bold" Padding="12,6"/>
                    <Button Content="🖨️ Tisk" Command="{Binding PrintCommand}"
                            Background="{DynamicResource ThemeInfoBrush}" Foreground="White" FontWeight="Bold" Padding="12,6"/>
                    <Button Content="🏷️ Štítek" Command="{Binding PrintLabelCommand}"
                            Background="{DynamicResource ThemeWarningBrush}" Foreground="White" FontWeight="Bold" Padding="12,6"/>
                    <Button Content="🏠 Zpět" Command="{Binding GoBackCommand}"
                            Background="{DynamicResource ThemeSecondaryBackgroundBrush}" Foreground="{DynamicResource ThemeTextPrimaryBrush}"
                            BorderBrush="{DynamicResource ThemeBorderBrush}" FontWeight="Bold" Padding="12,6"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Background="White" Margin="28,14" Padding="32"
                BorderBrush="{DynamicResource ThemeBorderBrush}" BorderThickness="1">
            <Border.Styles>
                <Style Selector="TextBlock">
                    <Setter Property="Foreground" Value="#1A1A1A"/>
                </Style>
            </Border.Styles>
            <ScrollViewer>
                <StackPanel Spacing="18">
                    <StackPanel HorizontalAlignment="Center" Spacing="4">
                        <TextBlock Text="CERTIFIKÁT KVALITY DISKU" FontSize="24" FontWeight="Bold"
                                   Foreground="#2A6FD6" HorizontalAlignment="Center"/>
                        <TextBlock Text="DiskChecker – Profesionální diagnóza disků"
                                   FontSize="11" Foreground="#5B6470" HorizontalAlignment="Center"/>
                    </StackPanel>

                    <Separator Background="{DynamicResource ThemeBorderBrush}"/>

                    <Grid ColumnDefinitions="2*,*" ColumnSpacing="16">
                        <Border Grid.Column="0" Background="{Binding PanelBackground}" Padding="14" CornerRadius="8">
                            <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto" RowSpacing="4" ColumnSpacing="10">
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Model:" FontWeight="Bold"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding DiskModel}"/>

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Sériové číslo:" FontWeight="Bold"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SerialNumber}" FontFamily="Consolas"/>

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Kapacita:" FontWeight="Bold"/>
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Capacity}"/>

                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Typ disku:" FontWeight="Bold"/>
                                <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding DiskType}"/>

                                <TextBlock Grid.Row="4" Grid.Column="0" Text="Číslo certifikátu:" FontWeight="Bold"/>
                                <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding CertificateNumber}"/>

                                <TextBlock Grid.Row="5" Grid.Column="0" Text="Vygenerováno:" FontWeight="Bold"/>
                                <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding CurrentDateTime, StringFormat='{}{0:dd.MM.yyyy HH:mm}'}"/>
                            </Grid>
                        </Border>

                        <Border Grid.Column="1" Background="{Binding SealBackground}" Padding="16" CornerRadius="12" BorderBrush="{Binding GradeColor}" BorderThickness="2">
                            <Grid RowDefinitions="Auto,Auto,*" MinHeight="230">
                                <TextBlock Grid.Row="0" Text="KONEČNÁ ZNÁMKA" FontSize="12" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                                <Border Grid.Row="1" Width="120" Height="120" CornerRadius="60" BorderBrush="{Binding GradeColor}" BorderThickness="4" Background="White" HorizontalAlignment="Center">
                                    <TextBlock Text="{Binding Grade}" FontSize="58" FontWeight="Bold" Foreground="{Binding GradeColor}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                               TextAlignment="Center"
                                               RenderTransformOrigin="0.5,0.5">
                                        <TextBlock.RenderTransform>
                                            <TranslateTransform Y="-6"/>
                                        </TextBlock.RenderTransform>
                                    </TextBlock>
                                </Border>
                                <TextBlock Grid.Row="2" Text="{Binding Score}" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,10,0,0"/>
                            </Grid>
                        </Border>
                    </Grid>

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="16">
                        <Border Grid.Column="0" Background="{Binding PanelBackground}" Padding="12" CornerRadius="8">
                            <StackPanel Spacing="4">
                                <TextBlock Text="Výsledky testu" FontWeight="Bold" FontSize="13"/>
                                <TextBlock Text="{Binding TestType, StringFormat='Typ: {0}'}"/>
                                <TextBlock Text="{Binding TestDuration, StringFormat='Doba: {0}'}"/>
                                <TextBlock Text="{Binding Errors, StringFormat='Chyby: {0}'}"/>
                                <TextBlock Text="{Binding TemperatureRange, StringFormat='Teplota: {0}'}"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1" Background="{Binding PanelBackground}" Padding="12" CornerRadius="8">
                            <StackPanel Spacing="4">
                                <TextBlock Text="Výkon" FontWeight="Bold" FontSize="13"/>
                                <TextBlock Text="{Binding AvgWriteSpeed, StringFormat='Průměrný zápis: {0}'}"/>
                                <TextBlock Text="{Binding AvgReadSpeed, StringFormat='Průměrné čtení: {0}'}"/>
                                <TextBlock Text="{Binding HealthStatus, StringFormat='Stav: {0}'}"/>
                                <TextBlock Text="{Binding Recommended, StringFormat='Doporučeno: {0}'}"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Border Background="{Binding PanelBackground}" Padding="12" CornerRadius="8">
                        <StackPanel Spacing="6">
                            <TextBlock Text="SMART souhrn" FontWeight="Bold" FontSize="13"/>
                            <TextBlock Text="{Binding Certificate.PowerOnHours, StringFormat='Provozní hodiny: {0:#,0}'}"/>
                            <TextBlock Text="{Binding Certificate.PowerCycles, StringFormat='Počet startů: {0:#,0}'}"/>
                            <TextBlock Text="{Binding Certificate.ReallocatedSectors, StringFormat='Realokované sektory: {0}'}"/>
                            <TextBlock Text="{Binding Certificate.PendingSectors, StringFormat='Čekající sektory: {0}'}"/>
                        </StackPanel>
                    </Border>

                    <Border Background="{Binding PanelBackground}" Padding="12" CornerRadius="8">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Výkonový profil testu" FontWeight="Bold" FontSize="13"/>

                            <Grid ColumnDefinitions="Auto,*" RowDefinitions="* ,Auto" RowSpacing="4" ColumnSpacing="8">
                                <Grid Grid.Row="0" Grid.Column="0" RowDefinitions="Auto,*,Auto" Height="120">
                                    <TextBlock Grid.Row="0" Text="{Binding ChartMaxSpeedLabel}" FontSize="9" Foreground="{DynamicResource ThemeTextMutedBrush}"/>
                                    <TextBlock Grid.Row="1" Text="{Binding ChartMidSpeedLabel}" FontSize="9" Foreground="{DynamicResource ThemeTextMutedBrush}" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Row="2" Text="{Binding ChartMinSpeedLabel}" FontSize="9" Foreground="{DynamicResource ThemeTextMutedBrush}" VerticalAlignment="Bottom"/>
                                </Grid>

                                <Canvas Grid.Row="0" Grid.Column="1" Height="120" Background="#FFFFFFFF" ClipToBounds="True">
                                    <Line StartPoint="10,10" EndPoint="10,110" Stroke="#FFCBD5E1" StrokeThickness="1"/>
                                    <Line StartPoint="10,60" EndPoint="520,60" Stroke="#FFF1F5F9" StrokeThickness="1"/>
                                    <Line StartPoint="10,110" EndPoint="520,110" Stroke="#FFCBD5E1" StrokeThickness="1"/>

                                    <Polyline Points="{Binding WriteProfilePoints}"
                                              Stroke="{Binding ChartStrokeWrite}" StrokeThickness="2"/>
                                    <Polyline Points="{Binding ReadProfilePoints}"
                                              Stroke="{Binding ChartStrokeRead}" StrokeThickness="2"/>
                                </Canvas>

                                <Grid Grid.Row="1" Grid.Column="1" ColumnDefinitions="Auto,*,Auto">
                                    <TextBlock Grid.Column="0" Text="{Binding ChartXAxisStartLabel}" FontSize="9" Foreground="{DynamicResource ThemeTextMutedBrush}"/>
                                    <TextBlock Grid.Column="1" Text="{Binding ChartXAxisMidLabel}" FontSize="9" Foreground="{DynamicResource ThemeTextMutedBrush}" HorizontalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" Text="{Binding ChartXAxisEndLabel}" FontSize="9" Foreground="{DynamicResource ThemeTextMutedBrush}" HorizontalAlignment="Right"/>
                                </Grid>
                            </Grid>

                            <StackPanel Orientation="Horizontal" Spacing="16">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <Border Width="10" Height="10" Background="{Binding ChartStrokeWrite}" CornerRadius="2"/>
                                    <TextBlock Text="Zápis" FontSize="11"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <Border Width="10" Height="10" Background="{Binding ChartStrokeRead}" CornerRadius="2"/>
                                    <TextBlock Text="Čtení" FontSize="11"/>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <StackPanel Spacing="4">
                        <TextBlock Text="Doporučení" FontWeight="Bold" FontSize="13"/>
                        <TextBlock Text="{Binding RecommendationText}" TextWrapping="Wrap"/>
                    </StackPanel>

                    <StackPanel Spacing="4" IsVisible="{Binding HasScoringReasons}">
                        <TextBlock Text="Důvody hodnocení" FontWeight="Bold" FontSize="13"/>
                        <Border Background="{Binding PanelBackground}" Padding="10" CornerRadius="6">
                            <TextBlock Text="{Binding ScoringReasonsText}" TextWrapping="Wrap"/>
                        </Border>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <Border Grid.Row="2" Classes="StatusBar" Padding="16,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="{Binding StatusMessage}" Classes="StatusText"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Panel IsVisible="{Binding IsLoading}">
                        <TextBlock Text="⏳ Načítám..." FontSize="10" Foreground="{DynamicResource ThemeWarningBrush}"/>
                    </Panel>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>