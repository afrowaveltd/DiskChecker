<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:DiskChecker.UI.Avalonia.ViewModels"
             xmlns:converters="using:DiskChecker.UI.Avalonia.Converters"
             x:Class="DiskChecker.UI.Avalonia.Views.CertificateView"
             Background="{DynamicResource ThemeBackgroundBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ========== HEADER ========== -->
        <Border Grid.Row="0" Background="{DynamicResource ThemePanelBrush}"
                BorderBrush="{DynamicResource ThemeBorderBrush}"
                BorderThickness="0,0,0,1" Padding="20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="📄 Certifikát Disku"
                               FontSize="28" FontWeight="Bold"
                               Foreground="#1a1a1a" Margin="0,0,0,5"/>
                    <TextBlock Text="Oficiální certifikát zdraví a kvality disku"
                               FontSize="13" Foreground="#444444"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="💾 Uložit PDF"
                            Command="{Binding SavePdfCommand}"
                            Background="#27AE60" Foreground="White"
                            FontWeight="Bold" Padding="15,8" Margin="0,0,10,0"
                            Cursor="Hand">
                        <Button.Styles>
                            <Style Selector="Button">
                                <Setter Property="BorderThickness" Value="0"/>
                            </Style>
                        </Button.Styles>
                    </Button>
                    <Button Content="🖨️ Tisk"
                            Command="{Binding PrintCommand}"
                            Background="#3498DB" Foreground="White"
                            FontWeight="Bold" Padding="15,8" Margin="0,0,10,0"
                            Cursor="Hand">
                        <Button.Styles>
                            <Style Selector="Button">
                                <Setter Property="BorderThickness" Value="0"/>
                            </Style>
                        </Button.Styles>
                    </Button>
                    <Button Content="🏠 Zpět"
                            Command="{Binding NavigateBackCommand}"
                            Background="#666666" Foreground="White"
                            FontWeight="Bold" Padding="15,8"
                            Cursor="Hand">
                        <Button.Styles>
                            <Style Selector="Button">
                                <Setter Property="BorderThickness" Value="0"/>
                            </Style>
                        </Button.Styles>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ========== CERTIFICATE PREVIEW ========== -->
        <Border Grid.Row="1" Grid.RowSpan="2" Background="White" Margin="40,20" Padding="40"
                BorderBrush="#DEE2E6" BorderThickness="1">
            <ScrollViewer>
                <StackPanel Spacing="20">
                    <!-- Certificate Header -->
                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="CERTIFIKÁT KVALITY DISKU" FontSize="24" FontWeight="Bold"
                                       Foreground="#004B93" HorizontalAlignment="Center"/>
                            <TextBlock Text="DiskChecker - Profesionální Diagnóza Disků"
                                       FontSize="11" Foreground="#666" HorizontalAlignment="Center"
                                       Margin="0,5,0,0"/>
                        </StackPanel>
                    </Grid>

                    <Separator Background="#DEE2E6" Margin="0,0,0,20"/>

                    <!-- Disk Information -->
                    <Border Background="#F8F9FA" Padding="15" CornerRadius="8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="💻 Model:" FontWeight="Bold" Margin="0,0,0,5"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Certificate.DeviceModel}" Margin="0,0,0,5"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="🔢 Sériové č.:" FontWeight="Bold" Margin="0,0,0,5"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Certificate.SerialNumber}" FontFamily="Consolas" Margin="0,0,0,5"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="💾 Kapacita:" FontWeight="Bold" Margin="0,0,0,5"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Certificate.CapacityText}" Margin="0,0,0,5"/>

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="📁 Typ:" FontWeight="Bold"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding Certificate.DiskType}"/>
                        </Grid>
                    </Border>

                    <!-- Grade Display -->
                    <Border Background="{Binding GradeBackgroundBrush}" Padding="30" CornerRadius="12"
                            HorizontalAlignment="Center">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="CELKOVÉ HODNOCENÍ" FontSize="12" Foreground="#333"
                                       HorizontalAlignment="Center" Margin="0,0,0,5"/>
                            <TextBlock Text="{Binding Certificate.OverallGrade}" FontSize="72" FontWeight="Bold"
                                       Foreground="{Binding GradeColor}" HorizontalAlignment="Center"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                                <TextBlock Text="Skóre: " FontSize="14"/>
                                <TextBlock Text="{Binding Certificate.OverallScore, StringFormat={}{0:F1}}" FontSize="14" FontWeight="Bold"/>
                                <TextBlock Text="% (" FontSize="14"/>
                                <TextBlock Text="{Binding Certificate.QualityRating}" FontSize="14"/>
                                <TextBlock Text=")" FontSize="14"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Test Summary -->
                    <StackPanel Spacing="10">
                        <TextBlock Text="📊 Test proveden:" FontWeight="Bold" FontSize="14" Margin="0,10,0,5"/>
                        
                        <Grid Background="#F8F9FA" Margin="0,0,0,5" ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Datum testu: " FontWeight="Bold"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Certificate.TestDate, StringFormat={}{0:dd.MM.yyyy HH:mm}}"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Typ testu: " FontWeight="Bold"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Certificate.TestType}"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Teplota při testu: " FontWeight="Bold"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Certificate.Temperature, StringFormat={}{0}°C}"/>

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Testováno sektorů: " FontWeight="Bold"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding Certificate.SectorsTested}"/>

                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Nalezeno chyb: " FontWeight="Bold"/>
                            <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding Certificate.ErrorCount}"/>
                        </Grid>
                    </StackPanel>

                    <!-- SMART Attributes -->
                    <StackPanel Spacing="10">
                        <TextBlock Text="🔍 Výběr SMART atributů:" FontWeight="Bold" FontSize="14" Margin="0,10,0,5"/>
                        
                        <Border Background="#F8F9FA" Padding="10"><Grid RowSpacing="5" ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Reallocated Sectors: " FontWeight="Bold"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Certificate.ReallocatedSectors}"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Pending Sectors: " FontWeight="Bold"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Certificate.PendingSectors}"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Provozní hodiny: " FontWeight="Bold"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Certificate.PowerOnHours}"/>

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Počet startů: " FontWeight="Bold"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding Certificate.PowerCycles}"/>

                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Chyby čtení: " FontWeight="Bold"/>
                            <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding Certificate.ReadErrors}"/>

                            <TextBlock Grid.Row="5" Grid.Column="0" Text="Stav disku: " FontWeight="Bold"/>
                            <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding Certificate.HealthStatus}" Foreground="#27AE60"/>
                        </Grid>
                        </Border>
                    </StackPanel>

                    <!-- Recommendations -->
                    <StackPanel Spacing="5">
                        <TextBlock Text="💡 Doporučení:" FontWeight="Bold" FontSize="14" Margin="0,10,0,5"/>
                        <TextBlock Text="{Binding Certificate.Recommendations}" TextWrapping="Wrap" FontSize="11"
                                   Foreground="#333"/>
                    </StackPanel>

                    <Separator Background="#DEE2E6" Margin="0,20,0,20"/>

                    <!-- Footer -->
                    <Grid Margin="0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="ID certifikátu:" FontSize="10" Foreground="#666"/>
                            <TextBlock Text="{Binding Certificate.CertificateId}" FontSize="11" FontFamily="Consolas"/>
                            <TextBlock Text="{Binding CurrentDateTime, StringFormat='Vytvořeno: {0:dd.MM.yyyy HH:mm}'}"
                                       FontSize="10" Foreground="#666" Margin="0,5,0,0"/>
                        </StackPanel>

                        <Border Grid.Column="1" Background="#F8F9FA" Padding="15,5" CornerRadius="4">
                            <StackPanel>
                                <TextBlock Text="DiskChecker v1.0" FontWeight="Bold" FontSize="10"/>
                                <TextBlock Text="Profesionální Diagnóza Disků" FontSize="8" Foreground="#666"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <TextBlock Text="⚠️ Tento certifikát je generován automaticky a slouží pro informační účely. Uživatel by měl zvážit aktuální stav disku před použitím."
                               FontSize="9" Foreground="#888" TextWrapping="Wrap" HorizontalAlignment="Center"/>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- ========== STATUS BAR ========== -->
        <Border Grid.Row="3" Background="#F0F0F0" Padding="20,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="{Binding StatusMessage}" FontSize="11"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Panel IsVisible="{Binding IsGenerating}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⏳ Generuji..." FontSize="11" Foreground="#E67E22"/>
                        </StackPanel>
                    </Panel>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>