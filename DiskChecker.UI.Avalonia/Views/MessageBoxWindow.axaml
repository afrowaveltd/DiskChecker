<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="DiskChecker.UI.Avalonia.Views.MessageBoxWindow"
        Title="{Binding MessageTitle}"
        Width="480"
        SizeToContent="Height"
        MinHeight="150"
        MaxHeight="400"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource ThemeBackgroundBrush}"
        CanResize="False">
    
    <Window.Styles>
        <Style Selector="Button.primary">
            <Setter Property="Background" Value="{DynamicResource ThemePrimaryBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,8"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.primary:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource ThemePrimaryHoverBrush}"/>
        </Style>
        
        <Style Selector="Button.secondary">
            <Setter Property="Background" Value="{DynamicResource ThemeCardBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextSecondaryBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="18,8"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.secondary:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource ThemeSecondaryBackgroundBrush}"/>
        </Style>
        
        <Style Selector="Button.danger">
            <Setter Property="Background" Value="{DynamicResource ThemeDangerBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,8"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Styles>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Header with icon and title -->
        <Border Grid.Row="0" 
                Background="{DynamicResource ThemePrimaryLightBrush}"
                Padding="16,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <!-- Icon -->
                <Border Grid.Column="0" 
                        Background="{DynamicResource ThemeCardBackgroundBrush}"
                        CornerRadius="8"
                        Padding="10"
                        Margin="0,0,12,0">
                    <TextBlock Text="{Binding MessageIcon}" 
                               FontSize="22"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"/>
                </Border>
                
                <!-- Title -->
                <TextBlock Grid.Column="1" 
                           Text="{Binding MessageTitle}" 
                           FontSize="16" 
                           FontWeight="Bold"
                           Foreground="{DynamicResource ThemeTextPrimaryBrush}"
                           VerticalAlignment="Center"
                           TextWrapping="Wrap"/>
            </Grid>
        </Border>
        
        <!-- Message content -->
        <Border Grid.Row="1" Padding="20,16">
            <ScrollViewer MaxHeight="200">
                <TextBlock Text="{Binding Message}" 
                           FontSize="13" 
                           Foreground="{DynamicResource ThemeTextSecondaryBrush}"
                           TextWrapping="Wrap"/>
            </ScrollViewer>
        </Border>
        
        <!-- Buttons -->
        <Border Grid.Row="2" 
                Background="{DynamicResource ThemeSecondaryBackgroundBrush}"
                Padding="16,12">
            <StackPanel Orientation="Horizontal" 
                        HorizontalAlignment="Right" 
                        Spacing="10">
                
                <!-- Cancel button -->
                <Button Content="Zrušit"
                        IsVisible="{Binding ShowCancel}"
                        Command="{Binding CancelCommand}"
                        Classes="secondary"/>
                
                <!-- No button -->
                <Button Content="Ne"
                        IsVisible="{Binding ShowNoButton}"
                        Command="{Binding NoCommand}"
                        Classes="secondary"/>
                
                <!-- Primary button (OK/Yes) -->
                <Button Content="{Binding PrimaryButtonText}"
                        IsVisible="{Binding ShowPrimary}"
                        Command="{Binding PrimaryCommand}"
                        Classes="primary"/>
                
            </StackPanel>
        </Border>
    </Grid>
</Window>