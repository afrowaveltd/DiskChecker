<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="DiskChecker.UI.Avalonia.Views.MessageBoxWindow"
        Title="{Binding MessageTitle}"
        Width="400"
        Height="200"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource ThemeBackgroundBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="20" HorizontalAlignment="Left">
            <TextBlock Text="{Binding MessageIcon}" FontSize="32" Margin="0,0,15,0" VerticalAlignment="Top"/>
            <TextBlock Text="{Binding Message}" 
                       TextWrapping="Wrap" 
                       VerticalAlignment="Center" 
                       FontSize="14"/>
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="20">
            <Button Name="YesButton" Content="Ano" IsVisible="{Binding ShowYesNo}" 
                    Click="YesButton_Click" Margin="0,0,10,0" Width="75"/>
            <Button Name="NoButton" Content="Ne" IsVisible="{Binding ShowYesNo}" 
                    Click="NoButton_Click" Margin="0,0,10,0" Width="75"/>
            <Button Name="OKButton" Content="OK" IsVisible="{Binding ShowOK}" 
                    Click="OKButton_Click" Width="75"/>
            <Button Name="CancelButton" Content="Zrušit" IsVisible="{Binding ShowCancel}" 
                    Click="CancelButton_Click" Margin="0,0,10,0" Width="75"/>
        </StackPanel>
    </Grid>
</Window>
