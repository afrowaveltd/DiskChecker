<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:DiskChecker.UI.Avalonia.ViewModels"
             xmlns:converters="using:DiskChecker.UI.Avalonia.Converters"
             x:Class="DiskChecker.UI.Avalonia.Views.SurfaceTestView"
             Background="{DynamicResource ThemeBackgroundBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ========== HEADER ========== -->
        <Border Grid.Row="0" Background="{DynamicResource ThemePanelBrush}" BorderBrush="{DynamicResource ThemeBorderBrush}" BorderThickness="0,0,0,1" Padding="20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Test Povrchu Disku" 
                               FontSize="28" FontWeight="Bold" Foreground="#1a1a1a" Margin="0,0,0,5"/>
                    <TextBlock Text="Kompletní zápis a ověření celého povrchu disku" 
                               FontSize="13" Foreground="#444444"/>
                    <TextBlock Text="{Binding StatusMessage}" FontSize="11" Foreground="#333333" Margin="0,4,0,0"/>
                </StackPanel>

                <Button Grid.Column="1"
                        Content="← Zpět"
                        Command="{Binding GoBackCommand}"
                        Background="#666666"
                        Foreground="White"
                        VerticalAlignment="Center"
                        Padding="15,8"/>
            </Grid>
        </Border>

        <!-- ========== DISK SELECTION ========== -->
        <Border Grid.Row="1" Background="{DynamicResource ThemePanelBrush}" BorderBrush="{DynamicResource ThemeBorderBrush}" BorderThickness="1" Margin="20,12,20,0" Padding="15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Vybraný disk:" 
                           FontSize="14" FontWeight="Bold" Foreground="#1A1A1A" 
                           VerticalAlignment="Center" Margin="0,0,15,0"/>

                <ComboBox Grid.Column="1" 
                          ItemsSource="{Binding AvailableDrives}"
                          SelectedItem="{Binding SelectedDrive}"
                          IsEnabled="{Binding CanChangeDisk}"
                          HorizontalAlignment="Stretch"
                          Padding="8,6">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="12"/>
                                <TextBlock Text="(" FontSize="12"/>
                                <TextBlock Text="{Binding Path}" FontSize="12" Foreground="#666666"/>
                                <TextBlock Text=")" FontSize="12"/>
                            </StackPanel>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="10" Margin="15,0,0,0">
                    <TextBlock Text="{Binding LockWarningText}" 
                               FontSize="11" Foreground="#D32F2F" FontWeight="Bold"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding CurrentTemperature, StringFormat='🌡 {0}°C'}" 
                               FontSize="14" FontWeight="Bold" Foreground="#D32F2F" 
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ========== DISK INFO ========== -->
        <Border Grid.Row="2" Background="{DynamicResource ThemePanelBrush}" BorderBrush="{DynamicResource ThemeBorderBrush}" BorderThickness="1" Margin="20,8,20,0" Padding="15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="{Binding SelectedDrive.Name}" 
                               FontSize="16" FontWeight="Bold" Foreground="#1A1A1A" Margin="0,0,0,4"/>
                    <TextBlock Text="{Binding SelectedDrive.Path}" 
                               FontSize="12" Foreground="#555555" Margin="0,0,0,4"/>
                    <TextBlock Text="{Binding SelectedDrive.TotalSize, StringFormat='Kapacita: {0:N0} GB'}" 
                               FontSize="12" Foreground="#333333"/>
                </StackPanel>

                <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                    <TextBlock Text="{Binding ErrorCount, StringFormat='⚠ Chyby: {0}'}" 
                               FontSize="14" FontWeight="Bold" Foreground="#E74C3C"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ========== PROGRESS SECTION ========== -->
        <Grid Grid.Row="3" Margin="20,12,20,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <!-- Progress & Graphs -->
            <Grid Grid.Column="0" Margin="0,0,10,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- WRITE Progress -->
                <StackPanel Grid.Row="0" Margin="0,0,0,10">
                    <TextBlock Text="ZÁPIS DAT (0-50%)" FontSize="12" FontWeight="Bold" Foreground="#333333" Margin="0,0,0,4"/>
                    <ProgressBar Value="{Binding WriteProgress}" Maximum="100" 
                                 Height="20" Background="#E6EAF0" Foreground="#27AE60"/>
                    <TextBlock Text="{Binding WriteProgress, StringFormat='{}{0:F1}%'}" 
                               HorizontalAlignment="Right" FontSize="10" Foreground="#27AE60"/>
                </StackPanel>

                <!-- VERIFY Progress -->
                <StackPanel Grid.Row="1" Margin="0,0,0,10">
                    <TextBlock Text="OVĚŘENÍ DAT (50-100%)" FontSize="12" FontWeight="Bold" Foreground="#333333" Margin="0,0,0,4"/>
                    <ProgressBar Value="{Binding VerifyProgress}" Maximum="100" 
                                 Height="20" Background="#E6EAF0" Foreground="#F39C12"/>
                    <TextBlock Text="{Binding VerifyProgress, StringFormat='{}{0:F1}%'}" 
                               HorizontalAlignment="Right" FontSize="10" Foreground="#F39C12"/>
                </StackPanel>

                <!-- Speed Graph -->
                <Border Grid.Row="2" Background="{DynamicResource ThemePanelBrush}" BorderBrush="{DynamicResource ThemeBorderBrush}" BorderThickness="1" Padding="10">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        
                        <TextBlock Grid.Row="0" Text="📊 Průběh rychlosti v čase" FontSize="12" FontWeight="Bold" Foreground="#333333" Margin="0,0,0,8"/>
                        
                        <!-- Speed Statistics -->
                        <Border Grid.Row="1" Background="#F0F9FF" CornerRadius="6" Padding="10" Margin="0,0,0,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                
                                <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                    <TextBlock Text="Aktuální" FontSize="10" Foreground="#666" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding CurrentSpeed, StringFormat='{}{0:F1} MB/s'}" FontSize="16" FontWeight="Bold" Foreground="#2563EB" HorizontalAlignment="Center"/>
                                </StackPanel>
                                
                                <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                    <TextBlock Text="Min" FontSize="10" Foreground="#666" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding MinSpeed, StringFormat='{}{0:F1} MB/s'}" FontSize="16" FontWeight="Bold" Foreground="#059669" HorizontalAlignment="Center"/>
                                </StackPanel>
                                
                                <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                    <TextBlock Text="Max" FontSize="10" Foreground="#666" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding MaxSpeed, StringFormat='{}{0:F1} MB/s'}" FontSize="16" FontWeight="Bold" Foreground="#DC2626" HorizontalAlignment="Center"/>
                                </StackPanel>
                                
                                <StackPanel Grid.Column="3" HorizontalAlignment="Center">
                                    <TextBlock Text="Průměr" FontSize="10" Foreground="#666" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding AvgSpeed, StringFormat='{}{0:F1} MB/s'}" FontSize="16" FontWeight="Bold" Foreground="#7C3AED" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                        
                        <!-- Graph Area -->
                        <Border Grid.Row="2" CornerRadius="8" Padding="10">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                                    <GradientStop Color="#1E3A5F" Offset="0"/>
                                    <GradientStop Color="#0F1F33" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="6*"/>
                                    <RowDefinition Height="4*"/>
                                </Grid.RowDefinitions>
                                
                                <!-- Zoom Controls -->
                                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                                    <TextBlock Text="Časové okno: " FontSize="11" Foreground="#94A3B8" VerticalAlignment="Center"/>
                                    <ComboBox ItemsSource="{Binding ZoomLevels}"
                                              SelectedIndex="{Binding SelectedZoomIndex}"
                                              MinWidth="80" FontSize="11"/>
                                    <TextBlock Text=" | " FontSize="11" Foreground="#64748B" Margin="8,0"/>
                                    <TextBlock FontSize="10" Foreground="#22C55E" Text="■ Zápis" VerticalAlignment="Center"/>
                                    <TextBlock FontSize="10" Foreground="#3B82F6" Text="  ■ Čtení" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                    <TextBlock FontSize="10" Foreground="#F97316" Text="  ■ Teplota" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                </StackPanel>
                                
                                <!-- Speed Graph (Write + Read) - 60% of space -->
                                <Grid Grid.Row="1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <!-- Y-Axis Labels for Speed -->
                                    <StackPanel Grid.Column="0" Orientation="Vertical" Margin="0,0,4,0">
                                        <TextBlock Text="{Binding DisplayMaxSpeed, StringFormat='{}{0:F0}'}" FontSize="8" Foreground="#64748B" TextAlignment="Right" Width="25"/>
                                        <TextBlock Text="{Binding AvgSpeed, StringFormat='{}{0:F0}'}" FontSize="8" Foreground="#64748B" TextAlignment="Right" Width="25" VerticalAlignment="Center"/>
                                        <TextBlock Text="0" FontSize="8" Foreground="#64748B" TextAlignment="Right" Width="25" VerticalAlignment="Bottom"/>
                                    </StackPanel>
                                    
                                    <!-- Graph Area -->
                                    <Grid Grid.Column="1">
                                        <!-- Write Speed Bars (Phase 0) -->
                                        <ItemsControl ItemsSource="{Binding VisibleWriteData}" 
                                                      VerticalAlignment="Stretch"
                                                      HorizontalAlignment="Stretch">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <UniformGrid Rows="1"/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border MinHeight="2"
                                                            Height="{Binding Height}"
                                                            Background="#22C55E"
                                                            CornerRadius="1,1,0,0"
                                                            Margin="0,0,1,0"
                                                            VerticalAlignment="Bottom"
                                                            ToolTip.Tip="{Binding Speed, StringFormat='{}{0:F1} MB/s - Zápis'}"/>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        
                                        <!-- Read Speed Bars (Phase 1) -->
                                        <ItemsControl ItemsSource="{Binding VisibleReadData}" 
                                                      VerticalAlignment="Stretch"
                                                      HorizontalAlignment="Stretch">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <UniformGrid Rows="1"/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border MinHeight="2"
                                                            Height="{Binding Height}"
                                                            Background="#3B82F6"
                                                            CornerRadius="1,1,0,0"
                                                            Margin="0,0,1,0"
                                                            VerticalAlignment="Bottom"
                                                            ToolTip.Tip="{Binding Speed, StringFormat='{}{0:F1} MB/s - Čtení'}"/>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        
                                        <!-- Empty state -->
                                        <TextBlock Text="📈 Spusťte test pro zobrazení grafu"
                                                   VerticalAlignment="Center" HorizontalAlignment="Center"
                                                   FontSize="14" Foreground="#64748B"
                                                   IsVisible="{Binding SpeedHistory.Count, Converter={StaticResource InvertedIntToBoolConverter}}"/>
                                    </Grid>
                                </Grid>
                                
                                <!-- Temperature Graph - 40% of space -->
                                <Grid Grid.Row="2" Margin="0,8,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <!-- Y-Axis Labels for Temperature -->
                                    <StackPanel Grid.Column="0" Orientation="Vertical" Margin="0,0,4,0">
                                        <TextBlock Text="{Binding DisplayMaxTemperature, StringFormat='{}{0}°'}" FontSize="8" Foreground="#F97316" TextAlignment="Right" Width="25"/>
                                        <TextBlock Text="15°" FontSize="8" Foreground="#64748B" TextAlignment="Right" Width="25" VerticalAlignment="Bottom"/>
                                    </StackPanel>
                                    
                                    <ItemsControl Grid.Column="1" ItemsSource="{Binding VisibleTemperatureData}" 
                                                  VerticalAlignment="Stretch"
                                                  HorizontalAlignment="Stretch">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <UniformGrid Rows="1"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border MinHeight="2"
                                                        Height="{Binding Height}"
                                                        Background="#F97316"
                                                        CornerRadius="1"
                                                        Margin="0,0,1,0"
                                                        VerticalAlignment="Bottom"
                                                        ToolTip.Tip="{Binding Temperature, StringFormat='{}{0}°C'}"/>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    
                                    <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="8,0,0,0">
                                        <TextBlock Text="{Binding MinTemperature, StringFormat='Min: {0}°C'}" FontSize="9" Foreground="#64748B" Margin="0,0,8,0"/>
                                        <TextBlock Text="{Binding MaxTemperature, StringFormat='Max: {0}°C'}" FontSize="9" Foreground="#F97316"/>
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>
            </Grid>

            <!-- Test Profiles & Controls -->
            <Grid Grid.Column="1" Margin="10,0,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Test Profiles -->
                <Border Grid.Row="0" Background="{DynamicResource ThemePanelBrush}" BorderBrush="{DynamicResource ThemeBorderBrush}" BorderThickness="1" Padding="10" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="Profily testů" FontSize="12" FontWeight="Bold" Foreground="#333333" Margin="0,0,0,8"/>
                        <ItemsControl ItemsSource="{Binding TestProfiles}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Command="{Binding $parent[ItemsControl].DataContext.SelectProfileCommand}"
                                             CommandParameter="{Binding}"
                                             Background="Transparent"
                                             HorizontalAlignment="Stretch"
                                             HorizontalContentAlignment="Stretch"
                                             Padding="0"
                                             BorderThickness="0">
                                        <Button.Styles>
                                            <Style Selector="Button">
                                                <Setter Property="Cursor" Value="Hand"/>
                                            </Style>
                                        </Button.Styles>
                                        <Border Background="{Binding IsSelected, Converter={StaticResource BooleanToBrushConverter}, ConverterParameter=Selected:#E3F2FD;Normal:#FFFFFF}"
                                                BorderBrush="{Binding IsSelected, Converter={StaticResource BooleanToBrushConverter}, ConverterParameter=Selected:#004B93;Normal:#CCCCCC}"
                                                BorderThickness="1"
                                                CornerRadius="4"
                                                Padding="10"
                                                Margin="0,0,0,5">
                                            <StackPanel>
                                                <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="11" Foreground="#1A1A1A"/>
                                                <TextBlock Text="{Binding Description}" FontSize="10" Foreground="#666666" TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Border>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Statistics -->
                <Border Grid.Row="1" Background="{DynamicResource ThemePanelBrush}" BorderBrush="{DynamicResource ThemeBorderBrush}" BorderThickness="1" Padding="10" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="Statistiky" FontSize="12" FontWeight="Bold" Foreground="#333333" Margin="0,0,0,8"/>
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Aktuální rychlost:" FontSize="11" Foreground="#444444"/>
                            <TextBlock Grid.Column="1" Text="{Binding CurrentSpeed, StringFormat='{}{0:F1} MB/s'}" FontSize="11" FontWeight="Bold" HorizontalAlignment="Right"/>
                        </Grid>
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Zbývající čas:" FontSize="11" Foreground="#444444"/>
                            <TextBlock Grid.Column="1" Text="{Binding TimeRemaining}" FontSize="11" FontWeight="Bold" HorizontalAlignment="Right"/>
                        </Grid>
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Chyby:" FontSize="11" Foreground="#444444"/>
                            <TextBlock Grid.Column="1" Text="{Binding ErrorCount}" FontSize="11" FontWeight="Bold" HorizontalAlignment="Right"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Test Controls -->
                <StackPanel Grid.Row="2" Orientation="Vertical">
                    <Button Content="▶ Spustit Test" 
                            Command="{Binding StartTestCommand}"
                            IsEnabled="{Binding CanStartTest}"
                            Background="#27AE60" Foreground="White" 
                            Padding="15,12" Margin="0,0,0,5">
                        <Button.Styles>
                            <Style Selector="Button">
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="Cursor" Value="Hand"/>
                            </Style>
                        </Button.Styles>
                    </Button>
                    
                    <Button Content="■ Zrušit Test" 
                            Command="{Binding CancelTestCommand}"
                            IsEnabled="{Binding IsTesting}"
                            Background="#E74C3C" Foreground="White" 
                            Padding="15,12">
                        <Button.Styles>
                            <Style Selector="Button">
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="Cursor" Value="Hand"/>
                            </Style>
                        </Button.Styles>
                    </Button>
                </StackPanel>
            </Grid>
        </Grid>

        <!-- ========== STATUS BAR ========== -->
        <TextBlock Grid.Row="4" Text="{Binding StatusMessage}" 
                   Background="#F0F0F0" Padding="20,8" 
                   FontSize="11" Foreground="#333333"
                   TextTrimming="CharacterEllipsis"/>
    </Grid>
</UserControl>