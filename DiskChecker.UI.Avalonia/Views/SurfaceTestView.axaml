<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:DiskChecker.UI.Avalonia.ViewModels"
             xmlns:converters="using:DiskChecker.UI.Avalonia.Converters"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.Avalonia;assembly=LiveChartsCore.SkiaSharpView.Avalonia"
             x:Class="DiskChecker.UI.Avalonia.Views.SurfaceTestView"
             Background="{DynamicResource ThemeBackgroundBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ========== HEADER ========== -->
        <Border Grid.Row="0" 
                Classes="PageHeader">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel>
                    <TextBlock Text="🧪 Test Povrchu Disku" Classes="PageTitle"/>
                    <TextBlock Text="Kompletní zápis a ověření celého povrchu disku" Classes="PageSubtitle"/>
                    <TextBlock Text="{Binding StatusMessage}" Classes="PageMetaText" Margin="0,2,0,0"/>
                </StackPanel>
                <Button Grid.Column="1"
                        Content="← Zpět na přehled"
                        Command="{Binding GoBackCommand}"
                        Background="{DynamicResource ThemeSecondaryBackgroundBrush}"
                        Foreground="{DynamicResource ThemeTextPrimaryBrush}"
                        BorderBrush="{DynamicResource ThemeBorderBrush}"
                        VerticalAlignment="Center"
                        CornerRadius="6"
                        Padding="12,6"
                        FontWeight="SemiBold"/>
            </Grid>
        </Border>

        <!-- ========== DISK SELECTION ========== -->
        <Border Grid.Row="1" Padding="16,6">
            <Grid ColumnDefinitions="*,Auto,Auto">
                <!-- Disk Selection Card -->
                <Border Background="{DynamicResource ThemeCardBackgroundBrush}" 
                        BorderBrush="{DynamicResource ThemeBorderBrush}"
                        CornerRadius="8" Padding="12">
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <TextBlock Text="💿" FontSize="24" Margin="0,0,12,0" VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="Vybraný disk" FontSize="10" Foreground="{DynamicResource ThemeTextMutedBrush}"/>
                            <ComboBox ItemsSource="{Binding AvailableDrives}"
                                     SelectedItem="{Binding SelectedDrive}"
                                     IsEnabled="{Binding CanChangeDisk}"
                                     HorizontalAlignment="Stretch"
                                     Padding="8,4"
                                     FontSize="12">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                                            <TextBlock Text="(" Foreground="{DynamicResource ThemeTextMutedBrush}"/>
                                            <TextBlock Text="{Binding Path}" Foreground="{DynamicResource ThemeTextMutedBrush}"/>
                                            <TextBlock Text=")" Foreground="{DynamicResource ThemeTextMutedBrush}"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Temperature & Lock Status -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="12" Margin="12,0">
                    <Border Background="{DynamicResource ThemeWarningBackgroundBrush}" CornerRadius="6" Padding="10,4">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <TextBlock Text="🌡" FontSize="14"/>
                            <TextBlock Text="{Binding CurrentTemperature, StringFormat='{}{0}°C'}" FontSize="13" FontWeight="Bold" Foreground="{DynamicResource ThemeWarningTextBrush}"/>
                        </StackPanel>
                    </Border>
                    <Border Background="{DynamicResource ThemeWarningBackgroundBrush}" CornerRadius="6" Padding="10,4"
                           BorderBrush="{DynamicResource ThemeWarningBorderBrush}"
                           BorderThickness="1"
                           IsVisible="{Binding IsLocked}">
                        <TextBlock Text="{Binding LockWarningText}" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource ThemeWarningTextBrush}"/>
                    </Border>
                </StackPanel>

                <!-- Error Count -->
                <Border Grid.Column="2" 
                        Background="{DynamicResource ThemeCardBackgroundBrush}"
                        BorderBrush="{DynamicResource ThemeDangerBrush}"
                        BorderThickness="1"
                        CornerRadius="6" 
                        Padding="12,6">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock Text="⚠ Chyby：" FontSize="11" Foreground="{DynamicResource ThemeTextSecondaryBrush}"/>
                        <TextBlock Text="{Binding ErrorCount}" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource ThemeDangerBrush}"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- ========== MAIN TEST AREA ========== -->
        <Border Grid.Row="2" Margin="16,0,16,8">
            <Grid ColumnDefinitions="3*,2*">
                <!-- Graph & Progress -->
                <Border Grid.Column="0" 
                        Background="{DynamicResource ThemeCardBackgroundBrush}"
                        BorderBrush="{DynamicResource ThemeBorderBrush}"
                        CornerRadius="8" Padding="14,10">
                    <Grid RowDefinitions="Auto,Auto,4*">
                        
                        <!-- Progress Headers -->
                        <Grid Grid.Row="0" ColumnDefinitions="*,*" Margin="0,0,0,8">
                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <Ellipse Width="8" Height="8" Fill="{DynamicResource ThemeSuccessBrush}"/>
                                    <TextBlock Text="ZÁPIS DAT (0-50%)" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource ThemeTextPrimaryBrush}"/>
                                </StackPanel>
                                <ProgressBar Value="{Binding WriteProgress}" Maximum="100" Height="10"
                                           Background="{DynamicResource ThemeBorderLightBrush}"
                                           Foreground="{DynamicResource ThemeSuccessBrush}"
                                           CornerRadius="5" Margin="0,4,0,2"/>
                                <TextBlock Text="{Binding WriteProgress, StringFormat='{}{0:F1}%'}" 
                                          FontSize="10" Foreground="{DynamicResource ThemeSuccessBrush}"
                                          HorizontalAlignment="Right"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <Ellipse Width="8" Height="8" Fill="{DynamicResource ThemeWarningBrush}"/>
                                    <TextBlock Text="OVĚŘENÍ DAT (50-100%)" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource ThemeTextPrimaryBrush}"/>
                                </StackPanel>
                                <ProgressBar Value="{Binding VerifyProgress}" Maximum="100" Height="10"
                                           Background="{DynamicResource ThemeBorderLightBrush}"
                                           Foreground="{DynamicResource ThemeWarningBrush}"
                                           CornerRadius="5" Margin="0,4,0,2"/>
                                <TextBlock Text="{Binding VerifyProgress, StringFormat='{}{0:F1}%'}" 
                                          FontSize="10" Foreground="{DynamicResource ThemeWarningBrush}"
                                          HorizontalAlignment="Right"/>
                            </StackPanel>
                        </Grid>

                        <!-- Speed Statistics - Write and Read separated -->
                        <Border Grid.Row="1" Background="{DynamicResource ThemePanelBackgroundBrush}" CornerRadius="6" Padding="8" Margin="0,0,0,8">
                            <Grid RowDefinitions="Auto,4,Auto">
                                <!-- Write Phase Statistics -->
                                <Border Grid.Row="0" Background="{DynamicResource ThemeChartWriteBackgroundBrush}" CornerRadius="4" Padding="6,4">
                                    <Grid ColumnDefinitions="Auto,*,*,*,*">
                                        <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="0,0,8,0">
                                            <Ellipse Width="8" Height="8" Fill="{DynamicResource ThemeChartWriteBrush}" Margin="0,0,4,0"/>
                                            <TextBlock Text="ZÁPIS" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource ThemeChartWriteBrush}" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                            <TextBlock Text="Akt" FontSize="8" Foreground="{DynamicResource ThemeTextMutedBrush}" HorizontalAlignment="Center"/>
                                            <TextBlock Text="{Binding WriteCurrentSpeed, StringFormat='{}{0:F0}'}" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource ThemeChartWriteBrush}" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                            <TextBlock Text="Min" FontSize="8" Foreground="{DynamicResource ThemeTextMutedBrush}" HorizontalAlignment="Center"/>
                                            <TextBlock Text="{Binding WriteMinSpeed, StringFormat='{}{0:F0}'}" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource ThemeChartWriteLightBrush}" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="3" HorizontalAlignment="Center">
                                            <TextBlock Text="Max" FontSize="8" Foreground="{DynamicResource ThemeTextMutedBrush}" HorizontalAlignment="Center"/>
                                            <TextBlock Text="{Binding WriteMaxSpeed, StringFormat='{}{0:F0}'}" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource ThemeChartWriteDarkBrush}" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="4" HorizontalAlignment="Center">
                                            <TextBlock Text="Prům" FontSize="8" Foreground="{DynamicResource ThemeTextMutedBrush}" HorizontalAlignment="Center"/>
                                            <TextBlock Text="{Binding WriteAvgSpeed, StringFormat='{}{0:F0}'}" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource ThemeChartWriteDarkBrush}" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                                
                                <!-- Read Phase Statistics -->
                                <Border Grid.Row="2" Background="{DynamicResource ThemeChartReadBackgroundBrush}" CornerRadius="4" Padding="6,4">
                                    <Grid ColumnDefinitions="Auto,*,*,*,*">
                                        <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="0,0,8,0">
                                            <Ellipse Width="8" Height="8" Fill="{DynamicResource ThemeChartReadBrush}" Margin="0,0,4,0"/>
                                            <TextBlock Text="ČTENÍ" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource ThemeChartReadBrush}" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                            <TextBlock Text="Akt" FontSize="8" Foreground="{DynamicResource ThemeTextMutedBrush}" HorizontalAlignment="Center"/>
                                            <TextBlock Text="{Binding ReadCurrentSpeed, StringFormat='{}{0:F0}'}" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource ThemeChartReadBrush}" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                            <TextBlock Text="Min" FontSize="8" Foreground="{DynamicResource ThemeTextMutedBrush}" HorizontalAlignment="Center"/>
                                            <TextBlock Text="{Binding ReadMinSpeed, StringFormat='{}{0:F0}'}" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource ThemeChartReadLightBrush}" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="3" HorizontalAlignment="Center">
                                            <TextBlock Text="Max" FontSize="8" Foreground="{DynamicResource ThemeTextMutedBrush}" HorizontalAlignment="Center"/>
                                            <TextBlock Text="{Binding ReadMaxSpeed, StringFormat='{}{0:F0}'}" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource ThemeChartReadDarkBrush}" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="4" HorizontalAlignment="Center">
                                            <TextBlock Text="Prům" FontSize="8" Foreground="{DynamicResource ThemeTextMutedBrush}" HorizontalAlignment="Center"/>
                                            <TextBlock Text="{Binding ReadAvgSpeed, StringFormat='{}{0:F0}'}" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource ThemeChartReadDarkBrush}" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Border>

                        <!-- Graph Area -->
                        <Border Grid.Row="2" Background="{DynamicResource ThemeGraphBackgroundBrush}" CornerRadius="8" Padding="10">
                            <Grid RowDefinitions="Auto,Auto,*">
                                <!-- Legend -->
                                <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="12" Margin="0,0,0,8">
                                    <Border Background="{DynamicResource ThemeChartWriteBrush}" Width="10" Height="10" CornerRadius="2"/>
                                    <TextBlock Text="Zápis" FontSize="10" Foreground="{DynamicResource ThemeTextMutedBrush}" VerticalAlignment="Center"/>
                                    <Border Background="{DynamicResource ThemeChartReadBrush}" Width="10" Height="10" CornerRadius="2" Margin="8,0,0,0"/>
                                    <TextBlock Text="Čtení" FontSize="10" Foreground="{DynamicResource ThemeTextMutedBrush}" VerticalAlignment="Center" Margin="4,0,0,0"/>
                                </StackPanel>

                                <!-- Stats Line -->
                                <Border Grid.Row="1" Background="{DynamicResource ThemePanelBackgroundBrush}" CornerRadius="4" Padding="8,4" Margin="0,0,0,8">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="24">
                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                            <TextBlock Text="Y-osa:" FontSize="10" Foreground="{DynamicResource ThemeTextMutedBrush}"/>
                                            <TextBlock Text="{Binding DisplayMaxSpeed, StringFormat='0 - {0:F0} MB/s'}" FontSize="10" Foreground="{DynamicResource ThemeTextSecondaryBrush}" FontWeight="SemiBold"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                            <TextBlock Text="Bodů:" FontSize="10" Foreground="{DynamicResource ThemeTextMutedBrush}"/>
                                            <TextBlock Text="{Binding ChartPointCount}" FontSize="10" Foreground="{DynamicResource ThemeTextSecondaryBrush}" FontWeight="SemiBold"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <!-- Live speed chart -->
                                <Grid Grid.Row="2">
                                    <lvc:CartesianChart Series="{Binding SpeedSeries}"
                                                        XAxes="{Binding SpeedXAxes}"
                                                        YAxes="{Binding SpeedYAxes}"
                                                        ZoomMode="None"
                                                        TooltipPosition="Top"
                                                        LegendPosition="Hidden"
                                                        AnimationsSpeed="0:0:0"/>

                                    <TextBlock Text="📈 Spusťte test pro zobrazení grafu"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Center"
                                               FontSize="12"
                                               Foreground="{DynamicResource ThemeTextMutedBrush}"
                                               IsVisible="{Binding ChartPointCount, Converter={StaticResource InvertedIntToBoolConverter}}"/>
                                </Grid>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>

                <!-- Test Profiles & Controls -->
                <Border Grid.Column="1" 
                        Background="{DynamicResource ThemeCardBackgroundBrush}"
                        BorderBrush="{DynamicResource ThemeBorderBrush}"
                        CornerRadius="8" 
                        Margin="8,0,0,0"
                        Padding="14">
                    <Grid RowDefinitions="Auto,*,Auto">
                        <!-- Test Profiles -->
                        <StackPanel Grid.Row="0">
                            <TextBlock Text="📋 Profily testů" FontSize="12" FontWeight="Bold" 
                                      Foreground="{DynamicResource ThemeTextPrimaryBrush}" Margin="0,0,0,10"/>
                            <ItemsControl ItemsSource="{Binding TestProfiles}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Command="{Binding $parent[ItemsControl].DataContext.SelectProfileCommand}"
                                               CommandParameter="{Binding}"
                                               Background="Transparent" BorderThickness="0"
                                               HorizontalAlignment="Stretch"
                                               HorizontalContentAlignment="Stretch"
                                               Padding="0"
                                               Cursor="Hand">
                                            <Border BorderThickness="2" CornerRadius="8" Padding="12" Margin="0,0,0,8">
                                                <Border.Background>
                                                    <MultiBinding Converter="{StaticResource ProfileBackgroundConverter}">
                                                        <Binding Path="IsSelected"/>
                                                        <Binding Source="{DynamicResource ThemePrimaryLightBrush}"/>
                                                        <Binding Source="{DynamicResource ThemeCardBackgroundBrush}"/>
                                                    </MultiBinding>
                                                </Border.Background>
                                                <Border.BorderBrush>
                                                    <MultiBinding Converter="{StaticResource ProfileBorderConverter}">
                                                        <Binding Path="IsSelected"/>
                                                        <Binding Source="{DynamicResource ThemePrimaryBrush}"/>
                                                        <Binding Source="{DynamicResource ThemeBorderBrush}"/>
                                                    </MultiBinding>
                                                </Border.BorderBrush>
                                                <StackPanel Spacing="4">
                                                    <TextBlock Text="{Binding Name}" FontSize="12" FontWeight="SemiBold"
                                                             Foreground="{DynamicResource ThemeTextPrimaryBrush}"/>
                                                    <TextBlock Text="{Binding Description}" FontSize="10" TextWrapping="Wrap"
                                                             Foreground="{DynamicResource ThemeTextSecondaryBrush}"
                                                             MaxLines="2"/>
                                                </StackPanel>
                                            </Border>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <!-- Statistics -->
                        <Border Grid.Row="1" 
                               Background="{DynamicResource ThemePanelBackgroundBrush}"
                               CornerRadius="6" 
                               Padding="10" 
                               Margin="0,12,0,0">
                            <StackPanel Spacing="6">
                                <TextBlock Text="📊 Statistiky" FontSize="11" FontWeight="Bold"
                                          Foreground="{DynamicResource ThemeTextPrimaryBrush}"/>
                                
                                <!-- Write Phase Stats -->
                                <Border Background="{DynamicResource ThemeChartWriteBackgroundBrush}" CornerRadius="4" Padding="6,4">
                                    <StackPanel Spacing="2">
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                                            <Ellipse Width="6" Height="6" Fill="{DynamicResource ThemeChartWriteBrush}" Margin="0,0,4,0"/>
                                            <TextBlock Text="Zápis" FontSize="9" FontWeight="Bold" Foreground="{DynamicResource ThemeChartWriteBrush}"/>
                                        </StackPanel>
                                        <Grid ColumnDefinitions="*,Auto" Margin="0,1">
                                            <TextBlock Text="Min:" FontSize="9" Foreground="{DynamicResource ThemeTextSecondaryBrush}"/>
                                            <TextBlock Grid.Column="1" Text="{Binding WriteMinSpeed, StringFormat='{}{0:F0} MB/s'}" FontSize="9" FontWeight="Bold" Foreground="{DynamicResource ThemeChartWriteBrush}"/>
                                        </Grid>
                                        <Grid ColumnDefinitions="*,Auto" Margin="0,1">
                                            <TextBlock Text="Max:" FontSize="9" Foreground="{DynamicResource ThemeTextSecondaryBrush}"/>
                                            <TextBlock Grid.Column="1" Text="{Binding WriteMaxSpeed, StringFormat='{}{0:F0} MB/s'}" FontSize="9" FontWeight="Bold" Foreground="{DynamicResource ThemeChartWriteDarkBrush}"/>
                                        </Grid>
                                        <Grid ColumnDefinitions="*,Auto" Margin="0,1">
                                            <TextBlock Text="Průměr:" FontSize="9" Foreground="{DynamicResource ThemeTextSecondaryBrush}"/>
                                            <TextBlock Grid.Column="1" Text="{Binding WriteAvgSpeed, StringFormat='{}{0:F0} MB/s'}" FontSize="9" FontWeight="Bold" Foreground="{DynamicResource ThemeChartWriteDarkBrush}"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                                
                                <!-- Read Phase Stats -->
                                <Border Background="{DynamicResource ThemeChartReadBackgroundBrush}" CornerRadius="4" Padding="6,4">
                                    <StackPanel Spacing="2">
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                                            <Ellipse Width="6" Height="6" Fill="{DynamicResource ThemeChartReadBrush}" Margin="0,0,4,0"/>
                                            <TextBlock Text="Čtení" FontSize="9" FontWeight="Bold" Foreground="{DynamicResource ThemeChartReadBrush}"/>
                                        </StackPanel>
                                        <Grid ColumnDefinitions="*,Auto" Margin="0,1">
                                            <TextBlock Text="Min:" FontSize="9" Foreground="{DynamicResource ThemeTextSecondaryBrush}"/>
                                            <TextBlock Grid.Column="1" Text="{Binding ReadMinSpeed, StringFormat='{}{0:F0} MB/s'}" FontSize="9" FontWeight="Bold" Foreground="{DynamicResource ThemeChartReadBrush}"/>
                                        </Grid>
                                        <Grid ColumnDefinitions="*,Auto" Margin="0,1">
                                            <TextBlock Text="Max:" FontSize="9" Foreground="{DynamicResource ThemeTextSecondaryBrush}"/>
                                            <TextBlock Grid.Column="1" Text="{Binding ReadMaxSpeed, StringFormat='{}{0:F0} MB/s'}" FontSize="9" FontWeight="Bold" Foreground="{DynamicResource ThemeChartReadDarkBrush}"/>
                                        </Grid>
                                        <Grid ColumnDefinitions="*,Auto" Margin="0,1">
                                            <TextBlock Text="Průměr:" FontSize="9" Foreground="{DynamicResource ThemeTextSecondaryBrush}"/>
                                            <TextBlock Grid.Column="1" Text="{Binding ReadAvgSpeed, StringFormat='{}{0:F0} MB/s'}" FontSize="9" FontWeight="Bold" Foreground="{DynamicResource ThemeChartReadDarkBrush}"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                                
                                <!-- Time & Errors -->
                                <Grid ColumnDefinitions="*,Auto" Margin="0,4">
                                    <TextBlock Text="Zbývající čas:" FontSize="10" Foreground="{DynamicResource ThemeTextSecondaryBrush}"/>
                                    <TextBlock Grid.Column="1" Text="{Binding TimeRemaining}" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource ThemeTextPrimaryBrush}" Margin="8,0,0,0"/>
                                </Grid>
                                <Grid ColumnDefinitions="*,Auto" Margin="0,4">
                                    <TextBlock Text="Chyby:" FontSize="10" Foreground="{DynamicResource ThemeTextSecondaryBrush}"/>
                                    <TextBlock Grid.Column="1" Text="{Binding ErrorCount}" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource ThemeDangerBrush}" Margin="8,0,0,0"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Action Buttons -->
                        <StackPanel Grid.Row="2" Spacing="6" Margin="0,14,0,0">
                            <Button Content="▶ Spustit Test"
                                   Command="{Binding StartTestCommand}"
                                   IsEnabled="{Binding CanStartTest}"
                                   Background="{DynamicResource ThemeSuccessBrush}"
                                   Foreground="White"
                                   FontWeight="Bold"
                                   FontSize="12"
                                   HorizontalAlignment="Stretch"
                                   CornerRadius="8"
                                   Padding="12,8">
                                <Button.Styles>
                                    <Style Selector="Button:pointerover">
                                        <Setter Property="Opacity" Value="0.9"/>
                                    </Style>
                                </Button.Styles>
                            </Button>
                            <Button Content="■ Zrušit Test"
                                   Command="{Binding CancelTestCommand}"
                                   IsEnabled="{Binding IsTesting}"
                                   Background="{DynamicResource ThemeDangerBrush}"
                                   Foreground="White"
                                   FontWeight="Bold"
                                   FontSize="12"
                                   HorizontalAlignment="Stretch"
                                   CornerRadius="8"
                                   Padding="12,8">
                                <Button.Styles>
                                    <Style Selector="Button:pointerover">
                                        <Setter Property="Opacity" Value="0.9"/>
                                    </Style>
                                </Button.Styles>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- ========== STATUS BAR ========== -->
        <Border Grid.Row="3" Classes="StatusBar">
            <TextBlock Text="{Binding StatusMessage}" 
                      Classes="StatusText"
                      Margin="16,0"/>
        </Border>
    </Grid>
</UserControl>