<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:DiskChecker.UI.Avalonia.ViewModels"
             xmlns:converters="using:DiskChecker.UI.Avalonia.Converters"
             x:Class="DiskChecker.UI.Avalonia.Views.DiskCardsView"
             Background="{DynamicResource ThemeBackgroundBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ========== HEADER ========== -->
        <Border Grid.Row="0" Background="{DynamicResource ThemePanelBackgroundBrush}"
                BorderBrush="{DynamicResource ThemeBorderBrush}"
                BorderThickness="0,0,0,1" Padding="16,10" MinHeight="60">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="💾 Karty Disků" Classes="PageTitle"/>
                    <TextBlock Text="Historie testů, oddíly a přípojné body" Classes="PageSubtitle"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="📊 Reporty"
                            Command="{Binding NavigateToReportsCommand}"
                            Background="{DynamicResource ThemePrimaryBrush}" Foreground="White"
                            FontWeight="Bold" Padding="12,6" Margin="0,0,8,0"
                            Cursor="Hand"/>
                    <Button Content="🔄 Obnovit"
                            Command="{Binding RefreshCommand}"
                            Background="{DynamicResource ThemeInfoBrush}" Foreground="White"
                            FontWeight="Bold" Padding="12,6" Margin="0,0,8,0"
                            Cursor="Hand"/>
                    <Button Content="🏠 Zpět"
                            Command="{Binding NavigateBackCommand}"
                            Background="{DynamicResource ThemeSecondaryBackgroundBrush}" Foreground="{DynamicResource ThemeTextPrimaryBrush}"
                            BorderBrush="{DynamicResource ThemeBorderBrush}"
                            FontWeight="Bold" Padding="12,6"
                            Cursor="Hand"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ========== SEARCH AND FILTER ========== -->
        <Border Grid.Row="1" Background="{DynamicResource ThemeSecondaryBackgroundBrush}" Padding="16,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox Grid.Column="0" Watermark="🔍 Hledat podle modelu, sériového čísla..."
                         Text="{Binding SearchText}" Width="300" HorizontalAlignment="Left"/>

                <ComboBox Grid.Column="1" ItemsSource="{Binding GradeFilters}"
                          SelectedItem="{Binding SelectedGradeFilter}"
                          Width="100" Margin="10,0,0,0"/>

                <CheckBox Grid.Column="2" Content="Pouze zamčené"
                          IsChecked="{Binding ShowLockedOnly}"
                          Margin="10,0,0,0"/>

                <CheckBox Grid.Column="3" Content="Pouze archivované"
                          IsChecked="{Binding ShowArchivedOnly}"
                          Margin="10,0,0,0"/>
            </Grid>
        </Border>

        <!-- ========== DATA GRID ========== -->
        <Border Grid.Row="2" Margin="16" Background="{DynamicResource ThemeCardBackgroundBrush}" BorderBrush="{DynamicResource ThemeBorderBrush}" BorderThickness="1">
            <Grid>
                <DataGrid ItemsSource="{Binding FilteredCards}"
                          SelectedItem="{Binding SelectedCard}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal"
                          BorderThickness="0"
                          FontSize="12"
                          DoubleTapped="CardsDataGrid_DoubleTapped">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Model" Binding="{Binding ModelName}" Width="170"/>
                        <DataGridTextColumn Header="Sériové č." Binding="{Binding SerialNumber}" Width="150"/>
                        <DataGridTextColumn Header="Kapacita" Binding="{Binding Capacity, StringFormat='{}{0:#,0} B'}" Width="110"/>
                        <DataGridTextColumn Header="Známka" Binding="{Binding OverallGrade}" Width="60"/>
                        <DataGridTextColumn Header="Skóre" Binding="{Binding OverallScore, StringFormat={}{0:F0}}" Width="60"/>
                        <DataGridTemplateColumn Header="Oddíly / přípojné body" Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Disabled">
                                        <ItemsControl ItemsSource="{Binding Volumes}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <StackPanel Spacing="4"/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="{Binding FileSystem, Converter={StaticResource FileSystemToBrushConverter}}"
                                                            BorderBrush="{DynamicResource ThemeBorderBrush}"
                                                            BorderThickness="1"
                                                            CornerRadius="6"
                                                            Padding="8,4">
                                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                                            <TextBlock Text="{Binding FileSystem}" 
                                                                       FontWeight="Bold"
                                                                       Foreground="{Binding FileSystem, Converter={StaticResource FileSystemToForegroundBrushConverter}}"/>
                                                            <TextBlock Text="•" Foreground="{DynamicResource ThemeTextMutedBrush}"/>
                                                            <TextBlock Text="{Binding Name}" Foreground="{DynamicResource ThemeTextPrimaryBrush}"/>
                                                            <TextBlock Text="•" Foreground="{DynamicResource ThemeTextMutedBrush}"/>
                                                            <TextBlock Text="{Binding Path}" Foreground="{DynamicResource ThemeTextSecondaryBrush}"/>
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Testů" Binding="{Binding TestCount}" Width="60"/>
                        <DataGridTextColumn Header="Poslední test" Binding="{Binding LastTestedAt, StringFormat={}{0:dd.MM.yyyy HH:mm}}" Width="130"/>
                        <DataGridTemplateColumn Header="Akce" Width="210">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <Button Content="📋 Detail"
                                                Command="{Binding $parent[DataGrid].DataContext.ViewCardDetailsCommand}"
                                                CommandParameter="{Binding}"
                                                Background="{DynamicResource ThemeInfoBrush}" Foreground="White"
                                                FontSize="10" Padding="8,4" Cursor="Hand"/>
                                        <Button Content="📄 Cert."
                                                Command="{Binding $parent[DataGrid].DataContext.GenerateCertificateCommand}"
                                                CommandParameter="{Binding}"
                                                IsEnabled="{Binding CanGenerateCertificate}"
                                                Background="{DynamicResource ThemeSuccessBrush}" Foreground="White"
                                                FontSize="10" Padding="8,4" Cursor="Hand"/>
                                        <Button Content="📁 Archiv"
                                                Command="{Binding $parent[DataGrid].DataContext.ArchiveCardCommand}"
                                                CommandParameter="{Binding}"
                                                Background="{DynamicResource ThemeWarningBrush}" Foreground="White"
                                                FontSize="10" Padding="8,4" Cursor="Hand"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Loading overlay -->
                <Panel IsVisible="{Binding IsLoading}" Background="{DynamicResource ThemeOverlayBrush}">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="⏳ Načítám data..." FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" Foreground="{DynamicResource ThemeTextInverseBrush}"/>
                        <ProgressBar IsIndeterminate="True" Width="200" Margin="0,10,0,0"/>
                    </StackPanel>
                </Panel>

                <!-- Empty state -->
                <Panel IsVisible="{Binding !IsLoading}">
                    <Panel.IsVisible>
                        <MultiBinding Converter="{x:Static converters:InverseBooleanMultiConverter.Instance}">
                            <Binding Path="FilteredCards.Count"/>
                        </MultiBinding>
                    </Panel.IsVisible>
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="📂" FontSize="48" HorizontalAlignment="Center"/>
                        <TextBlock Text="Žádné karty disků" FontSize="18" FontWeight="Bold"
                                   HorizontalAlignment="Center" Margin="0,10,0,5"/>
                        <TextBlock Text="Spusťte test disku pro vytvoření nové karty"
                                   FontSize="12" Foreground="{DynamicResource ThemeTextSecondaryBrush}" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Panel>
            </Grid>
        </Border>

        <!-- ========== STATUS BAR ========== -->
        <Border Grid.Row="3" Classes="StatusBar" Padding="16,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="{Binding StatusMessage}" Classes="StatusText"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <TextBlock Text="{Binding CardCount, StringFormat='Celkem karet: {0}'}" FontSize="10" Margin="0,0,16,0" Foreground="{DynamicResource ThemeTextMutedBrush}"/>
                    <TextBlock Text="{Binding FilteredCount, StringFormat='Zobrazeno: {0}'}" FontSize="10" Foreground="{DynamicResource ThemeTextMutedBrush}"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>