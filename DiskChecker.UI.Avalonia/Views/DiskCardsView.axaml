<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:DiskChecker.UI.Avalonia.ViewModels"
             xmlns:converters="using:DiskChecker.UI.Avalonia.Converters"
             x:Class="DiskChecker.UI.Avalonia.Views.DiskCardsView"
             Background="{DynamicResource ThemeBackgroundBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ========== HEADER ========== -->
        <Border Grid.Row="0" Background="{DynamicResource ThemePanelBackgroundBrush}"
                BorderBrush="{DynamicResource ThemeBorderBrush}"
                BorderThickness="0,0,0,1" Padding="16,10" MinHeight="60">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="{Binding L[DiskCardsView.DiskCards]}" Classes="PageTitle"/>
                    <TextBlock Text="{Binding L[DiskCardsView.Subtitle]}" Classes="PageSubtitle"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="{Binding L[DiskCardsView.Reports]}"
                            Command="{Binding NavigateToReportsCommand}"
                            Background="{DynamicResource ThemePrimaryBrush}" Foreground="White"
                            FontWeight="Bold" Padding="12,6" Margin="0,0,8,0"
                            Cursor="Hand"/>
                    <Button Content="{Binding L[DiskCardsView.Certificates]}"
                            Command="{Binding NavigateToCertificateBrowserCommand}"
                            Background="{DynamicResource ThemeSuccessBrush}" Foreground="White"
                            FontWeight="Bold" Padding="12,6" Margin="0,0,8,0"
                            Cursor="Hand"/>
                    <Button Content="{Binding L[DiskCardsView.Refresh]}"
                            Command="{Binding RefreshCommand}"
                            Background="{DynamicResource ThemeInfoBrush}" Foreground="White"
                            FontWeight="Bold" Padding="12,6" Margin="0,0,8,0"
                            Cursor="Hand"/>
                    <Button Content="{Binding L[Common.Back]}"
                            Command="{Binding NavigateBackCommand}"
                            Background="{DynamicResource ThemeSecondaryBackgroundBrush}" Foreground="{DynamicResource ThemeTextPrimaryBrush}"
                            BorderBrush="{DynamicResource ThemeBorderBrush}"
                            FontWeight="Bold" Padding="12,6"
                            Cursor="Hand"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ========== SEARCH AND FILTER ========== -->
        <Border Grid.Row="1" Background="{DynamicResource ThemeSecondaryBackgroundBrush}" Padding="16,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox Grid.Column="0" Watermark="{Binding L[DiskCardsView.SearchWatermark]}"
                         Text="{Binding SearchText}" Width="300" HorizontalAlignment="Left"/>

                <ComboBox Grid.Column="1" ItemsSource="{Binding GradeFilters}"
                          SelectedItem="{Binding SelectedGradeFilter}"
                          Width="100" Margin="10,0,0,0"/>

                <CheckBox Grid.Column="2" Content="{Binding L[DiskCardsView.LockedOnly]}"
                          IsChecked="{Binding ShowLockedOnly}"
                          Margin="10,0,0,0"/>

                <CheckBox Grid.Column="3" Content="{Binding L[DiskCardsView.ArchivedOnly]}"
                          IsChecked="{Binding ShowArchivedOnly}"
                          Margin="10,0,0,0"/>
            </Grid>
        </Border>

        <!-- ========== DATA GRID ========== -->
        <Border Grid.Row="2" Margin="16" Background="{DynamicResource ThemeCardBackgroundBrush}" BorderBrush="{DynamicResource ThemeBorderBrush}" BorderThickness="1">
            <Grid>
                <DataGrid ItemsSource="{Binding FilteredCards}"
                          SelectedItem="{Binding SelectedCard}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal"
                          BorderThickness="0"
                          FontSize="12"
                          Background="{DynamicResource ThemeCardBackgroundBrush}"
                          Foreground="{DynamicResource ThemeTextPrimaryBrush}"
                          RowBackground="{DynamicResource ThemeCardBackgroundBrush}"
                          HorizontalGridLinesBrush="{DynamicResource ThemeBorderLightBrush}"
                          VerticalGridLinesBrush="{DynamicResource ThemeBorderLightBrush}"
                          DoubleTapped="CardsDataGrid_DoubleTapped">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="{Binding L[DiskCardsView.Model]}" Binding="{Binding ModelName}" Width="170"/>
                        <DataGridTextColumn Header="{Binding L[DiskCardsView.SerialNumber]}" Binding="{Binding SerialNumber}" Width="150"/>
                        <DataGridTextColumn Header="{Binding L[DiskCardsView.Capacity]}" Binding="{Binding Capacity, StringFormat='{}{0:#,0} B'}" Width="110"/>
                        <DataGridTextColumn Header="{Binding L[DiskCardsView.Grade]}" Binding="{Binding OverallGrade}" Width="60"/>
                        <DataGridTextColumn Header="{Binding L[DiskCardsView.Score]}" Binding="{Binding OverallScore, StringFormat={}{0:F0}}" Width="60"/>
                        <DataGridTextColumn Header="{Binding L[DiskCardsView.Hours]}" Binding="{Binding PowerOnHours, StringFormat='{}{0:#,0}'}" Width="75"/>
                        <DataGridTextColumn Header="{Binding L[DiskCardsView.Starts]}" Binding="{Binding PowerCycleCount, StringFormat='{}{0:#,0}'}" Width="75"/>
                        <DataGridTemplateColumn Header="{Binding L[DiskCardsView.Volumes]}" Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Disabled">
                                        <ItemsControl ItemsSource="{Binding Volumes}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <StackPanel Spacing="4"/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="{Binding FileSystem, Converter={StaticResource FileSystemToBrushConverter}}"
                                                            BorderBrush="{DynamicResource ThemeBorderBrush}"
                                                            BorderThickness="1"
                                                            CornerRadius="6"
                                                            Padding="8,4">
                                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                                            <TextBlock Text="{Binding FileSystem}" 
                                                                       FontWeight="Bold"
                                                                       Foreground="{Binding FileSystem, Converter={StaticResource FileSystemToForegroundBrushConverter}}"/>
                                                            <TextBlock Text="•" Foreground="{DynamicResource ThemeTextMutedBrush}"/>
                                                            <TextBlock Text="{Binding Name}" Foreground="{DynamicResource ThemeTextPrimaryBrush}"/>
                                                            <TextBlock Text="•" Foreground="{DynamicResource ThemeTextMutedBrush}"/>
                                                            <TextBlock Text="{Binding Path}" Foreground="{DynamicResource ThemeTextSecondaryBrush}"/>
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="{Binding L[DiskCardsView.Tests]}" Binding="{Binding TestCount}" Width="60"/>
                        <DataGridTextColumn Header="{Binding L[DiskCardsView.LastTest]}" Binding="{Binding LastTestedAt, StringFormat={}{0:dd.MM.yyyy HH:mm}}" Width="130"/>
                        <DataGridTemplateColumn Header="{Binding L[DiskCardsView.Actions]}" Width="210">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <Button Content="{Binding L[DiskCardsView.Detail]}"
                                                Command="{Binding $parent[DataGrid].DataContext.ViewCardDetailsCommand}"
                                                CommandParameter="{Binding}"
                                                Background="{DynamicResource ThemeInfoBrush}" Foreground="White"
                                                FontSize="10" Padding="8,4" Cursor="Hand"/>
                                        <Button Content="{Binding L[DiskCardsView.Cert]}"
                                                Command="{Binding $parent[DataGrid].DataContext.GenerateCertificateCommand}"
                                                CommandParameter="{Binding}"
                                                IsEnabled="{Binding TestCount, Converter={StaticResource IntToBoolConverter}}"
                                                Background="{DynamicResource ThemeSuccessBrush}" Foreground="White"
                                                FontSize="10" Padding="8,4" Cursor="Hand"/>
                                        <Button Content="{Binding L[DiskCardsView.Archive]}"
                                                Command="{Binding $parent[DataGrid].DataContext.ArchiveCardCommand}"
                                                CommandParameter="{Binding}"
                                                Background="{DynamicResource ThemeWarningBrush}" Foreground="White"
                                                FontSize="10" Padding="8,4" Cursor="Hand"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Loading overlay -->
                <Panel IsVisible="{Binding IsLoading}" Background="{DynamicResource ThemeOverlayBrush}">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="{Binding L[DiskCardsView.Loading]}" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" Foreground="{DynamicResource ThemeTextInverseBrush}"/>
                        <ProgressBar IsIndeterminate="True" Width="200" Margin="0,10,0,0"/>
                    </StackPanel>
                </Panel>

                <!-- Empty state -->
                <Panel IsVisible="{Binding FilteredCount, Converter={StaticResource IntToBoolConverter}, ConverterParameter=Invert}">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="📂" FontSize="48" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding L[DiskCardsView.NoCards]}" FontSize="18" FontWeight="Bold"
                                   HorizontalAlignment="Center" Margin="0,10,0,5"/>
                        <TextBlock Text="{Binding L[DiskCardsView.RunTestHint]}"
                                   FontSize="12" Foreground="{DynamicResource ThemeTextSecondaryBrush}" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Panel>
            </Grid>
        </Border>

        <!-- ========== STATUS BAR ========== -->
        <Border Grid.Row="3" Classes="StatusBar" Padding="16,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="{Binding StatusMessage}" Classes="StatusText"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <TextBlock FontSize="10" Margin="0,0,16,0" Foreground="{DynamicResource ThemeTextMutedBrush}">
                        <Run Text="{Binding L[DiskCardsView.TotalCards]}"/>
                        <Run Text="{Binding CardCount}"/>
                    </TextBlock>
                    <TextBlock FontSize="10" Foreground="{DynamicResource ThemeTextMutedBrush}">
                        <Run Text="{Binding L[DiskCardsView.Shown]}"/>
                        <Run Text="{Binding FilteredCount}"/>
                    </TextBlock>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>