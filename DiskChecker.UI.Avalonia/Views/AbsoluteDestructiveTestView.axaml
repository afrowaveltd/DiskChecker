<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:DiskChecker.UI.Avalonia.ViewModels"
             xmlns:converters="using:DiskChecker.UI.Avalonia.Converters"
             xmlns:lvc="using:LiveChartsCore.SkiaSharpView.Avalonia"
             x:Class="DiskChecker.UI.Avalonia.Views.AbsoluteDestructiveTestView"
             x:DataType="vm:AbsoluteDestructiveTestViewModel">

    <ScrollViewer>
        <StackPanel Spacing="12" Margin="16">

            <!-- ═══════════ HEADER ═══════════ -->
            <Border Background="{DynamicResource ThemeCardBackgroundBrush}"
                    CornerRadius="8" Padding="16"
                    BorderBrush="{DynamicResource ThemeBorderBrush}" BorderThickness="1">
                <Grid ColumnDefinitions="Auto,*,Auto">
                    <StackPanel Grid.Column="0" Spacing="4">
                        <TextBlock Text="{Binding L[DestructiveTest.Title]}" FontSize="18" FontWeight="Bold"
                                   Foreground="{DynamicResource ThemeTextPrimaryBrush}"/>
                        <!-- Selected disk always visible -->
                        <Border Background="{DynamicResource ThemePrimaryLightBrush}"
                                CornerRadius="4" Padding="8,4" Margin="0,4,0,0"
                                BorderBrush="{DynamicResource ThemePrimaryBrush}" BorderThickness="1">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <TextBlock Text="💿" FontSize="14" VerticalAlignment="Center"/>
                                <StackPanel>
                                    <TextBlock Text="{Binding SelectedDrive.Name}" FontSize="13" FontWeight="Bold"
                                               Foreground="{DynamicResource ThemeTextPrimaryBrush}"/>
                                    <TextBlock FontSize="10" Foreground="{DynamicResource ThemeTextMutedBrush}">
                                        <Run Text="{Binding L[Disk.Path]}"/>
                                        <Run Text="{Binding SelectedDrive.Path}" FontWeight="SemiBold"/>
                                    </TextBlock>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Spacing="8" VerticalAlignment="Center" HorizontalAlignment="Right">
                        <!-- Start button -->
                        <Button Content="{Binding L[DestructiveTest.StartTest]}"
                                Command="{Binding StartTestCommand}"
                                IsVisible="{Binding !IsTesting}"
                                Background="{DynamicResource ThemeDangerBrush}"
                                Foreground="White"
                                FontWeight="Bold" FontSize="13"
                                Padding="20,10" CornerRadius="8"
                                Cursor="Hand"/>
                        <!-- Cancel button -->
                        <Button Content="{Binding L[DestructiveTest.CancelTest]}"
                                Command="{Binding CancelTestCommand}"
                                IsVisible="{Binding IsTesting}"
                                Background="#E74C3C"
                                Foreground="White"
                                FontWeight="Bold" FontSize="13"
                                Padding="20,10" CornerRadius="8"
                                Cursor="Hand"/>
                        <!-- Back button -->
                        <Button Content="{Binding L[Common.Back]}"
                                Command="{Binding GoBackCommand}"
                                IsVisible="{Binding !IsTesting}"
                                Padding="12,6" CornerRadius="6"
                                Cursor="Hand"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ═══════════ MANUAL PROFILE SELECTOR ═══════════ -->
            <Border Background="{DynamicResource ThemeWarningBrush}20"
                    CornerRadius="8" Padding="12"
                    BorderBrush="{DynamicResource ThemeWarningBrush}" BorderThickness="1"
                    IsVisible="{Binding ShowManualProfileSelector}">
                <StackPanel Spacing="8">
                    <TextBlock Text="{Binding L[SMART.DataUnavailable]}" FontSize="14" FontWeight="Bold"
                               Foreground="{DynamicResource ThemeWarningBrush}"/>
                    <TextBlock Text="{Binding L[DestructiveTest.SelectManualProfile]}"
                               FontSize="11" Foreground="{DynamicResource ThemeTextSecondaryBrush}"
                               TextWrapping="Wrap"/>
                    <ListBox ItemsSource="{Binding ManualProfiles}"
                             SelectedIndex="{Binding SelectedManualProfile, Converter={StaticResource EnumToIndexConverter}}"
                             Background="{DynamicResource ThemeSecondaryBackgroundBrush}"
                             BorderBrush="{DynamicResource ThemeBorderBrush}"
                             BorderThickness="1" CornerRadius="6">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Spacing="2" Margin="4">
                                    <TextBlock Text="{Binding Name}" FontSize="12" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding Description}" FontSize="10"
                                               Foreground="{DynamicResource ThemeTextMutedBrush}"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </Border>

            <!-- ═══════════ OVERALL PROGRESS ═══════════ -->
            <Border Background="{DynamicResource ThemeCardBackgroundBrush}"
                    CornerRadius="8" Padding="12"
                    BorderBrush="{DynamicResource ThemeBorderBrush}" BorderThickness="1"
                    IsVisible="{Binding IsTesting}">
                <StackPanel Spacing="6">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Grid.Column="0" Text="{Binding StatusMessage}" FontSize="12"
                                   Foreground="{DynamicResource ThemeTextPrimaryBrush}"
                                   TextTrimming="CharacterEllipsis"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="12">
                            <TextBlock FontSize="11" Foreground="{DynamicResource ThemeTextSecondaryBrush}">
                                <Run Text="⏱ "/>
                                <Run Text="{Binding ElapsedTime}"/>
                            </TextBlock>
                            <TextBlock FontSize="11" Foreground="{DynamicResource ThemeTextMutedBrush}">
                                <Run Text="{Binding L[DestructiveTest.Remaining]}"/>
                                <Run Text="{Binding EstimatedRemaining}"/>
                            </TextBlock>
                        </StackPanel>
                    </Grid>
                    <Grid ColumnDefinitions="Auto,*">
                        <TextBlock Grid.Column="0" Text="{Binding OverallProgress, StringFormat='{}{0:F0}%'}"
                                   FontSize="11" FontWeight="Bold" Width="40"
                                   Foreground="{DynamicResource ThemePrimaryBrush}"
                                   VerticalAlignment="Center"/>
                        <ProgressBar Grid.Column="1" Value="{Binding OverallProgress}"
                                     Minimum="0" Maximum="100" Height="8"
                                     CornerRadius="4"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ═══════════ PHASE TIMELINE ═══════════ -->
            <Border Background="{DynamicResource ThemeCardBackgroundBrush}"
                    CornerRadius="8" Padding="12"
                    BorderBrush="{DynamicResource ThemeBorderBrush}" BorderThickness="1">
                <StackPanel Spacing="4">
                    <TextBlock Text="{Binding L[DestructiveTest.PhaseProgress]}" FontSize="13" FontWeight="Bold"
                               Foreground="{DynamicResource ThemeTextPrimaryBrush}" Margin="0,0,0,4"/>
                    <ItemsControl ItemsSource="{Binding Phases}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnDefinitions="Auto,Auto,*,Auto" Margin="0,2">
                                    <!-- Status icon -->
                                    <TextBlock Grid.Column="0" Text="✅" FontSize="12" Width="20"
                                               IsVisible="{Binding Status, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Completed}"/>
                                    <TextBlock Grid.Column="0" Text="🔄" FontSize="12" Width="20"
                                               IsVisible="{Binding Status, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Running}"/>
                                    <TextBlock Grid.Column="0" Text="❌" FontSize="12" Width="20"
                                               IsVisible="{Binding Status, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Failed}"/>
                                    <TextBlock Grid.Column="0" Text="⏳" FontSize="12" Width="20"
                                               IsVisible="{Binding Status, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Pending}"/>

                                    <!-- Phase name -->
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4">
                                        <TextBlock Text="{Binding Icon}" FontSize="12"/>
                                        <TextBlock Text="{Binding Name}" FontSize="12" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource ThemeTextPrimaryBrush}"/>
                                    </StackPanel>

                                    <!-- Progress bar within phase -->
                                    <ProgressBar Grid.Column="2" Value="{Binding ProgressPercent}"
                                                 Minimum="0" Maximum="100" Height="4"
                                                 CornerRadius="2" Margin="8,0"
                                                 IsVisible="{Binding Status, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Running}"/>

                                    <!-- Detail -->
                                    <TextBlock Grid.Column="3" Text="{Binding Detail}" FontSize="10"
                                               Foreground="{DynamicResource ThemeTextMutedBrush}"
                                               TextTrimming="CharacterEllipsis"
                                               MaxWidth="300"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- ═══════════ SANITIZATION CHART (persistent, two passes) ═══════════ -->
            <Border Background="{DynamicResource ThemeCardBackgroundBrush}"
                    CornerRadius="8" Padding="12"
                    BorderBrush="{DynamicResource ThemeBorderBrush}" BorderThickness="1"
                    IsVisible="{Binding IsTesting}">
                <StackPanel Spacing="6">
                    <Grid ColumnDefinitions="*,Auto,Auto">
                        <TextBlock Grid.Column="0" Text="{Binding SanitizeChartTitle}" FontSize="13" FontWeight="Bold"
                                   Foreground="{DynamicResource ThemeTextPrimaryBrush}"/>
                        <TextBlock Grid.Column="1" Text="{Binding SanitizeDataWritten}" FontSize="10"
                                   Foreground="{DynamicResource ThemeDangerBrush}" Margin="8,0"
                                   VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="{Binding SanitizeDataRead}" FontSize="10"
                                   Foreground="{DynamicResource ThemeSuccessBrush}"
                                   VerticalAlignment="Center"/>
                    </Grid>
                    <!-- Legend with toggles (clickable buttons styled as legend items) -->
                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="4,0,0,2">
                        <Button Command="{Binding ToggleSanitizeSeriesCommand}" CommandParameter="pass1write"
                                Background="Transparent" BorderThickness="0" Padding="2" Cursor="Hand">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <Border Width="14" Height="2" Background="#EF4444" CornerRadius="1" VerticalAlignment="Center"
                                        IsVisible="{Binding ShowSanitizePass1Write}"/>
                                <Border Width="14" Height="2" Background="{DynamicResource ThemeTextMutedBrush}" CornerRadius="1" VerticalAlignment="Center"
                                        IsVisible="{Binding !ShowSanitizePass1Write}"/>
                                <TextBlock Text="{Binding L[DestructiveTest.Sanitize.Write1]}" FontSize="9" Foreground="{DynamicResource ThemeTextSecondaryBrush}"/>
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding ToggleSanitizeSeriesCommand}" CommandParameter="pass1read"
                                Background="Transparent" BorderThickness="0" Padding="2" Cursor="Hand">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <Border Width="14" Height="2" Background="#22C55E" CornerRadius="1" VerticalAlignment="Center"
                                        IsVisible="{Binding ShowSanitizePass1Read}"/>
                                <Border Width="14" Height="2" Background="{DynamicResource ThemeTextMutedBrush}" CornerRadius="1" VerticalAlignment="Center"
                                        IsVisible="{Binding !ShowSanitizePass1Read}"/>
                                <TextBlock Text="{Binding L[DestructiveTest.Sanitize.Read1]}" FontSize="9" Foreground="{DynamicResource ThemeTextSecondaryBrush}"/>
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding ToggleSanitizeSeriesCommand}" CommandParameter="pass2write"
                                Background="Transparent" BorderThickness="0" Padding="2" Cursor="Hand">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <Border Width="14" Height="2" Background="#B91C1C" CornerRadius="1" VerticalAlignment="Center"
                                        IsVisible="{Binding ShowSanitizePass2Write}"/>
                                <Border Width="14" Height="2" Background="{DynamicResource ThemeTextMutedBrush}" CornerRadius="1" VerticalAlignment="Center"
                                        IsVisible="{Binding !ShowSanitizePass2Write}"/>
                                <TextBlock Text="{Binding L[DestructiveTest.Sanitize.Write2]}" FontSize="9" Foreground="{DynamicResource ThemeTextSecondaryBrush}"/>
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding ToggleSanitizeSeriesCommand}" CommandParameter="pass2read"
                                Background="Transparent" BorderThickness="0" Padding="2" Cursor="Hand">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <Border Width="14" Height="2" Background="#15803D" CornerRadius="1" VerticalAlignment="Center"
                                        IsVisible="{Binding ShowSanitizePass2Read}"/>
                                <Border Width="14" Height="2" Background="{DynamicResource ThemeTextMutedBrush}" CornerRadius="1" VerticalAlignment="Center"
                                        IsVisible="{Binding !ShowSanitizePass2Read}"/>
                                <TextBlock Text="{Binding L[DestructiveTest.Sanitize.Read2]}" FontSize="9" Foreground="{DynamicResource ThemeTextSecondaryBrush}"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                    <lvc:CartesianChart Series="{Binding SanitizeChartSeries}"
                                        XAxes="{Binding SanitizeChartXAxes}"
                                        YAxes="{Binding SanitizeChartYAxes}"
                                        ZoomMode="None"
                                        TooltipPosition="Top"
                                        LegendPosition="Hidden"
                                        AnimationsSpeed="0:0:0"
                                        Height="220"/>
                </StackPanel>
            </Border>

            <!-- ═══════════ CURRENT PHASE CHART (seek phases) ═══════════ -->
            <Border Background="{DynamicResource ThemeCardBackgroundBrush}"
                    CornerRadius="8" Padding="12"
                    BorderBrush="{DynamicResource ThemeBorderBrush}" BorderThickness="1"
                    IsVisible="{Binding IsTesting}">
                <StackPanel Spacing="4">
                    <TextBlock FontSize="13" FontWeight="Bold"
                               Foreground="{DynamicResource ThemeTextPrimaryBrush}">
                        <Run Text="{Binding L[DestructiveTest.CurrentPhase]}"/>
                        <Run Text="{Binding CurrentPhaseName}"/>
                    </TextBlock>
                    <lvc:CartesianChart Series="{Binding CurrentPhaseSeries}"
                                        XAxes="{Binding CurrentPhaseXAxes}"
                                        YAxes="{Binding CurrentPhaseYAxes}"
                                        ZoomMode="None"
                                        TooltipPosition="Top"
                                        LegendPosition="Hidden"
                                        AnimationsSpeed="0:0:0"
                                        Height="200"/>
                </StackPanel>
            </Border>

            <!-- ═══════════ SEEK RESULTS CHARTS (switchable, after completion) ═══════════ -->
            <!-- NOTE: IsVisible is intentionally NOT bound – chart must stay in visual tree
                 so LiveCharts2 SkiaSharp initializes its render surface properly. -->
            <Border Background="{DynamicResource ThemeCardBackgroundBrush}"
                    CornerRadius="8" Padding="12"
                    BorderBrush="{DynamicResource ThemeBorderBrush}" BorderThickness="1">
                <StackPanel Spacing="8">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Grid.Column="0" Text="{Binding SeekChartTitle}" FontSize="13" FontWeight="Bold"
                                   Foreground="{DynamicResource ThemeTextPrimaryBrush}"/>
                        <!-- Toggle buttons -->
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4">
                            <Button Content="{Binding L[DestructiveTest.Toggle.FullStroke]}"
                                    Command="{Binding SwitchSeekChartCommand}"
                                    CommandParameter="0"
                                    Padding="8,4" CornerRadius="4" FontSize="10"
                                    Cursor="Hand"/>
                            <Button Content="{Binding L[DestructiveTest.Toggle.Random]}"
                                    Command="{Binding SwitchSeekChartCommand}"
                                    CommandParameter="1"
                                    Padding="8,4" CornerRadius="4" FontSize="10"
                                    Cursor="Hand"/>
                            <Button Content="{Binding L[DestructiveTest.Toggle.Skip]}"
                                    Command="{Binding SwitchSeekChartCommand}"
                                    CommandParameter="2"
                                    Padding="8,4" CornerRadius="4" FontSize="10"
                                    Cursor="Hand"/>
                        </StackPanel>
                    </Grid>
                    <Grid>
                        <lvc:CartesianChart Series="{Binding SeekChartSeries}"
                                            XAxes="{Binding SeekChartXAxes}"
                                            YAxes="{Binding SeekChartYAxes}"
                                            ZoomMode="None"
                                            TooltipPosition="Top"
                                            LegendPosition="Hidden"
                                            AnimationsSpeed="0:0:0"
                                            Height="220"/>
                        <!-- Overlay shown when no seek charts available yet -->
                        <TextBlock Text="{Binding L[DestructiveTest.SeekGraphsPending]}"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center"
                                   FontSize="12"
                                   Foreground="{DynamicResource ThemeTextMutedBrush}"
                                   IsVisible="{Binding HasSeekCharts, Converter={StaticResource InverseBooleanConverter}}"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ═══════════ SMART TELEMETRY ═══════════ -->
            <Border Background="{DynamicResource ThemeCardBackgroundBrush}"
                    CornerRadius="8" Padding="12"
                    BorderBrush="{DynamicResource ThemeBorderBrush}" BorderThickness="1">
                <StackPanel Spacing="6">
                    <TextBlock Text="{Binding L[DestructiveTest.SmartTelemetry]}" FontSize="13" FontWeight="Bold"
                               Foreground="{DynamicResource ThemeTextPrimaryBrush}"/>

                    <!-- Baseline -->
                    <Border Background="{DynamicResource ThemeSecondaryBackgroundBrush}"
                            CornerRadius="4" Padding="8">
                        <StackPanel Spacing="2">
                            <TextBlock Text="{Binding L[DestructiveTest.InitialState]}" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{DynamicResource ThemeTextSecondaryBrush}"/>
                            <TextBlock Text="{Binding SmartBaselineSummary}" FontSize="10"
                                       Foreground="{DynamicResource ThemeTextMutedBrush}"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <!-- Delta -->
                    <Border Background="{DynamicResource ThemeSecondaryBackgroundBrush}"
                            CornerRadius="4" Padding="8"
                            IsVisible="{Binding HasResults}">
                        <StackPanel Spacing="2">
                            <TextBlock Text="{Binding L[DestructiveTest.SmartDelta.Title]}" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{DynamicResource ThemeTextSecondaryBrush}"/>
                            <TextBlock Text="{Binding SmartDeltaSummary}" FontSize="10"
                                       Foreground="{DynamicResource ThemeTextMutedBrush}"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <!-- Temperature -->
                    <Grid ColumnDefinitions="Auto,Auto,Auto,*" IsVisible="{Binding IsTesting}">
                        <TextBlock Grid.Column="0" Text="🌡" FontSize="12" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="{Binding CurrentTemperature, StringFormat='{}{0}°C'}"
                                   FontSize="14" FontWeight="Bold" Margin="4,0"
                                   Foreground="{DynamicResource ThemeTextPrimaryBrush}"
                                   VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="2" FontSize="10" Margin="8,0,0,0"
                                   Foreground="{DynamicResource ThemeTextMutedBrush}"
                                   VerticalAlignment="Center">
                            <Run Text="Min: "/>
                            <Run Text="{Binding MinTemperature}"/>
                            <Run Text="°C | Max: "/>
                            <Run Text="{Binding MaxTemperature}"/>
                            <Run Text="°C"/>
                        </TextBlock>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ═══════════ DISK RECOVERY (when disk disappears) ═══════════ -->
            <Border Background="{DynamicResource ThemeCardBackgroundBrush}"
                    CornerRadius="8" Padding="16"
                    BorderBrush="{DynamicResource ThemeWarningBrush}" BorderThickness="2"
                    IsVisible="{Binding IsDiskRecoveryActive}">
                <StackPanel Spacing="8">
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <TextBlock Grid.Column="0" Text="⚠️" FontSize="20" VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="1" Margin="8,0">
                            <TextBlock Text="{Binding L[DestructiveTest.Recovery.Title]}" FontSize="14" FontWeight="Bold"
                                       Foreground="{DynamicResource ThemeWarningBrush}"/>
                            <TextBlock Text="{Binding DiskRecoveryStatus}" FontSize="11"
                                       Foreground="{DynamicResource ThemeTextSecondaryBrush}"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                        <Border Grid.Column="2" Background="{DynamicResource ThemeSecondaryBackgroundBrush}"
                                CornerRadius="6" Padding="10,6">
                            <TextBlock Text="{Binding DiskRecoveryCountdown}" FontSize="16" FontWeight="Bold"
                                       Foreground="{DynamicResource ThemePrimaryBrush}"
                                       HorizontalAlignment="Center"/>
                        </Border>
                    </Grid>
                    <!-- Disappearance log -->
                    <Border Background="{DynamicResource ThemeSecondaryBackgroundBrush}"
                            CornerRadius="4" Padding="8"
                            IsVisible="{Binding DiskDisappearanceCount, Converter={StaticResource IntToBoolConverter}}">
                        <TextBlock Text="{Binding DiskDisappearanceLog}" FontSize="9"
                                   Foreground="{DynamicResource ThemeTextMutedBrush}"
                                   FontFamily="Courier New" TextWrapping="Wrap"/>
                    </Border>
                </StackPanel>
            </Border>

            <!-- ═══════════ RESULTS (after completion) ═══════════ -->
            <Border Background="{DynamicResource ThemeCardBackgroundBrush}"
                    CornerRadius="8" Padding="16"
                    BorderBrush="{DynamicResource ThemeBorderBrush}" BorderThickness="1"
                    IsVisible="{Binding HasResults}">
                <StackPanel Spacing="12">
                    <TextBlock Text="{Binding L[DestructiveTest.TestResults]}" FontSize="16" FontWeight="Bold"
                               Foreground="{DynamicResource ThemeSuccessBrush}"/>

                    <!-- Sanitization comparison -->
                    <Border Background="{DynamicResource ThemeSecondaryBackgroundBrush}"
                            CornerRadius="6" Padding="10">
                        <StackPanel Spacing="4">
                            <TextBlock Text="{Binding L[DestructiveTest.SanitizeComparison]}" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{DynamicResource ThemeTextPrimaryBrush}"/>
                            <TextBlock Text="{Binding SanitizeComparisonSummary}" FontSize="10"
                                       Foreground="{DynamicResource ThemeTextSecondaryBrush}"
                                       TextWrapping="Wrap" FontFamily="Courier New"/>
                        </StackPanel>
                    </Border>

                    <!-- Seek results -->
                    <Border Background="{DynamicResource ThemeSecondaryBackgroundBrush}"
                            CornerRadius="6" Padding="10">
                        <StackPanel Spacing="4">
                            <TextBlock Text="{Binding L[DestructiveTest.SeekResults]}" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{DynamicResource ThemeTextPrimaryBrush}"/>
                            <TextBlock Text="{Binding SeekResultsSummary}" FontSize="10"
                                       Foreground="{DynamicResource ThemeTextSecondaryBrush}"
                                       TextWrapping="Wrap" FontFamily="Courier New"/>
                        </StackPanel>
                    </Border>

                    <!-- Post-test statistics (compact) -->
                    <Border Background="{DynamicResource ThemeSecondaryBackgroundBrush}"
                            CornerRadius="6" Padding="10">
                        <StackPanel Spacing="4">
                            <TextBlock Text="📊 Statistika" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{DynamicResource ThemeTextPrimaryBrush}"/>
                            <TextBlock Text="{Binding PostTestStatistics}" FontSize="10"
                                       Foreground="{DynamicResource ThemeTextSecondaryBrush}"
                                       TextWrapping="Wrap" FontFamily="Courier New"/>
                        </StackPanel>
                    </Border>

                    <!-- SMART changes -->
                    <Border Background="{DynamicResource ThemeSecondaryBackgroundBrush}"
                            CornerRadius="6" Padding="10">
                        <StackPanel Spacing="4">
                            <TextBlock Text="{Binding L[DestructiveTest.SmartChanges]}" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{DynamicResource ThemeTextPrimaryBrush}"/>
                            <TextBlock Text="{Binding SmartChangeDetails}" FontSize="10"
                                       Foreground="{DynamicResource ThemeTextSecondaryBrush}"
                                       TextWrapping="Wrap" FontFamily="Courier New"/>
                        </StackPanel>
                    </Border>

                    <!-- Full summary -->
                    <Border Background="{DynamicResource ThemeSecondaryBackgroundBrush}"
                            CornerRadius="6" Padding="10">
                        <StackPanel Spacing="4">
                            <TextBlock Text="{Binding L[DestructiveTest.CompleteSummary]}" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{DynamicResource ThemeTextPrimaryBrush}"/>
                            <TextBlock Text="{Binding ResultsSummary}" FontSize="10"
                                       Foreground="{DynamicResource ThemeTextSecondaryBrush}"
                                       TextWrapping="Wrap" FontFamily="Courier New"/>
                        </StackPanel>
                    </Border>

                    <!-- Certificate button -->
                    <Button Content="{Binding L[DestructiveTest.ShowCertificate]}"
                            Command="{Binding GenerateCertificateCommand}"
                            IsVisible="{Binding IsCertificateReady}"
                            Background="{DynamicResource ThemePrimaryBrush}"
                            Foreground="White"
                            FontWeight="Bold" FontSize="13"
                            Padding="20,10" CornerRadius="8"
                            HorizontalAlignment="Center"
                            Cursor="Hand"/>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
