<!-- EXTRA_MARKER_FOR_VOLUME -->
                    
                    <!-- Volume and FileSystem Info -->
                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                        <TextBlock Text="{Binding VolumeInfo}" FontSize="14" FontWeight="SemiBold"/>
                        <TextBlock Text=" • " Opacity="0.5"/>
                        <TextBlock FontSize="12" Opacity="0.7">
                            <TextBlock.Text>
                                <MultiBinding StringFormat="{}{0} • {1}">
                                    <Binding Path="FileSystem"/>
                                    <Binding Path="TotalSize" Converter="{x:Static converters:SizeConverter.Instance}"/>
                                </MultiBinding>
                            </TextBlock.Text>
                        </TextBlock>
                    </StackPanel>
                </StackPanel>="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:DiskChecker.UI.Avalonia.ViewModels"
             xmlns:converters="using:DiskChecker.UI.Avalonia.Converters"
             x:Class="DiskChecker.UI.Avalonia.Views.DiskSelectionView"
             x:DataType="vm:DiskSelectionViewModel"
             Background="{DynamicResource ThemeBackgroundBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ========== HEADER ========== -->
        <Border Grid.Row="0" Background="{DynamicResource ThemePanelBrush}" BorderBrush="{DynamicResource ThemeBorderBrush}" BorderThickness="0,0,0,1" Padding="20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- DISK_ITEM_STACKPANEL -->
                <StackPanel Grid.Column="0" Margin="0,0,0,5" CornerRadius="8">
                    <StackPanel.Background>
                        <MultiBinding Converter="{x:Static converters:DiskCardBackgroundConverter.Instance}">
                            <Binding Path="IsSystemDisk"/>
                            <Binding Path="FileSystem"/>
                            <Binding Path="VolumeInfo"/>
                        </MultiBinding>
                    </StackPanel.Background>
                    <StackPanel.BorderBrush>
                        <Binding Path="FileSystem" Converter="{x:Static converters:FileSystemColorConverter.Instance}"/>
                    </StackPanel.BorderBrush>
                    <StackPanel.BORDER_THICK_2</StackPanel.BorderThickness>
                    <TextBlock Text="💾 Vyberte Disk pro Testování" 
                               FontSize="28" FontWeight="Bold" Foreground="#1a1a1a" Margin="0,0,0,5"/>
                    <TextBlock Text="Zvolte disk, který chcete diagnostikovat" 
                               FontSize="13" Foreground="#444444"/>
                    <TextBlock Text="{Binding LoadingState}" FontSize="11" Foreground="#333333" Margin="0,4,0,0"/>
                    <ProgressBar IsIndeterminate="True" Margin="0,6,200,0" Background="#E6EAF0" Foreground="#004B93">
                        <ProgressBar.IsVisible>
                            <Binding Path="IsBusy" />
                        </ProgressBar.IsVisible>
                    </ProgressBar>
                </StackPanel>

                <Button Grid.Column="1"
                        Content="🔄 Reload disků"
                        Command="{Binding ReloadDisksCommand}"
                        Background="#004B93"
                        Foreground="White"
                        VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- ========== DASHBOARD ========== -->
        <Grid Grid.Row="1" Margin="20,12,20,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="3*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{DynamicResource ThemePanelBrush}" BorderBrush="{DynamicResource ThemeBorderBrush}" BorderThickness="1" Padding="14" Margin="0,0,10,0">
                <StackPanel>
                    <TextBlock Text="⚙️ Rychlý SMART report systémového disku" FontSize="13" FontWeight="Bold" Foreground="#333333" Margin="0,0,0,10"/>
                    <TextBlock Text="{Binding DiskCards[0].DisplayName, FallbackValue='Načítání...'}" FontSize="12" FontWeight="SemiBold" Foreground="#1A1A1A" Margin="0,0,0,6"/>
                    <TextBlock FontSize="12" Foreground="#007ACC" Margin="0,0,0,4">
                        <TextBlock.Text>
                            <MultiBinding StringFormat="Známka: {0}">
                                <Binding Path="DiskCards[0].GradeText" FallbackValue="?"/>
                            </MultiBinding>
                        </TextBlock.Text>
                    </TextBlock>
                    <TextBlock FontSize="12" Foreground="#333333" Margin="0,0,0,4">
                        <TextBlock.Text>
                            <MultiBinding StringFormat="Teplota: {0}">
                                <Binding Path="DiskCards[0].TemperatureText" FallbackValue="N/A"/>
                            </MultiBinding>
                        </TextBlock.Text>
                    </TextBlock>
                    <TextBlock Text="Disk je v dobrém stavu, žádné kritické chyby SMART." FontSize="11" Foreground="#444444" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Background="{DynamicResource ThemePanelBrush}" BorderBrush="{DynamicResource ThemeBorderBrush}" BorderThickness="1" Padding="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="🕒 Poslední testy" FontSize="13" FontWeight="Bold" Foreground="#333333" Margin="0,0,0,8"/>

                    <ListBox Grid.Row="1"
                             ItemsSource="{Binding RecentTests}"
                             IsHitTestVisible="False">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding TestDate}" Width="130"/>
                                    <TextBlock Text="{Binding DriveName}" Width="150"/>
                                    <TextBlock Text="{Binding TestType}" Width="120"/>
                                    <TextBlock Text="{Binding Grade}" Width="80"/>
                                    <TextBlock Text="{Binding Score}" Width="80"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>
        </Grid>

        <!-- ========== DISK LIST ========== -->
        <Border Grid.Row="2" Background="{DynamicResource ThemePanelBrush}" BorderBrush="{DynamicResource ThemeBorderBrush}" BorderThickness="1" Margin="20,0,20,20" Padding="15">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="📦 Vyberte disk z nabídky" FontSize="14" FontWeight="Bold" Foreground="#333333" Margin="0,0,0,12"/>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding DiskCards}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="3" HorizontalAlignment="Left" VerticalAlignment="Top"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="10" Cursor="Hand">
                                    <Border Name="DiskCard" 
                                            Background="#FFFFFF" 
                                            BorderBrush="#D0D0D0" 
                                            BorderThickness="1"
                                            CornerRadius="6"
                                            Padding="16"
                                            MinHeight="200">
                                        <!-- Styles/classes removed for compatibility with Avalonia XAML generator -->

                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>

                                            <!-- Icon -->
                                            <TextBlock Grid.Row="0" Text="💾" FontSize="32" 
                                                      HorizontalAlignment="Left" Margin="0,0,0,8"/>

                                            <!-- Name &amp; Path -->
                                            <StackPanel Grid.Row="1" Margin="0,0,0,8">
                                                <TextBlock Text="{Binding DisplayName}" 
                                                          FontSize="14" FontWeight="Bold" Foreground="#1a1a1a" Margin="0,0,0,2"/>
                                                <TextBlock Text="{Binding DisplayPath}" 
                                                          FontSize="10" Foreground="#555555" TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>

                                            <!-- Key Metrics -->
                                            <StackPanel Grid.Row="2" Margin="0,0,0,8">
                                                <Grid Margin="0,0,0,4">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="Velikost: " FontSize="10" Foreground="#444444"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding CapacityText}" FontSize="10" FontWeight="Bold" Foreground="#004B93"/>
                                                </Grid>
                                                
                                                <Grid Margin="0,0,0,4">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="SMART: " FontSize="10" Foreground="#444444"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding GradeText}" FontSize="10" FontWeight="Bold" Foreground="#004B93"/>
                                                </Grid>

                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="Teplota: " FontSize="10" Foreground="#444444"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding TemperatureText}" FontSize="10" FontWeight="Bold" Foreground="#D32F2F"/>
                                                </Grid>

                                                <TextBlock Text="{Binding IsSystemDiskLabel}" 
                                                          FontSize="9" Foreground="#FF9800" Margin="0,6,0,0" FontWeight="Bold">
                                                    <TextBlock.IsVisible>
                                                        <Binding Path="IsSystemDisk" />
                                                    </TextBlock.IsVisible>
                                                </TextBlock>
                                            </StackPanel>

                                            <!-- Click Area -->
                                            <!-- Note: Click handling is done via Button inside the card -->
                                        </Grid>
                                    </Border>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid.RowDefinitions>
            </Grid>
        </ScrollViewer>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- ========== ACTION BUTTONS ========== -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="20,0,20,20">
            <Button Content="🧪 Test Povrchu" 
                    Command="{Binding NavigateToSurfaceTestCommand}"
                    IsEnabled="{Binding SelectedDrive, Converter={StaticResource NotNullConverter}}"
                    Background="#004B93" Foreground="White" 
                    Padding="20,12" Margin="0,0,12,0"
                    FontSize="13" Width="200">
                <Button.Styles>
                    <Style Selector="Button">
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Opacity" Value="1"/>
                        <Setter Property="Padding" Value="12,8"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                        <Setter Property="Cursor" Value="Hand"/>
                    </Style>
                    <Style Selector="Button:pointerover">
                        <Setter Property="Opacity" Value="0.9"/>
                    </Style>
                    <Style Selector="Button:pressed">
                        <Setter Property="Opacity" Value="0.78"/>
                    </Style>
                    <Style Selector="Button:disabled">
                        <Setter Property="Opacity" Value="0.45"/>
                    </Style>
                </Button.Styles>
            </Button>
            
            <Button Content="🔧 SMART Check" 
                    Command="{Binding NavigateToSmartCheckCommand}"
                    IsEnabled="{Binding SelectedDrive, Converter={StaticResource NotNullConverter}}"
                    Background="#F7C600" Foreground="#1A1A1A"
                    Padding="20,12" Margin="0,0,12,0"
                    FontSize="13" Width="200">
                <Button.Styles>
                    <Style Selector="Button">
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Opacity" Value="1"/>
                        <Setter Property="Padding" Value="12,8"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                        <Setter Property="Cursor" Value="Hand"/>
                    </Style>
                    <Style Selector="Button:pointerover">
                        <Setter Property="Opacity" Value="0.9"/>
                    </Style>
                    <Style Selector="Button:pressed">
                        <Setter Property="Opacity" Value="0.78"/>
                    </Style>
                    <Style Selector="Button:disabled">
                        <Setter Property="Opacity" Value="0.45"/>
                    </Style>
                </Button.Styles>
            </Button>

            <Button Content="📊 Detail Disku" 
                    Command="{Binding NavigateToDiskDetailCommand}"
                    IsEnabled="{Binding SelectedDrive, Converter={StaticResource NotNullConverter}}"
                    Background="#005A2B" Foreground="White"
                    Padding="20,12"
                    FontSize="13" Width="200">
                <Button.Styles>
                    <Style Selector="Button">
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Opacity" Value="1"/>
                        <Setter Property="Padding" Value="12,8"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                        <Setter Property="Cursor" Value="Hand"/>
                    </Style>
                    <Style Selector="Button:pointerover">
                        <Setter Property="Opacity" Value="0.9"/>
                    </Style>
                    <Style Selector="Button:pressed">
                        <Setter Property="Opacity" Value="0.78"/>
                    </Style>
                    <Style Selector="Button:disabled">
                        <Setter Property="Opacity" Value="0.45"/>
                    </Style>
                </Button.Styles>
            </Button>
        </StackPanel>

        <!-- ========== STATUS BAR ========== -->
        <TextBlock Grid.Row="4" Text="{Binding StatusMessage}" 
                   Background="#F0F0F0" Padding="20,8" 
                   FontSize="11" Foreground="#333333"
                   TextTrimming="CharacterEllipsis"/>
    </Grid>
<!-- END_DISK_ITEM -->
                </StackPanel>
            </DataTemplate>
        </ItemsControl.ItemTemplate>
    </ItemsControl>