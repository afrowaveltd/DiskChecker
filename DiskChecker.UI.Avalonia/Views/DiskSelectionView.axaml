<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:DiskChecker.UI.Avalonia.ViewModels"
             xmlns:converters="using:DiskChecker.UI.Avalonia.Converters"
             x:Class="DiskChecker.UI.Avalonia.Views.DiskSelectionView"
             Background="{DynamicResource ThemeBackgroundBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ========== HEADER ========== -->
        <Border Grid.Row="0" 
                Classes="PageHeader">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel>
                    <TextBlock Text="💾 Vyberte Disk pro Testování" Classes="PageTitle"/>
                    <TextBlock Text="Zvolte disk pro diagnostiku a analýzu" Classes="PageSubtitle"/>
                    <TextBlock Text="{Binding LoadingState}" Classes="PageMetaText" Margin="0,4,0,0"/>
                    <ProgressBar IsIndeterminate="True" 
                                Width="200" Height="3"
                                Margin="0,6,0,0"
                                Background="{DynamicResource ThemeBorderLightBrush}"
                                Foreground="{DynamicResource ThemePrimaryBrush}">
                        <ProgressBar.IsVisible>
                            <Binding Path="IsBusy"/>
                        </ProgressBar.IsVisible>
                    </ProgressBar>
                </StackPanel>

                <Button Grid.Column="1"
                        Content="🔄 Načíst disky"
                        Command="{Binding ReloadDisksCommand}"
                        Background="{DynamicResource ThemePrimaryBrush}"
                        Foreground="White"
                        VerticalAlignment="Center"
                        CornerRadius="6"
                        Padding="12,6"
                        FontWeight="SemiBold"/>
            </Grid>
        </Border>

        <!-- ========== DASHBOARD ========== -->
        <Border Grid.Row="1" Padding="16,12">
            <Grid ColumnDefinitions="2*,*,*">
                
                <!-- Quick SMART Report -->
                <Border Background="{DynamicResource ThemeCardBackgroundBrush}" 
                        BorderBrush="{DynamicResource ThemeBorderBrush}"
                        CornerRadius="8" Padding="14" Margin="0,0,8,0">
                    <StackPanel Spacing="6">
                        <TextBlock Text="📊 Rychlý SMART report - Systémový disk" 
                                   FontSize="12" FontWeight="Bold" 
                                   Foreground="{DynamicResource ThemeTextPrimaryBrush}"/>
                        <TextBlock Text="{Binding SystemDiskName}" 
                                   FontSize="11" FontWeight="SemiBold"
                                   Foreground="{DynamicResource ThemeTextPrimaryBrush}"/>
                        <Border Background="{DynamicResource ThemePrimaryLightBrush}" 
                                CornerRadius="6" Padding="10,8" Margin="0,4,0,0">
                            <Grid ColumnDefinitions="Auto,*">
                                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
                                    <TextBlock FontSize="11" Foreground="{DynamicResource ThemePrimaryBrush}">
                                        <Run Text="Známka: "/>
                                        <Run Text="{Binding SystemDiskGrade}" FontWeight="Bold"/>
                                    </TextBlock>
                                    <TextBlock Text=" | " Foreground="{DynamicResource ThemeTextMutedBrush}" FontSize="11"/>
                                    <TextBlock FontSize="11" Foreground="{DynamicResource ThemeDangerBrush}">
                                        <Run Text="Teplota: "/>
                                        <Run Text="{Binding SystemDiskTemperature}" FontWeight="Bold"/>
                                    </TextBlock>
                                </StackPanel>
                                <TextBlock Grid.Column="1"
                                          Text="✓ OK" FontWeight="Bold"
                                          Foreground="{DynamicResource ThemeSuccessBrush}"
                                          FontSize="11" HorizontalAlignment="Right"
                                          IsVisible="{Binding IsSystemDiskHealthy}"/>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Summary Stats -->
                <Border Background="{DynamicResource ThemeCardBackgroundBrush}" 
                        BorderBrush="{DynamicResource ThemeBorderBrush}"
                        CornerRadius="8" Padding="14" Margin="8,0,8,0">
                    <StackPanel Spacing="4">
                        <TextBlock Text="Fyzické disky" FontSize="10" Foreground="{DynamicResource ThemeTextMutedBrush}"/>
                        <TextBlock Text="{Binding PhysicalDiskCount}" 
                                   FontSize="24" FontWeight="Bold"
                                   Foreground="{DynamicResource ThemePrimaryBrush}"/>
                        <TextBlock Text="{Binding TotalCapacity}" 
                                   FontSize="10"
                                   Foreground="{DynamicResource ThemeTextSecondaryBrush}"/>
                    </StackPanel>
                </Border>

                <!-- Health Overview -->
                <Border Background="{DynamicResource ThemeCardBackgroundBrush}" 
                        BorderBrush="{DynamicResource ThemeBorderBrush}"
                        CornerRadius="8" Padding="14" Margin="8,0,0,0">
                    <StackPanel Spacing="4">
                        <TextBlock Text="Stav testovací sestavy" FontSize="10" Foreground="{DynamicResource ThemeTextMutedBrush}"/>
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <Border Width="10" Height="10" CornerRadius="5" Background="{DynamicResource ThemeSuccessBrush}"/>
                            <TextBlock Text="{Binding HealthyDiskCount}" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource ThemeSuccessBrush}"/>
                            <TextBlock Text=" / " FontSize="14" Foreground="{DynamicResource ThemeTextMutedBrush}" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding PhysicalDiskCount}" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource ThemeTextPrimaryBrush}"/>
                        </StackPanel>
                        <TextBlock Text="{Binding HealthSummary}" 
                                   FontSize="10"
                                   Foreground="{DynamicResource ThemeTextSecondaryBrush}"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- ========== DISK LIST ========== -->
        <Border Grid.Row="2" 
                Background="{DynamicResource ThemeSecondaryBackgroundBrush}" 
                BorderBrush="{DynamicResource ThemeBorderBrush}"
                Margin="16,0,16,8"
                Padding="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <Border Grid.Row="0" 
                        Background="{DynamicResource ThemePanelBackgroundBrush}"
                        Padding="16,10"
                        BorderBrush="{DynamicResource ThemeBorderBrush}"
                        BorderThickness="0,0,0,1">
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <TextBlock Text="💿 Vyberte disk z nabídky" 
                                       FontSize="13" FontWeight="Bold"
                                       Foreground="{DynamicResource ThemeTextPrimaryBrush}"/>
                            <TextBlock Text="🔒 = Zamčeno" 
                                       FontSize="10"
                                       Foreground="{DynamicResource ThemeWarningBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Disk Cards -->
                <ScrollViewer Grid.Row="1" 
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Disabled"
                             Padding="16,10">
                    <ItemsControl ItemsSource="{Binding DiskCards}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal" ItemWidth="420"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <!-- Disk Card - ENLARGED -->
                                <Border CornerRadius="12" Margin="4" Cursor="Hand"
                                       Background="{DynamicResource ThemeCardBackgroundBrush}"
                                       BorderBrush="{DynamicResource ThemeBorderBrush}"
                                       BorderThickness="1"
                                       Width="406" MinHeight="240">
                                    <Border.Styles>
                                        <Style Selector="Border">
                                            <Setter Property="Transitions">
                                                <Transitions>
                                                    <DoubleTransition Property="Opacity" Duration="0:0:0.1"/>
                                                    <BrushTransition Property="BorderBrush" Duration="0:0:0.1"/>
                                                </Transitions>
                                            </Setter>
                                        </Style>
                                        <Style Selector="Border:pointerover">
                                            <Setter Property="Opacity" Value="0.95"/>
                                            <Setter Property="BorderBrush" Value="{DynamicResource ThemePrimaryBrush}"/>
                                        </Style>
                                    </Border.Styles>
                                    
                                    <Grid RowDefinitions="Auto,Auto,Auto,Auto,*">
                                        
                                        <!-- Header with Icon and Disk Type Badge -->
                                        <Grid Grid.Row="0" Margin="14,14,14,8">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <TextBlock Text="💾" FontSize="28" Foreground="{DynamicResource ThemePrimaryBrush}"/>
                                                <Border Background="{DynamicResource ThemePrimaryLightBrush}" 
                                                       CornerRadius="4" Padding="6,2" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding BusTypeDisplay}" FontSize="10" FontWeight="Bold"
                                                              Foreground="{DynamicResource ThemePrimaryBrush}"/>
                                                </Border>
                                            </StackPanel>
                                            <Border Background="{DynamicResource ThemeWarningBackgroundBrush}" CornerRadius="4" Padding="4,2" HorizontalAlignment="Right"
                                                   BorderBrush="{DynamicResource ThemeWarningBorderBrush}"
                                                   BorderThickness="1"
                                                   IsVisible="{Binding IsLocked}">
                                                <TextBlock Text="🔒 Uzamčen" FontSize="9" FontWeight="Bold" Foreground="{DynamicResource ThemeWarningTextBrush}"/>
                                            </Border>
                                        </Grid>

                                        <!-- Disk Info -->
                                        <StackPanel Grid.Row="1" Margin="14,0,14,6">
                                            <TextBlock Text="{Binding DisplayName}" 
                                                      FontSize="14" FontWeight="Bold"
                                                      Foreground="{DynamicResource ThemeTextPrimaryBrush}"
                                                      TextTrimming="CharacterEllipsis"
                                                      MaxLines="1"/>
                                            <TextBlock Text="{Binding DisplayPath}" 
                                                      FontSize="9"
                                                      Foreground="{DynamicResource ThemeTextMutedBrush}"
                                                      TextTrimming="CharacterEllipsis"
                                                      Margin="0,1,0,0"/>
                                            <TextBlock Text="{Binding SerialNumber, StringFormat='S/N: {0}'}" 
                                                      FontSize="9"
                                                      Foreground="{DynamicResource ThemeTextMutedBrush}"
                                                      TextTrimming="CharacterEllipsis"
                                                      Margin="0,1,0,0"
                                                      IsVisible="{Binding SerialNumber, Converter={StaticResource NotNullConverter}}"/>
                                        </StackPanel>

                                        <!-- Metrics -->
                                        <Border Grid.Row="2" 
                                               Background="{DynamicResource ThemePanelBackgroundBrush}"
                                               Margin="14,0,14,8"
                                               Padding="12,8"
                                               CornerRadius="6">
                                            <Grid ColumnDefinitions="*,*,*">
                                                <StackPanel>
                                                    <TextBlock Text="Velikost" FontSize="9" Foreground="{DynamicResource ThemeTextMutedBrush}"/>
                                                    <TextBlock Text="{Binding CapacityText}" FontSize="12" FontWeight="Bold"
                                                              Foreground="{DynamicResource ThemePrimaryBrush}"/>
                                                </StackPanel>
                                                <StackPanel HorizontalAlignment="Center">
                                                    <TextBlock Text="SMART" FontSize="9" Foreground="{DynamicResource ThemeTextMutedBrush}"
                                                              HorizontalAlignment="Center"/>
                                                    <TextBlock Text="{Binding GradeText}" FontSize="12" FontWeight="Bold"
                                                              Foreground="{DynamicResource ThemeSuccessBrush}"
                                                              HorizontalAlignment="Center"/>
                                                </StackPanel>
                                                <StackPanel HorizontalAlignment="Right">
                                                    <TextBlock Text="Teplota" FontSize="9" Foreground="{DynamicResource ThemeTextMutedBrush}"
                                                              HorizontalAlignment="Right"/>
                                                    <TextBlock Text="{Binding TemperatureText}" FontSize="12" FontWeight="Bold"
                                                              Foreground="{DynamicResource ThemeDangerBrush}"
                                                              HorizontalAlignment="Right"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>

                                        <!-- Partitions Section -->
                                        <Border Grid.Row="3" 
                                               Background="{DynamicResource ThemeSecondaryBackgroundBrush}"
                                               Margin="14,0,14,8"
                                               Padding="10,6"
                                               CornerRadius="6"
                                               IsVisible="{Binding HasMountPoints}">
                                            <StackPanel Spacing="4">
                                                <TextBlock Text="📁 Oddíly a přípojné body" FontSize="10" FontWeight="Bold"
                                                          Foreground="{DynamicResource ThemeTextPrimaryBrush}"/>
                                                <TextBlock Text="{Binding PartitionsDisplay}" 
                                                          FontSize="9"
                                                          Foreground="{DynamicResource ThemeTextSecondaryBrush}"
                                                          TextWrapping="Wrap"
                                                          MaxLines="3"
                                                          TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>
                                        </Border>

                                        <!-- Status Labels -->
                                        <Grid Grid.Row="4" Margin="14,0,14,14" VerticalAlignment="Bottom">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" Spacing="2">
                                                <Border Background="{DynamicResource ThemeWarningBackgroundBrush}" CornerRadius="3" Padding="6,2" HorizontalAlignment="Left"
                                                       BorderBrush="{DynamicResource ThemeWarningBorderBrush}"
                                                       BorderThickness="1"
                                                       IsVisible="{Binding IsSystemDisk}">
                                                    <TextBlock Text="{Binding IsSystemDiskLabel}" 
                                                              FontSize="9" FontWeight="SemiBold"
                                                              Foreground="{DynamicResource ThemeWarningTextBrush}"/>
                                                </Border>
                                                <TextBlock Text="{Binding LockStatusText}" 
                                                          FontSize="9"
                                                          Foreground="{DynamicResource ThemeDangerBrush}"
                                                          TextWrapping="Wrap"
                                                          IsVisible="{Binding IsLocked}"/>
                                            </StackPanel>
                                            
                                            <!-- Lock Button -->
                                            <Button Grid.Column="1"
                                                    Command="{Binding $parent[ItemsControl].DataContext.ToggleLockDiskCommand}"
                                                    CommandParameter="{Binding}"
                                                    Background="{DynamicResource ThemeInfoBrush}" Foreground="White"
                                                    FontSize="9" Padding="10,4"
                                                    HorizontalAlignment="Right"
                                                    VerticalAlignment="Bottom"
                                                    CornerRadius="4"
                                                    IsVisible="{Binding IsSystemDisk, Converter={StaticResource InverseBooleanConverter}}">
                                                <TextBlock Text="{Binding IsLocked, Converter={StaticResource LockTextConverter}}"/>
                                            </Button>
                                        </Grid>

                                        <!-- Click Overlay -->
                                        <Button Grid.Row="0" Grid.RowSpan="5"
                                                Command="{Binding $parent[ItemsControl].DataContext.SelectDiskCommand}"
                                                CommandParameter="{Binding}"
                                                Background="Transparent"
                                                HorizontalAlignment="Stretch"
                                                VerticalAlignment="Stretch"
                                                BorderThickness="0"
                                                Cursor="Hand">
                                            <Button.Template>
                                                <ControlTemplate>
                                                    <Border Background="Transparent"/>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- ========== STATUS BAR ========== -->
        <Border Grid.Row="3" 
                Classes="StatusBar">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0" 
                           Text="{Binding StatusMessage}" 
                           Classes="StatusText"
                           Margin="16,0"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="16,0" Spacing="8">
                    <Border Background="{DynamicResource ThemeSuccessBrush}" Width="8" Height="8" CornerRadius="4"/>
                    <TextBlock FontSize="10" Foreground="{DynamicResource ThemeTextMutedBrush}">Aplikace připravena</TextBlock>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>