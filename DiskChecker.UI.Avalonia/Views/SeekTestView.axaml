<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:DiskChecker.UI.Avalonia.ViewModels"
             xmlns:converters="using:DiskChecker.UI.Avalonia.Converters"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.Avalonia;assembly=LiveChartsCore.SkiaSharpView.Avalonia"
             x:Class="DiskChecker.UI.Avalonia.Views.SeekTestView"
             Background="{DynamicResource ThemeBackgroundBrush}">

    <UserControl.Resources>
        <converters:BytesToHumanReadableConverter x:Key="BytesToHumanReadableConverter"/>
    </UserControl.Resources>

    <UserControl.Styles>
        <Style Selector="Border.SeekCard">
            <Setter Property="Background" Value="{DynamicResource ThemeCardBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16"/>
        </Style>
        <Style Selector="Border.SeekPanel">
            <Setter Property="Background" Value="{DynamicResource ThemePanelBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="12"/>
        </Style>
        <Style Selector="TextBlock.SeekSectionTitle">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextPrimaryBrush}"/>
        </Style>
        <Style Selector="TextBlock.SeekLabel">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextMutedBrush}"/>
        </Style>
        <Style Selector="TextBlock.SeekValue">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>
    </UserControl.Styles>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ========== HEADER ========== -->
        <Border Grid.Row="0" Classes="PageHeader">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel>
                    <TextBlock Text="{Binding L[SeekTest.Title]}" Classes="PageTitle"/>
                    <TextBlock Text="{Binding L[SeekTest.Description]}" Classes="PageSubtitle"/>
                    <Border Margin="0,4,0,0" Padding="8,4" CornerRadius="6"
                            BorderBrush="{DynamicResource ThemeBorderBrush}" BorderThickness="1">
                        <Border.Styles>
                            <Style Selector="Border">
                                <Setter Property="Background" Value="{DynamicResource ThemeSecondaryBackgroundBrush}"/>
                            </Style>
                        </Border.Styles>
                        <TextBlock Text="{Binding StatusMessage}" Classes="PageMetaText" TextWrapping="Wrap"/>
                    </Border>
                </StackPanel>
                <Button Grid.Column="1"
                        Content="{Binding L[SeekTest.BackToOverview]}"
                        Command="{Binding GoBackCommand}"
                        Background="{DynamicResource ThemeSecondaryBackgroundBrush}"
                        Foreground="{DynamicResource ThemeTextPrimaryBrush}"
                        BorderBrush="{DynamicResource ThemeBorderBrush}"
                        VerticalAlignment="Center"
                        CornerRadius="6"
                        Padding="12,6"
                        FontWeight="SemiBold"/>
            </Grid>
        </Border>

        <!-- ========== DISK SELECTION + RECOMMENDATION ========== -->
        <Border Grid.Row="1" Padding="16,8">
            <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="*,Auto">
                <!-- Disk Info Card -->
                <Border Classes="SeekCard" Padding="12">
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                        <Border Width="34" Height="34" CornerRadius="17"
                                Background="{DynamicResource ThemePrimaryLightBrush}"
                                VerticalAlignment="Center">
                            <TextBlock Text="💿" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="{Binding L[SeekTest.SelectedDisk]}" Classes="SeekLabel"/>
                            <TextBlock Text="{Binding DriveDisplayName}" FontSize="15" FontWeight="Bold"/>
                            <TextBlock Text="{Binding DriveCapacityText}" Classes="PageMetaText"/>
                        </StackPanel>
                        <!-- Recommendation badge -->
                        <Border Grid.Column="2" CornerRadius="6" Padding="10,6" VerticalAlignment="Center"
                                Background="{DynamicResource ThemePrimaryLightBrush}"
                                BorderBrush="{DynamicResource ThemeBorderBrush}" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="{Binding L[SeekTest.SmartRecommendation]}" Classes="SeekLabel" HorizontalAlignment="Center"/>
                                <TextBlock Text="{Binding RecommendationText}" FontSize="12" FontWeight="Bold"
                                          HorizontalAlignment="Center" TextWrapping="Wrap" MaxWidth="300"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <!-- Recommendation rationale -->
                <Border Grid.Row="1" Margin="0,8,0,0" Padding="12,8" CornerRadius="8"
                        Background="{DynamicResource ThemePanelBackgroundBrush}"
                        BorderBrush="{DynamicResource ThemeBorderBrush}" BorderThickness="1"
                        IsVisible="{Binding RecommendationRationale, Converter={StaticResource StringToBoolConverter}}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="📋" FontSize="14" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding RecommendationRationale}" FontSize="11"
                                  Foreground="{DynamicResource ThemeTextSecondaryBrush}"
                                  TextWrapping="Wrap" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Fragile disk warning -->
                <Border Grid.Column="1" Grid.RowSpan="2" Margin="12,0,0,0" Padding="16,12" CornerRadius="8"
                        Background="{DynamicResource ThemeDangerBackgroundBrush}"
                        BorderBrush="{DynamicResource ThemeDangerBrush}" BorderThickness="2"
                        IsVisible="{Binding IsDiskTooFragile}"
                        VerticalAlignment="Center">
                    <StackPanel>
                        <TextBlock Text="{Binding L[SeekTest.DiskTooWorn]}" FontSize="14" FontWeight="Bold"
                                  Foreground="{DynamicResource ThemeDangerBrush}"/>
                        <TextBlock Text="{Binding L[SeekTest.CannotRun]}"
                                  FontSize="11" Foreground="{DynamicResource ThemeTextSecondaryBrush}"
                                  TextWrapping="Wrap" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- ========== MAIN CONTENT ========== -->
        <ScrollViewer Grid.Row="2">
            <StackPanel Margin="16,0,16,8" Spacing="12">

                <!-- ===== TEST CONFIGURATION ===== -->
                <Border Classes="SeekCard">
                    <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="3*,2*" ColumnSpacing="14" RowSpacing="12">
                        <Grid Grid.Row="0" Grid.ColumnSpan="2" ColumnDefinitions="*,Auto">
                            <TextBlock Text="{Binding L[SeekTest.TestConfiguration]}" Classes="SeekSectionTitle"/>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding MaxSafeSeekCount, StringFormat='Max bezpečně: {0}'}"
                                       FontSize="10"
                                       Foreground="{DynamicResource ThemeTextSecondaryBrush}"
                                       VerticalAlignment="Center"/>
                        </Grid>

                        <!-- Test Type Selection -->
                        <Border Grid.Row="1" Grid.Column="0" Classes="SeekPanel">
                            <StackPanel Spacing="8">
                                <TextBlock Text="{Binding L[SeekTest.TestType]}" FontSize="12" FontWeight="SemiBold"/>
                                <ListBox ItemsSource="{Binding TestTypeOptions}"
                                         SelectedIndex="{Binding SelectedTestType, Converter={StaticResource EnumToIndexConverter}}"
                                         IsEnabled="{Binding IsNotTesting}"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         Padding="0">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Margin="2" Spacing="2">
                                                <TextBlock Text="{Binding Name}" FontSize="12" FontWeight="SemiBold"/>
                                                <TextBlock Text="{Binding Description}" FontSize="10"
                                                           Foreground="{DynamicResource ThemeTextMutedBrush}"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </StackPanel>
                        </Border>

                        <!-- Seek Count -->
                        <StackPanel Grid.Row="1" Grid.Column="1" Spacing="10">
                            <Border Classes="SeekPanel">
                                <StackPanel Spacing="8">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <TextBlock Text="{Binding L[SeekTest.SeekCount]}" FontSize="12" FontWeight="SemiBold"/>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4">
                                            <TextBlock Text="{Binding L[SeekTest.Recommended]}" Classes="SeekLabel" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding RecommendedSeekCount}" FontSize="10"
                                                       FontWeight="Bold" Foreground="{DynamicResource ThemePrimaryBrush}"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Grid>
                                    <NumericUpDown Value="{Binding SelectedSeekCount}"
                                                   Minimum="100" Maximum="10000" Increment="100"
                                                   IsEnabled="{Binding IsNotTesting}"
                                                   HorizontalAlignment="Stretch"/>
                                    <Border Background="{DynamicResource ThemeWarningBackgroundBrush}"
                                            BorderBrush="{DynamicResource ThemeWarningBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="5" Padding="8,6"
                                            IsVisible="{Binding IsSeekCountExceedsSafe}">
                                        <TextBlock Text="{Binding L[SeekTest.SeekCountWarning]}"
                                                   FontSize="10" Foreground="{DynamicResource ThemeWarningTextBrush}"
                                                   TextWrapping="Wrap"/>
                                    </Border>
                                </StackPanel>
                            </Border>

                            <!-- Skip Segments (only for Skip type) -->
                            <Border Classes="SeekPanel" IsVisible="{Binding IsSkipSelected}">
                                <StackPanel Spacing="8">
                                    <TextBlock Text="{Binding L[SeekTest.SkipSegments]}" FontSize="12" FontWeight="SemiBold"/>
                                    <NumericUpDown Value="{Binding SelectedSkipSegments}"
                                                   Minimum="100" Maximum="10000" Increment="100"
                                                   IsEnabled="{Binding IsNotTesting}"
                                                   HorizontalAlignment="Stretch"/>
                                </StackPanel>
                            </Border>

                            <!-- Advanced options -->
                            <Border Classes="SeekPanel">
                                <StackPanel Spacing="8">
                                    <TextBlock Text="{Binding L[SeekTest.Advanced]}" FontSize="12" FontWeight="SemiBold"/>
                                    <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto" ColumnSpacing="10" RowSpacing="8">
                                        <TextBlock Text="{Binding L[SeekTest.BlockSize]}" Classes="SeekLabel"
                                                   VerticalAlignment="Center"/>
                                        <NumericUpDown Grid.Column="1" Value="{Binding BlockSizeBytes}"
                                                       Minimum="512" Maximum="65536" Increment="512"
                                                       IsEnabled="{Binding IsNotTesting}"
                                                       HorizontalAlignment="Stretch"/>
                                        <TextBlock Grid.Row="1" Text="{Binding L[SeekTest.Timeout]}" Classes="SeekLabel"
                                                   VerticalAlignment="Center"/>
                                        <NumericUpDown Grid.Row="1" Grid.Column="1" Value="{Binding TimeoutSeconds}"
                                                       Minimum="30" Maximum="3600" Increment="30"
                                                       IsEnabled="{Binding IsNotTesting}"
                                                       HorizontalAlignment="Stretch"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- Action Buttons -->
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                <Button Content="{Binding L[SeekTest.StartTest]}"
                                        Command="{Binding StartTestCommand}"
                                        Classes="Primary"
                                        HorizontalAlignment="Stretch"
                                        Padding="16,10"
                                        IsVisible="{Binding IsNotTesting}"/>
                                <Button Content="{Binding L[SeekTest.CancelTest]}"
                                        Command="{Binding AbortTestCommand}"
                                        Classes="Danger"
                                        HorizontalAlignment="Stretch"
                                        Padding="16,10"
                                        IsVisible="{Binding IsTesting}"/>
                                <Button Grid.Column="1"
                                        Content="{Binding L[SeekTest.Reload]}"
                                        Command="{Binding LoadRecommendationCommand}"
                                        Classes="Secondary"
                                        Padding="12,10"
                                        IsVisible="{Binding IsNotTesting}"/>
                            </Grid>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- ===== PROGRESS ===== -->
                <Border Background="{DynamicResource ThemeCardBackgroundBrush}"
                        BorderBrush="{DynamicResource ThemeBorderBrush}"
                        CornerRadius="8" Padding="16"
                        IsVisible="{Binding IsTesting}">
                    <StackPanel Spacing="8">
                        <TextBlock Text="{Binding L[SeekTest.TestProgress]}" FontSize="14" FontWeight="Bold"/>

                        <!-- Pre-positioning indicator -->
                        <Border CornerRadius="4" Padding="6,4"
                                Background="{DynamicResource ThemeSecondaryBackgroundBrush}"
                                IsVisible="{Binding IsPrePositioned}">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <TextBlock Text="📍" FontSize="10"/>
                                <TextBlock Text="{Binding L[SeekTest.HeadPositioned]}" FontSize="10"
                                          Foreground="{DynamicResource ThemeSuccessBrush}"/>
                            </StackPanel>
                        </Border>

                        <!-- Progress bar -->
                        <Grid ColumnDefinitions="*,Auto">
                            <ProgressBar Value="{Binding ProgressPercent}" Minimum="0" Maximum="100"
                                         Height="20" CornerRadius="4"
                                         Foreground="{DynamicResource ThemePrimaryBrush}"
                                         Background="{DynamicResource ThemeSecondaryBackgroundBrush}"/>
                            <TextBlock Grid.Column="1" Text="{Binding ProgressPercent, StringFormat='{}{0:F0}%'}"
                                      FontSize="14" FontWeight="Bold" Margin="12,0,0,0"
                                      VerticalAlignment="Center"/>
                        </Grid>

                        <!-- Stats -->
                        <Grid ColumnDefinitions="Auto,*,Auto,Auto">
                            <TextBlock Text="{Binding CompletedSeeks, StringFormat='{}Seeků: {0}'}"
                                      FontSize="11" Foreground="{DynamicResource ThemeTextSecondaryBrush}"/>
                            <TextBlock Grid.Column="1" Text="/" FontSize="11"
                                      Foreground="{DynamicResource ThemeTextMutedBrush}"
                                      HorizontalAlignment="Center"/>
                            <TextBlock Grid.Column="2" Text="{Binding TotalSeeks, StringFormat='{}{0} celkem'}"
                                      FontSize="11" Foreground="{DynamicResource ThemeTextSecondaryBrush}"/>
                            <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="12" Margin="12,0,0,0">
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <TextBlock Text="⏱️" FontSize="10"/>
                                    <TextBlock Text="{Binding ElapsedTime}" FontSize="11"
                                              Foreground="{DynamicResource ThemeTextSecondaryBrush}"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <TextBlock Text="⏳" FontSize="10"/>
                                    <TextBlock Text="{Binding EstimatedRemaining}" FontSize="11"
                                              Foreground="{DynamicResource ThemeTextSecondaryBrush}"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>

                        <!-- Real-time latest sample -->
                        <Border CornerRadius="4" Padding="8,6"
                                Background="{DynamicResource ThemeSecondaryBackgroundBrush}"
                                IsVisible="{Binding HasLatestSample}">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="🔍" FontSize="12" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding L[SeekTest.LatestSample]}" FontSize="10"
                                          Foreground="{DynamicResource ThemeTextMutedBrush}"
                                          VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding LatestSampleText}" FontSize="11" FontWeight="SemiBold"
                                          Foreground="{DynamicResource ThemePrimaryBrush}"
                                          VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <!-- Real-time chart during test -->
                        <Border Background="{DynamicResource ThemeSecondaryBackgroundBrush}"
                                CornerRadius="6" Padding="8"
                                IsVisible="{Binding IsTesting}">
                            <Grid>
                                <lvc:CartesianChart Series="{Binding LatencySeries}"
                                                    XAxes="{Binding LatencyXAxes}"
                                                    YAxes="{Binding LatencyYAxes}"
                                                    ZoomMode="None"
                                                    TooltipPosition="Top"
                                                    LegendPosition="Hidden"
                                                    AnimationsSpeed="0:0:0"
                                                    Height="200"/>
                                <TextBlock Text="{Binding L[SeekTest.WaitingForData]}"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Center"
                                           FontSize="12"
                                           Foreground="{DynamicResource ThemeTextMutedBrush}"
                                           IsVisible="{Binding ChartPointCount, Converter={StaticResource InvertedIntToBoolConverter}}"/>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- ===== RESULTS ===== -->
                <Border Background="{DynamicResource ThemeCardBackgroundBrush}"
                        BorderBrush="{DynamicResource ThemeBorderBrush}"
                        CornerRadius="8" Padding="16"
                        IsVisible="{Binding HasResults}">
                    <StackPanel Spacing="10">
                        <TextBlock Text="{Binding L[SeekTest.Results]}" FontSize="14" FontWeight="Bold"/>

                        <!-- Summary -->
                        <Border Background="{DynamicResource ThemeSecondaryBackgroundBrush}"
                                CornerRadius="6" Padding="10,8">
                            <TextBlock Text="{Binding ResultSummary}" FontSize="12" FontWeight="SemiBold"
                                      TextWrapping="Wrap"/>
                        </Border>

                        <!-- Latency metrics -->
                        <Grid ColumnDefinitions="*,*,*,*" RowDefinitions="Auto,Auto,Auto">
                            <!-- Average -->
                            <Border Grid.Column="0" Background="{DynamicResource ThemeSecondaryBackgroundBrush}"
                                    CornerRadius="6" Padding="10,8" Margin="0,0,4,0">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="{Binding L[SeekTest.Average]}" FontSize="9" Foreground="{DynamicResource ThemeTextMutedBrush}"
                                              HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding AverageLatencyMs, StringFormat='{}{0:F2} ms'}"
                                              FontSize="16" FontWeight="Bold"
                                              Foreground="{DynamicResource ThemePrimaryBrush}"
                                              HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <!-- Median -->
                            <Border Grid.Column="1" Background="{DynamicResource ThemeSecondaryBackgroundBrush}"
                                    CornerRadius="6" Padding="10,8" Margin="2,0">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="{Binding L[SeekTest.Median]}" FontSize="9" Foreground="{DynamicResource ThemeTextMutedBrush}"
                                              HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding MedianLatencyMs, StringFormat='{}{0:F2} ms'}"
                                              FontSize="16" FontWeight="Bold"
                                              Foreground="{DynamicResource ThemeAccentBrush}"
                                              HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <!-- Min -->
                            <Border Grid.Column="2" Background="{DynamicResource ThemeSecondaryBackgroundBrush}"
                                    CornerRadius="6" Padding="10,8" Margin="2,0">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="{Binding L[SeekTest.Min]}" FontSize="9" Foreground="{DynamicResource ThemeTextMutedBrush}"
                                              HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding MinLatencyMs, StringFormat='{}{0:F2} ms'}"
                                              FontSize="16" FontWeight="Bold"
                                              Foreground="{DynamicResource ThemeSuccessBrush}"
                                              HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <!-- Max -->
                            <Border Grid.Column="3" Background="{DynamicResource ThemeSecondaryBackgroundBrush}"
                                    CornerRadius="6" Padding="10,8" Margin="4,0,0,0">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="{Binding L[SeekTest.Max]}" FontSize="9" Foreground="{DynamicResource ThemeTextMutedBrush}"
                                              HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding MaxLatencyMs, StringFormat='{}{0:F2} ms'}"
                                              FontSize="16" FontWeight="Bold"
                                              Foreground="{DynamicResource ThemeDangerBrush}"
                                              HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <!-- StdDev -->
                            <Border Grid.Row="1" Grid.Column="0" Background="{DynamicResource ThemeSecondaryBackgroundBrush}"
                                    CornerRadius="6" Padding="10,8" Margin="0,6,4,0">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="{Binding L[SeekTest.StdDev]}" FontSize="9" Foreground="{DynamicResource ThemeTextMutedBrush}"
                                              HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding StdDevLatencyMs, StringFormat='{}{0:F2} ms'}"
                                              FontSize="16" FontWeight="Bold"
                                              Foreground="{DynamicResource ThemeTextSecondaryBrush}"
                                              HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <!-- P95 -->
                            <Border Grid.Row="1" Grid.Column="1" Background="{DynamicResource ThemeSecondaryBackgroundBrush}"
                                    CornerRadius="6" Padding="10,8" Margin="2,6,2,0">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="P95" FontSize="9" Foreground="{DynamicResource ThemeTextMutedBrush}"
                                              HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding P95LatencyMs, StringFormat='{}{0:F2} ms'}"
                                              FontSize="16" FontWeight="Bold"
                                              Foreground="{DynamicResource ThemeWarningBrush}"
                                              HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <!-- P99 -->
                            <Border Grid.Row="1" Grid.Column="2" Background="{DynamicResource ThemeSecondaryBackgroundBrush}"
                                    CornerRadius="6" Padding="10,8" Margin="2,6,2,0">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="{Binding L[SeekTest.P99]}" FontSize="9" Foreground="{DynamicResource ThemeTextMutedBrush}"
                                              HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding P99LatencyMs, StringFormat='{}{0:F2} ms'}"
                                              FontSize="16" FontWeight="Bold"
                                              Foreground="{DynamicResource ThemeDangerBrush}"
                                              HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <!-- Error count -->
                            <Border Grid.Row="1" Grid.Column="3" Background="{DynamicResource ThemeSecondaryBackgroundBrush}"
                                    CornerRadius="6" Padding="10,8" Margin="4,6,0,0">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="Chyby" FontSize="9" Foreground="{DynamicResource ThemeTextMutedBrush}"
                                              HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding ErrorCount}" FontSize="16" FontWeight="Bold"
                                              Foreground="{DynamicResource ThemeDangerBrush}"
                                              HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- Latency distribution chart (final) -->
                        <!-- NOTE: IsVisible is intentionally NOT bound here – the chart must remain
                             in the visual tree from the start so LiveCharts2 SkiaSharp initializes
                             its render surface. The "no data" overlay handles the empty state. -->
                        <Border Background="{DynamicResource ThemeSecondaryBackgroundBrush}"
                                CornerRadius="6" Padding="8">
                            <StackPanel Spacing="4">
                                <!-- Legend row 1: sample points -->
                                <StackPanel Orientation="Horizontal" Spacing="12" Margin="4,0,0,2">
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <Ellipse Width="8" Height="8" Fill="DodgerBlue" Margin="0,0,2,0"/>
                                        <TextBlock Text="{Binding L[SeekTest.NormalSamples]}" FontSize="9" Foreground="{DynamicResource ThemeTextSecondaryBrush}"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <Ellipse Width="10" Height="10" Fill="Orange" Margin="0,0,2,0"/>
                                        <TextBlock Text="{Binding L[SeekTest.Outliers]}" FontSize="9" Foreground="{DynamicResource ThemeTextSecondaryBrush}"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <Ellipse Width="11" Height="11" Fill="Red" Margin="0,0,2,0"/>
                                        <TextBlock Text="{Binding L[SeekTest.Extreme]}" FontSize="9" Foreground="{DynamicResource ThemeTextSecondaryBrush}"/>
                                    </StackPanel>
                                </StackPanel>
                                <!-- Legend row 2: reference lines -->
                                <StackPanel Orientation="Horizontal" Spacing="12" Margin="4,0,0,4">
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <Border Width="14" Height="2" Background="OrangeRed" CornerRadius="1"
                                                VerticalAlignment="Center" Margin="0,0,2,0"/>
                                        <TextBlock Text="{Binding L[SeekTest.Average]}" FontSize="9" Foreground="{DynamicResource ThemeTextSecondaryBrush}"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <Border Width="14" Height="2" Background="MediumPurple" CornerRadius="1"
                                                VerticalAlignment="Center" Margin="0,0,2,0"/>
                                        <TextBlock Text="{Binding L[SeekTest.Median]}" FontSize="9" Foreground="{DynamicResource ThemeTextSecondaryBrush}"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <Border Width="14" Height="2" Background="Gold" CornerRadius="1"
                                                VerticalAlignment="Center" Margin="0,0,2,0"/>
                                        <TextBlock Text="P95" FontSize="9" Foreground="{DynamicResource ThemeTextSecondaryBrush}"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <Border Width="14" Height="2" Background="DarkOrange" CornerRadius="1"
                                                VerticalAlignment="Center" Margin="0,0,2,0"/>
                                        <TextBlock Text="P99" FontSize="9" Foreground="{DynamicResource ThemeTextSecondaryBrush}"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <Border Width="14" Height="2" Background="LimeGreen" CornerRadius="1"
                                                VerticalAlignment="Center" Margin="0,0,2,0"/>
                                        <TextBlock Text="Minimum" FontSize="9" Foreground="{DynamicResource ThemeTextSecondaryBrush}"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <Border Width="14" Height="2" Background="Tomato" CornerRadius="1"
                                                VerticalAlignment="Center" Margin="0,0,2,0"/>
                                        <TextBlock Text="Maximum" FontSize="9" Foreground="{DynamicResource ThemeTextSecondaryBrush}"/>
                                    </StackPanel>
                                </StackPanel>
                                <Grid>
                                    <lvc:CartesianChart Series="{Binding FinalLatencySeries}"
                                                        XAxes="{Binding FinalLatencyXAxes}"
                                                        YAxes="{Binding FinalLatencyYAxes}"
                                                        ZoomMode="None"
                                                        TooltipPosition="Top"
                                                        LegendPosition="Hidden"
                                                        AnimationsSpeed="0:0:0"
                                                        Height="250"/>
                                    <TextBlock Text="{Binding L[SeekTest.NoData]}"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Center"
                                               FontSize="12"
                                               Foreground="{DynamicResource ThemeTextMutedBrush}"
                                               IsVisible="{Binding FinalChartPointCount, Converter={StaticResource InvertedIntToBoolConverter}}"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Samples table (first 50) -->
                        <Border Background="{DynamicResource ThemeSecondaryBackgroundBrush}"
                                CornerRadius="6" Padding="8"
                                IsVisible="{Binding Samples.Count, Converter={StaticResource IntToBoolConverter}}">
                            <StackPanel Spacing="4">
                                <TextBlock Text="{Binding L[SeekTest.LatencySamples]}" FontSize="10"
                                          Foreground="{DynamicResource ThemeTextMutedBrush}"/>
                                <ScrollViewer MaxHeight="200">
                                    <ItemsControl ItemsSource="{Binding Samples}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Padding="4,2" BorderBrush="{DynamicResource ThemeBorderBrush}"
                                                        BorderThickness="0,0,0,1">
                                                    <Grid ColumnDefinitions="40,80,80,80,80,*">
                                                        <TextBlock Text="{Binding Index, StringFormat='{}#{0}'}"
                                                                  FontSize="10" Foreground="{DynamicResource ThemeTextMutedBrush}"/>
                                                        <TextBlock Grid.Column="1"
                                                                  Text="{Binding LatencyMs, StringFormat='{}{0:F2} ms'}"
                                                                  FontSize="10" FontWeight="SemiBold"/>
                                                        <TextBlock Grid.Column="2"
                                                                  Text="{Binding SourceLba, StringFormat='{}Src: {0}'}"
                                                                  FontSize="9" Foreground="{DynamicResource ThemeTextMutedBrush}"/>
                                                        <TextBlock Grid.Column="3"
                                                                  Text="{Binding DestinationLba, StringFormat='{}Dst: {0}'}"
                                                                  FontSize="9" Foreground="{DynamicResource ThemeTextMutedBrush}"/>
                                                        <TextBlock Grid.Column="4"
                                                                  Text="{Binding SeekDistance, StringFormat='{}Δ: {0}'}"
                                                                  FontSize="9" Foreground="{DynamicResource ThemeTextSecondaryBrush}"/>
                                                        <TextBlock Grid.Column="5"
                                                                  Text="{Binding ErrorMessage}"
                                                                  FontSize="9" Foreground="{DynamicResource ThemeDangerBrush}"
                                                                  TextTrimming="CharacterEllipsis"/>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- ========== BOTTOM STATUS BAR ========== -->
        <Border Grid.Row="3"
                Background="{DynamicResource ThemeSecondaryBackgroundBrush}"
                BorderBrush="{DynamicResource ThemeBorderBrush}"
                BorderThickness="0,1,0,0"
                MinHeight="24" Padding="12,3">
            <StackPanel Orientation="Horizontal" Spacing="12">
                <TextBlock Text="📌" Foreground="{DynamicResource ThemePrimaryBrush}" FontSize="10"
                          VerticalAlignment="Center"/>
                <TextBlock Text="{Binding StatusMessage}"
                          Foreground="{DynamicResource ThemeTextSecondaryBrush}"
                          FontSize="11" TextTrimming="CharacterEllipsis"
                          VerticalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
