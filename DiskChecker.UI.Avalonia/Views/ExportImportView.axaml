<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:DiskChecker.UI.Avalonia.ViewModels"
             xmlns:converters="using:DiskChecker.UI.Avalonia.Converters"
             x:Class="DiskChecker.UI.Avalonia.Views.ExportImportView"
             x:DataType="vm:ExportImportViewModel"
             Background="{DynamicResource ThemeBackgroundBrush}">

    <UserControl.Resources>
        <converters:EnumToBooleanConverter x:Key="EnumToBooleanConverter"/>
        <converters:InverseBooleanConverter x:Key="InverseBooleanConverter"/>
        <converters:NotNullConverter x:Key="NotNullConverter"/>
        <converters:IntToBoolConverter x:Key="IntToBoolConverter"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ═══ HEADER ═══ -->
        <Border Grid.Row="0" Classes="PageHeader">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel>
                    <TextBlock Text="{Binding L[ExportImport.Title]}" Classes="PageTitle"/>
                    <TextBlock Text="{Binding L[ExportImport.Description]}" Classes="PageSubtitle"/>
                    <TextBlock Text="{Binding StatusMessage}" Classes="PageMetaText" Margin="0,2,0,0"/>
                </StackPanel>
                <Button Grid.Column="1"
                        Content="{Binding L[Common.Back]}"
                        Command="{Binding GoBackCommand}"
                        Background="{DynamicResource ThemeSecondaryBackgroundBrush}"
                        Foreground="{DynamicResource ThemeTextPrimaryBrush}"
                        BorderBrush="{DynamicResource ThemeBorderBrush}"
                        VerticalAlignment="Center"
                        CornerRadius="6"
                        Padding="14,8"
                        FontWeight="SemiBold"/>
            </Grid>
        </Border>

        <!-- ═══ MAIN CONTENT ═══ -->
        <ScrollViewer Grid.Row="1">
            <StackPanel Spacing="12" Margin="16,8">

                <!-- ════════════════════════════════════════ -->
                <!-- EXPORT SECTION -->
                <!-- ════════════════════════════════════════ -->
                <Border Background="{DynamicResource ThemeCardBackgroundBrush}"
                        CornerRadius="8" Padding="16"
                        BorderBrush="{DynamicResource ThemeBorderBrush}" BorderThickness="1">
                    <StackPanel Spacing="10">
                        <TextBlock Text="{Binding L[ExportImport.ExportSection]}" FontSize="16" FontWeight="Bold"
                                   Foreground="{DynamicResource ThemeTextPrimaryBrush}"/>

                        <!-- Export scope -->
                        <TextBlock Text="{Binding L[ExportImport.ExportScope]}" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource ThemeTextSecondaryBrush}"/>

                        <StackPanel Spacing="6" Margin="12,0,0,0">
                            <RadioButton Content="{Binding L[ExportImport.ExportAll]}" 
                                         IsChecked="{Binding IsExportAll}"
                                         GroupName="ExportScope"
                                         Foreground="{DynamicResource ThemeTextPrimaryBrush}"/>
                            <RadioButton Content="{Binding L[ExportImport.ExportMeasurements]}"
                                         IsChecked="{Binding IsExportMeasurements}"
                                         GroupName="ExportScope"
                                         Foreground="{DynamicResource ThemeTextPrimaryBrush}"/>
                            <RadioButton Content="{Binding L[ExportImport.ExportSelected]}"
                                         IsChecked="{Binding IsExportSelected}"
                                         GroupName="ExportScope"
                                         Foreground="{DynamicResource ThemeTextPrimaryBrush}"/>
                        </StackPanel>

                        <!-- Selected disks list (visible when ExportSelected) -->
                        <Border Background="{DynamicResource ThemeSecondaryBackgroundBrush}"
                                CornerRadius="6" Padding="8"
                                IsVisible="{Binding IsExportSelected}">
                            <StackPanel Spacing="4">
                                <TextBlock Text="{Binding L[ExportImport.SelectDisks]}" FontSize="11"
                                           Foreground="{DynamicResource ThemeTextMutedBrush}"/>
                                <ScrollViewer MaxHeight="150">
                                    <ItemsControl ItemsSource="{Binding AvailableDisks}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="vm:SelectableDiskCard">
                                                <Border Padding="6,4" Margin="0,1"
                                                        Background="{DynamicResource ThemeCardBackgroundBrush}"
                                                        CornerRadius="4">
                                                    <CheckBox Content="{Binding ModelName}"
                                                              IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                              FontSize="11"
                                                              Foreground="{DynamicResource ThemeTextPrimaryBrush}"/>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </StackPanel>
                        </Border>

                        <!-- Export file path -->
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                            <TextBox Grid.Column="0"
                                     Text="{Binding ExportFilePath}"
                                     Watermark="{Binding L[ExportImport.SelectExportPath]}"
                                     IsReadOnly="True"
                                     Background="{DynamicResource ThemeSecondaryBackgroundBrush}"
                                     Foreground="{DynamicResource ThemeTextPrimaryBrush}"
                                     FontSize="11"
                                     Padding="8,6"/>
                            <Button Grid.Column="1"
                                    Content="{Binding L[ExportImport.Browse]}"
                                    Command="{Binding BrowseExportPathCommand}"
                                    Padding="12,6" CornerRadius="6" FontSize="11"
                                    Cursor="Hand"/>
                        </Grid>

                        <!-- Export button -->
                        <Button Content="{Binding L[ExportImport.StartExport]}"
                                Command="{Binding ExportCommand}"
                                IsEnabled="{Binding Phase, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Idle}"
                                Background="{DynamicResource ThemePrimaryBrush}"
                                Foreground="White"
                                FontWeight="Bold" FontSize="13"
                                Padding="20,10" CornerRadius="8"
                                HorizontalAlignment="Left"
                                Cursor="Hand"/>
                    </StackPanel>
                </Border>

                <!-- ════════════════════════════════════════ -->
                <!-- LOCAL BACKUP SECTION -->
                <!-- ════════════════════════════════════════ -->
                <Border Background="{DynamicResource ThemeCardBackgroundBrush}"
                        CornerRadius="8" Padding="16"
                        BorderBrush="{DynamicResource ThemeBorderBrush}" BorderThickness="1">
                    <StackPanel Spacing="10">
                        <TextBlock Text="{Binding L[ExportImport.LocalBackupSection]}" FontSize="16" FontWeight="Bold"
                                   Foreground="{DynamicResource ThemeTextPrimaryBrush}"/>

                        <TextBlock Text="{Binding L[ExportImport.LocalBackupDescription]}"
                                   FontSize="10"
                                   Foreground="{DynamicResource ThemeTextMutedBrush}"
                                   TextWrapping="Wrap"/>

                        <!-- Backup path -->
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                            <TextBox Grid.Column="0"
                                     Text="{Binding BackupPath}"
                                     Watermark="{Binding L[ExportImport.BackupPathHint]}"
                                     Background="{DynamicResource ThemeSecondaryBackgroundBrush}"
                                     Foreground="{DynamicResource ThemeTextPrimaryBrush}"
                                     FontSize="11"
                                     Padding="8,6"/>
                            <Button Grid.Column="1"
                                    Content="{Binding L[ExportImport.Browse]}"
                                    Command="{Binding BrowseBackupPathCommand}"
                                    Padding="12,6" CornerRadius="6" FontSize="11"
                                    Cursor="Hand"/>
                        </Grid>

                        <!-- Create backup button -->
                        <Button Content="{Binding L[ExportImport.CreateBackup]}"
                                Command="{Binding CreateLocalBackupCommand}"
                                IsEnabled="{Binding Phase, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Idle}"
                                Background="{DynamicResource ThemeSuccessBrush}"
                                Foreground="White"
                                FontWeight="Bold" FontSize="13"
                                Padding="20,10" CornerRadius="8"
                                HorizontalAlignment="Left"
                                Cursor="Hand"/>

                        <!-- Available backups -->
                        <TextBlock Text="{Binding L[ExportImport.AvailableBackups]}" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource ThemeTextSecondaryBrush}"/>

                        <ScrollViewer MaxHeight="150">
                            <ItemsControl ItemsSource="{Binding AvailableLocalBackups}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="8,6" Margin="0,2"
                                                Background="{DynamicResource ThemeSecondaryBackgroundBrush}"
                                                CornerRadius="4"
                                                Cursor="Hand">
                                            <StackPanel Spacing="2">
                                                <TextBlock Text="{Binding FileName}" FontSize="11" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource ThemeTextPrimaryBrush}"/>
                                                <StackPanel Orientation="Horizontal" Spacing="12">
                                                    <TextBlock Text="{Binding CreatedAt}" FontSize="9"
                                                               Foreground="{DynamicResource ThemeTextMutedBrush}"/>
                                                    <TextBlock Text="{Binding SizeBytes}" FontSize="9"
                                                               Foreground="{DynamicResource ThemeTextSecondaryBrush}"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>

                        <!-- Restore button -->
                        <Button Content="{Binding L[ExportImport.RestoreBackup]}"
                                Command="{Binding RestoreLocalBackupCommand}"
                                IsEnabled="{Binding Phase, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Idle}"
                                Background="{DynamicResource ThemeWarningBrush}"
                                Foreground="White"
                                FontWeight="Bold" FontSize="13"
                                Padding="20,10" CornerRadius="8"
                                HorizontalAlignment="Left"
                                Cursor="Hand"/>

                        <Button Content="{Binding L[ExportImport.RefreshBackups]}"
                                Command="{Binding RefreshLocalBackupsCommand}"
                                Padding="12,6" CornerRadius="6" FontSize="11"
                                HorizontalAlignment="Left"
                                Cursor="Hand"/>
                    </StackPanel>
                </Border>

                <!-- ════════════════════════════════════════ -->
                <!-- IMPORT SECTION -->
                <!-- ════════════════════════════════════════ -->
                <Border Background="{DynamicResource ThemeCardBackgroundBrush}"
                        CornerRadius="8" Padding="16"
                        BorderBrush="{DynamicResource ThemeBorderBrush}" BorderThickness="1">
                    <StackPanel Spacing="10">
                        <TextBlock Text="{Binding L[ExportImport.ImportSection]}" FontSize="16" FontWeight="Bold"
                                   Foreground="{DynamicResource ThemeTextPrimaryBrush}"/>

                        <!-- Import file path -->
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                            <TextBox Grid.Column="0"
                                     Text="{Binding ImportFilePath}"
                                     Watermark="{Binding L[ExportImport.SelectImportPath]}"
                                     IsReadOnly="True"
                                     Background="{DynamicResource ThemeSecondaryBackgroundBrush}"
                                     Foreground="{DynamicResource ThemeTextPrimaryBrush}"
                                     FontSize="11"
                                     Padding="8,6"/>
                            <Button Grid.Column="1"
                                    Content="{Binding L[ExportImport.Browse]}"
                                    Command="{Binding BrowseImportPathCommand}"
                                    Padding="12,6" CornerRadius="6" FontSize="11"
                                    Cursor="Hand"/>
                        </Grid>

                        <!-- Import preview -->
                        <Border Background="{DynamicResource ThemeSecondaryBackgroundBrush}"
                                CornerRadius="6" Padding="10"
                                IsVisible="{Binding ImportPreviewText, Converter={StaticResource NotNullConverter}}">
                            <TextBlock Text="{Binding ImportPreviewText}" FontSize="10"
                                       Foreground="{DynamicResource ThemeTextSecondaryBrush}"
                                       FontFamily="Courier New"
                                       TextWrapping="Wrap"/>
                        </Border>

                        <!-- Import mode -->
                        <TextBlock Text="{Binding L[ExportImport.ImportMode]}" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource ThemeTextSecondaryBrush}"/>

                        <StackPanel Spacing="6" Margin="12,0,0,0">
                            <RadioButton Content="{Binding L[ExportImport.ImportAdd]}"
                                         IsChecked="{Binding IsImportAdd}"
                                         GroupName="ImportMode"
                                         Foreground="{DynamicResource ThemeTextPrimaryBrush}"/>
                            <RadioButton Content="{Binding L[ExportImport.ImportReplace]}"
                                         IsChecked="{Binding IsImportReplace}"
                                         GroupName="ImportMode"
                                         Foreground="{DynamicResource ThemeTextPrimaryBrush}"/>
                        </StackPanel>

                        <TextBlock Text="{Binding L[ExportImport.ImportModeHint]}"
                                   FontSize="9"
                                   Foreground="{DynamicResource ThemeTextMutedBrush}"
                                   TextWrapping="Wrap"/>

                        <!-- Import button -->
                        <Button Content="{Binding L[ExportImport.StartImport]}"
                                Command="{Binding ImportCommand}"
                                IsEnabled="{Binding Phase, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Idle}"
                                Background="{DynamicResource ThemeWarningBrush}"
                                Foreground="White"
                                FontWeight="Bold" FontSize="13"
                                Padding="20,10" CornerRadius="8"
                                HorizontalAlignment="Left"
                                Cursor="Hand"/>
                    </StackPanel>
                </Border>

                <!-- ════════════════════════════════════════ -->
                <!-- PROGRESS (during operation) -->
                <!-- ════════════════════════════════════════ -->
                <Border Background="{DynamicResource ThemeCardBackgroundBrush}"
                        CornerRadius="8" Padding="16"
                        BorderBrush="{DynamicResource ThemeBorderBrush}" BorderThickness="1"
                        IsVisible="{Binding Phase, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Exporting}">
                    <StackPanel Spacing="8">
                        <TextBlock Text="{Binding L[ExportImport.Exporting]}" FontSize="14" FontWeight="Bold"
                                   Foreground="{DynamicResource ThemePrimaryBrush}"/>
                        <ProgressBar Value="{Binding ExportProgress}" Height="8"
                                     Foreground="{DynamicResource ThemePrimaryBrush}"/>
                        <TextBlock Text="{Binding StatusMessage}" FontSize="11"
                                   Foreground="{DynamicResource ThemeTextSecondaryBrush}"/>
                    </StackPanel>
                </Border>

                <Border Background="{DynamicResource ThemeCardBackgroundBrush}"
                        CornerRadius="8" Padding="16"
                        BorderBrush="{DynamicResource ThemeBorderBrush}" BorderThickness="1"
                        IsVisible="{Binding Phase, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Importing}">
                    <StackPanel Spacing="8">
                        <TextBlock Text="{Binding L[ExportImport.Importing]}" FontSize="14" FontWeight="Bold"
                                   Foreground="{DynamicResource ThemeWarningBrush}"/>
                        <ProgressBar Value="{Binding ImportProgress}" Height="8"
                                     Foreground="{DynamicResource ThemeWarningBrush}"/>
                        <TextBlock Text="{Binding StatusMessage}" FontSize="11"
                                   Foreground="{DynamicResource ThemeTextSecondaryBrush}"/>
                    </StackPanel>
                </Border>

                <!-- ════════════════════════════════════════ -->
                <!-- RESULT -->
                <!-- ════════════════════════════════════════ -->
                <Border Background="{DynamicResource ThemeCardBackgroundBrush}"
                        CornerRadius="8" Padding="16"
                        BorderBrush="{DynamicResource ThemeBorderBrush}" BorderThickness="1"
                        IsVisible="{Binding Phase, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Completed}">
                    <StackPanel Spacing="8">
                        <TextBlock Text="{Binding L[ExportImport.Result]}" FontSize="14" FontWeight="Bold"
                                   Foreground="{DynamicResource ThemeSuccessBrush}"/>
                        <TextBlock Text="{Binding ResultText}" FontSize="11"
                                   Foreground="{DynamicResource ThemeTextPrimaryBrush}"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <Border Background="{DynamicResource ThemeCardBackgroundBrush}"
                        CornerRadius="8" Padding="16"
                        BorderBrush="{DynamicResource ThemeBorderBrush}" BorderThickness="1"
                        IsVisible="{Binding Phase, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Failed}">
                    <StackPanel Spacing="8">
                        <TextBlock Text="{Binding L[ExportImport.Failed]}" FontSize="14" FontWeight="Bold"
                                   Foreground="{DynamicResource ThemeDangerBrush}"/>
                        <TextBlock Text="{Binding ResultText}" FontSize="11"
                                   Foreground="{DynamicResource ThemeTextPrimaryBrush}"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <!-- ════════════════════════════════════════ -->
                <!-- LOG -->
                <!-- ════════════════════════════════════════ -->
                <Border Background="{DynamicResource ThemeCardBackgroundBrush}"
                        CornerRadius="8" Padding="16"
                        BorderBrush="{DynamicResource ThemeBorderBrush}" BorderThickness="1"
                        IsVisible="{Binding ExportLogText, Converter={StaticResource NotNullConverter}}">
                    <StackPanel Spacing="4">
                        <TextBlock Text="{Binding L[ExportImport.Log]}" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource ThemeTextPrimaryBrush}"/>
                        <Border Background="{DynamicResource ThemeSecondaryBackgroundBrush}"
                                CornerRadius="4" Padding="8" MaxHeight="150">
                            <ScrollViewer>
                                <TextBlock Text="{Binding ExportLogText}" FontSize="9"
                                           Foreground="{DynamicResource ThemeTextSecondaryBrush}"
                                           FontFamily="Courier New" TextWrapping="Wrap"/>
                            </ScrollViewer>
                        </Border>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- ═══ ACTION BAR ═══ -->
        <Border Grid.Row="2" Classes="StatusBar">
            <Grid ColumnDefinitions="*,Auto,Auto">
                <TextBlock Grid.Column="0" Text="{Binding StatusMessage}"
                           Foreground="{DynamicResource ThemeTextSecondaryBrush}"
                           VerticalAlignment="Center" FontSize="11"/>

                <Button Grid.Column="1" Content="{Binding L[ExportImport.Cancel]}"
                        Command="{Binding CancelCommand}"
                        IsVisible="{Binding Phase, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Exporting}"
                        Background="{DynamicResource ThemeDangerBrush}"
                        Foreground="White"
                        FontWeight="Bold" FontSize="12"
                        Padding="20,10" CornerRadius="8"
                        Cursor="Hand"/>

                <Button Grid.Column="1" Content="{Binding L[ExportImport.Cancel]}"
                        Command="{Binding CancelCommand}"
                        IsVisible="{Binding Phase, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Importing}"
                        Background="{DynamicResource ThemeDangerBrush}"
                        Foreground="White"
                        FontWeight="Bold" FontSize="12"
                        Padding="20,10" CornerRadius="8"
                        Cursor="Hand"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
