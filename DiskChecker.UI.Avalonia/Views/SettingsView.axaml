<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:DiskChecker.UI.Avalonia.ViewModels"
             x:Class="DiskChecker.UI.Avalonia.Views.SettingsView"
             Background="{DynamicResource ThemeBackgroundBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ========== HEADER ========== -->
        <Border Grid.Row="0" 
                Classes="PageHeader">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel>
                    <TextBlock Text="⚙️ Nastavení" Classes="PageTitle"/>
                    <TextBlock Text="Konfigurace aplikace a preferencí" Classes="PageSubtitle"/>
                    <TextBlock Text="{Binding StatusMessage}" Classes="PageMetaText" Margin="0,2,0,0"/>
                </StackPanel>
                <Button Grid.Column="1"
                        Content="← Zpět"
                        Command="{Binding GoBackCommand}"
                        Background="{DynamicResource ThemeSecondaryBackgroundBrush}"
                        Foreground="{DynamicResource ThemeTextPrimaryBrush}"
                        BorderBrush="{DynamicResource ThemeBorderBrush}"
                        VerticalAlignment="Center"
                        CornerRadius="6"
                        Padding="14,8"
                        FontWeight="SemiBold"/>
            </Grid>
        </Border>

        <!-- ========== SETTINGS CONTENT ========== -->
        <ScrollViewer Grid.Row="1" Margin="16">
            <StackPanel Spacing="12">
                
                <!-- General Settings -->
                <Border Background="{DynamicResource ThemeCardBackgroundBrush}"
                       BorderBrush="{DynamicResource ThemeBorderBrush}"
                       BorderThickness="1"
                       CornerRadius="8"
                       Padding="16">
                    <StackPanel Spacing="10">
                        <TextBlock Text="📋 Obecné nastavení" 
                                  FontSize="14" FontWeight="Bold"
                                  Foreground="{DynamicResource ThemeTextPrimaryBrush}"
                                  Margin="0,0,0,8"/>
                        
                        <Grid ColumnDefinitions="200,*">
                            <TextBlock Grid.Column="0" Text="Jazyk aplikace:" 
                                      FontSize="11" VerticalAlignment="Center"
                                      Foreground="{DynamicResource ThemeTextSecondaryBrush}"/>
                            <ComboBox Grid.Column="1" SelectedIndex="0"
                                      HorizontalAlignment="Stretch"
                                      Background="{DynamicResource ThemeCardBackgroundBrush}"
                                      BorderBrush="{DynamicResource ThemeBorderBrush}">
                                <ComboBoxItem Content="Čeština"/>
                                <ComboBoxItem Content="English"/>
                                <ComboBoxItem Content="Deutsch"/>
                            </ComboBox>
                        </Grid>
                        
                        <Grid ColumnDefinitions="200,*">
                            <TextBlock Grid.Column="0" Text="Automatické ukládání:" 
                                      FontSize="11" VerticalAlignment="Center"
                                      Foreground="{DynamicResource ThemeTextSecondaryBrush}"/>
                            <CheckBox Grid.Column="1" Content="Ukládat výsledky automaticky"
                                     IsChecked="{Binding AutoSaveResults}"
                                     FontSize="11"/>
                        </Grid>
                        
                        <Grid ColumnDefinitions="200,*">
                            <TextBlock Grid.Column="0" Text="Upozornění:" 
                                      FontSize="11" VerticalAlignment="Center"
                                      Foreground="{DynamicResource ThemeTextSecondaryBrush}"/>
                            <CheckBox Grid.Column="1" Content="Zobrazovat upozornění při dokončení"
                                     IsChecked="{Binding ShowNotifications}"
                                     FontSize="11"/>
                        </Grid>
                        
                        <Grid ColumnDefinitions="200,*">
                            <TextBlock Grid.Column="0" Text="Příjemce reportů:" 
                                      FontSize="11" VerticalAlignment="Center"
                                      Foreground="{DynamicResource ThemeTextSecondaryBrush}"/>
                            <TextBox Grid.Column="1"
                                    Text="{Binding ReportRecipientEmail}"
                                    Watermark="např. servis@firma.cz"
                                    Background="{DynamicResource ThemeCardBackgroundBrush}"
                                    BorderBrush="{DynamicResource ThemeBorderBrush}"
                                    Padding="8,4"/>
                        </Grid>

                        <Grid ColumnDefinitions="200,*">
                            <TextBlock Grid.Column="0" Text="Kdy posílat e-mail:" 
                                      FontSize="11" VerticalAlignment="Center"
                                      Foreground="{DynamicResource ThemeTextSecondaryBrush}"/>
                            <CheckBox Grid.Column="1"
                                     Content="Posílat automaticky jen pro dlouhotrvající testy (např. sanitizace)"
                                     IsChecked="{Binding EmailSendOnlyForLongRunningTests}"
                                     FontSize="11"/>
                        </Grid>

                        <Grid ColumnDefinitions="200,*">
                            <TextBlock Grid.Column="0" Text="Příloha certifikátu:" 
                                      FontSize="11" VerticalAlignment="Center"
                                      Foreground="{DynamicResource ThemeTextSecondaryBrush}"/>
                            <CheckBox Grid.Column="1"
                                     Content="Přikládat PDF certifikát do e-mailu"
                                     IsChecked="{Binding EmailIncludeCertificateAttachment}"
                                     FontSize="11"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Test Settings -->
                <Border Background="{DynamicResource ThemeCardBackgroundBrush}"
                       BorderBrush="{DynamicResource ThemeBorderBrush}"
                       BorderThickness="1"
                       CornerRadius="8"
                       Padding="16">
                    <StackPanel Spacing="10">
                        <TextBlock Text="🧪 Nastavení testů" 
                                  FontSize="14" FontWeight="Bold"
                                  Foreground="{DynamicResource ThemeTextPrimaryBrush}"
                                  Margin="0,0,0,8"/>
                        
                        <Grid ColumnDefinitions="200,*">
                            <TextBlock Grid.Column="0" Text="Výchozí test:" 
                                      FontSize="11" VerticalAlignment="Center"
                                      Foreground="{DynamicResource ThemeTextSecondaryBrush}"/>
                            <ComboBox Grid.Column="1" SelectedIndex="0"
                                      HorizontalAlignment="Stretch"
                                      Background="{DynamicResource ThemeCardBackgroundBrush}"
                                      BorderBrush="{DynamicResource ThemeBorderBrush}">
                                <ComboBoxItem Content="Rychlý test"/>
                                <ComboBoxItem Content="Plný test"/>
                                <ComboBoxItem Content="Sanitizace"/>
                            </ComboBox>
                        </Grid>
                        
                        <Grid ColumnDefinitions="200,*">
                            <TextBlock Grid.Column="0" Text="SMART cache TTL (min):" 
                                      FontSize="11" VerticalAlignment="Center"
                                      Foreground="{DynamicResource ThemeTextSecondaryBrush}"/>
                            <TextBox Grid.Column="1" 
                                    Text="{Binding SmartCacheTtl}"
                                    Background="{DynamicResource ThemeCardBackgroundBrush}"
                                    BorderBrush="{DynamicResource ThemeBorderBrush}"
                                    Padding="8,4"/>
                        </Grid>
                        
                        <Grid ColumnDefinitions="200,*">
                            <TextBlock Grid.Column="0" Text="USB recovery retry:" 
                                      FontSize="11" VerticalAlignment="Center"
                                      Foreground="{DynamicResource ThemeTextSecondaryBrush}"/>
                            <TextBox Grid.Column="1"
                                    Text="{Binding UsbRecoveryRetryCount}"
                                    Background="{DynamicResource ThemeCardBackgroundBrush}"
                                    BorderBrush="{DynamicResource ThemeBorderBrush}"
                                    Padding="8,4"/>
                        </Grid>
                          
                        <Grid ColumnDefinitions="200,*">
                            <TextBlock Grid.Column="0" Text="Timeout testů (s):" 
                                      FontSize="11" VerticalAlignment="Center"
                                      Foreground="{DynamicResource ThemeTextSecondaryBrush}"/>
                            <TextBox Grid.Column="1" 
                                    Text="{Binding TestTimeout}"
                                    Background="{DynamicResource ThemeCardBackgroundBrush}"
                                    BorderBrush="{DynamicResource ThemeBorderBrush}"
                                    Padding="8,4"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Storage Settings -->
                <Border Background="{DynamicResource ThemeCardBackgroundBrush}"
                       BorderBrush="{DynamicResource ThemeBorderBrush}"
                       BorderThickness="1"
                       CornerRadius="8"
                       Padding="16">
                    <StackPanel Spacing="10">
                        <TextBlock Text="💾 Úložiště dat" 
                                  FontSize="14" FontWeight="Bold"
                                  Foreground="{DynamicResource ThemeTextPrimaryBrush}"
                                  Margin="0,0,0,8"/>
                        
                        <Grid ColumnDefinitions="200,*">
                            <TextBlock Grid.Column="0" Text="Databáze:" 
                                      FontSize="11" VerticalAlignment="Center"
                                      Foreground="{DynamicResource ThemeTextSecondaryBrush}"/>
                            <TextBlock Grid.Column="1" 
                                      Text="~/.local/share/DiskChecker/DiskChecker.db"
                                      FontSize="10"
                                      FontFamily="Consolas"
                                      Foreground="{DynamicResource ThemeTextMutedBrush}"
                                      VerticalAlignment="Center"/>
                        </Grid>
                        
                        <Grid ColumnDefinitions="200,*">
                            <TextBlock Grid.Column="0" Text="Velikost databáze:" 
                                      FontSize="11" VerticalAlignment="Center"
                                      Foreground="{DynamicResource ThemeTextSecondaryBrush}"/>
                            <TextBlock Grid.Column="1" 
                                      Text="{Binding DatabaseSize}"
                                      FontSize="11"
                                      Foreground="{DynamicResource ThemeTextSecondaryBrush}"
                                      VerticalAlignment="Center"/>
                        </Grid>
                        
                        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
                            <Button Content="📂 Otevřít složku"
                                   Command="{Binding OpenDataFolderCommand}"
                                   Background="{DynamicResource ThemeSecondaryBackgroundBrush}"
                                   Foreground="{DynamicResource ThemeTextPrimaryBrush}"
                                   BorderBrush="{DynamicResource ThemeBorderBrush}"
                                   CornerRadius="6"
                                   Padding="10,6"
                                   FontSize="10"/>
                            <Button Content="🗑️ Vyčistit cache"
                                   Command="{Binding ClearCacheCommand}"
                                   Background="{DynamicResource ThemeSecondaryBackgroundBrush}"
                                   Foreground="{DynamicResource ThemeTextPrimaryBrush}"
                                   BorderBrush="{DynamicResource ThemeBorderBrush}"
                                   CornerRadius="6"
                                   Padding="10,6"
                                   FontSize="10"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Backup Settings -->
                <Border Background="{DynamicResource ThemeCardBackgroundBrush}"
                       BorderBrush="{DynamicResource ThemeBorderBrush}"
                       BorderThickness="1"
                       CornerRadius="8"
                       Padding="16">
                    <StackPanel Spacing="10">
                        <TextBlock Text="🔧 Záloha a obnovení" 
                                  FontSize="14" FontWeight="Bold"
                                  Foreground="{DynamicResource ThemeTextPrimaryBrush}"
                                  Margin="0,0,0,8"/>
                        
                        <Grid ColumnDefinitions="200,*">
                            <TextBlock Grid.Column="0" Text="Automatická záloha:" 
                                      FontSize="11" VerticalAlignment="Center"
                                      Foreground="{DynamicResource ThemeTextSecondaryBrush}"/>
                            <CheckBox Grid.Column="1" Content="Zálohovat každý týden"
                                     IsChecked="{Binding AutoBackup}"
                                     FontSize="11"/>
                        </Grid>
                        
                        <Grid ColumnDefinitions="200,*">
                            <TextBlock Grid.Column="0" Text="Poslední záloha:" 
                                      FontSize="11" VerticalAlignment="Center"
                                      Foreground="{DynamicResource ThemeTextSecondaryBrush}"/>
                            <TextBlock Grid.Column="1" 
                                      Text="{Binding LastBackup, StringFormat='{}{0:dd.MM.yyyy HH:mm}'}"
                                      FontSize="11"
                                      Foreground="{DynamicResource ThemeTextSecondaryBrush}"
                                      VerticalAlignment="Center"/>
                        </Grid>
                        
                        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
                            <Button Content="💾 Vytvořit zálohu"
                                   Command="{Binding CreateBackupCommand}"
                                   Background="{DynamicResource ThemePrimaryBrush}"
                                   Foreground="White"
                                   CornerRadius="6"
                                   Padding="12,6"
                                   FontWeight="SemiBold"
                                   FontSize="10"/>
                            <Button Content="📂 Obnovit ze zálohy"
                                   Command="{Binding RestoreBackupCommand}"
                                   Background="{DynamicResource ThemeSecondaryBackgroundBrush}"
                                   Foreground="{DynamicResource ThemeTextPrimaryBrush}"
                                   BorderBrush="{DynamicResource ThemeBorderBrush}"
                                   CornerRadius="6"
                                   Padding="12,6"
                                   FontSize="10"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- About Section -->
                <Border Background="{DynamicResource ThemeCardBackgroundBrush}"
                       BorderBrush="{DynamicResource ThemeBorderBrush}"
                       BorderThickness="1"
                       CornerRadius="8"
                       Padding="16">
                    <StackPanel Spacing="6">
                        <TextBlock Text="ℹ️ O aplikaci" 
                                  FontSize="14" FontWeight="Bold"
                                  Foreground="{DynamicResource ThemeTextPrimaryBrush}"
                                  Margin="0,0,0,8"/>
                        
                        <TextBlock FontSize="11" Foreground="{DynamicResource ThemeTextSecondaryBrush}">
                            <Run Text="DiskChecker v1.0.0"/>
                        </TextBlock>
                        <TextBlock FontSize="10" Foreground="{DynamicResource ThemeTextMutedBrush}">
                            <Run Text="Profesionální nástroj pro diagnostiku disků"/>
                        </TextBlock>
                        <TextBlock FontSize="10" Foreground="{DynamicResource ThemeTextMutedBrush}">
                            <Run Text="© 2024-2026 DiskChecker Project"/>
                        </TextBlock>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- ========== STATUS BAR ========== -->
        <Border Grid.Row="2" Classes="StatusBar">
            <StackPanel Orientation="Horizontal" Margin="16,0" Spacing="12">
                <Button Content="💾 Uložit nastavení"
                       Command="{Binding SaveSettingsCommand}"
                       Background="{DynamicResource ThemeSuccessBrush}"
                       Foreground="White"
                       CornerRadius="6"
                       Padding="12,4"
                       FontWeight="SemiBold"
                       FontSize="10"/>
                <Button Content="↺ Obnovit výchozí"
                       Command="{Binding ResetSettingsCommand}"
                       Background="{DynamicResource ThemeSecondaryBackgroundBrush}"
                       Foreground="{DynamicResource ThemeTextPrimaryBrush}"
                       BorderBrush="{DynamicResource ThemeBorderBrush}"
                       CornerRadius="6"
                       Padding="12,4"
                       FontSize="10"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>