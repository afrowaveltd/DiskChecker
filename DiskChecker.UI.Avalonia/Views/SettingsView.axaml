<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:DiskChecker.UI.Avalonia.ViewModels"
             x:Class="DiskChecker.UI.Avalonia.Views.SettingsView"
             Background="{DynamicResource ThemeBackgroundBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ========== HEADER ========== -->
        <Border Grid.Row="0" 
                Classes="PageHeader">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel>
                    <TextBlock Text="{Binding L[Settings.Title]}" Classes="PageTitle"/>
                    <TextBlock Text="{Binding L[Settings.Description]}" Classes="PageSubtitle"/>
                    <TextBlock Text="{Binding StatusMessage}" Classes="PageMetaText" Margin="0,2,0,0"/>
                </StackPanel>
                <Button Grid.Column="1"
                        Content="{Binding L[Settings.BackButton]}"
                        Command="{Binding GoBackCommand}"
                        Background="{DynamicResource ThemeSecondaryBackgroundBrush}"
                        Foreground="{DynamicResource ThemeTextPrimaryBrush}"
                        BorderBrush="{DynamicResource ThemeBorderBrush}"
                        VerticalAlignment="Center"
                        CornerRadius="6"
                        Padding="14,8"
                        FontWeight="SemiBold"/>
            </Grid>
        </Border>

        <!-- ========== SETTINGS CONTENT ========== -->
        <ScrollViewer Grid.Row="1" Margin="16">
            <StackPanel Spacing="12">
                
                <!-- General Settings -->
                <Border Background="{DynamicResource ThemeCardBackgroundBrush}"
                       BorderBrush="{DynamicResource ThemeBorderBrush}"
                       BorderThickness="1"
                       CornerRadius="8"
                       Padding="16">
                    <StackPanel Spacing="10">
                        <TextBlock Text="{Binding L[Settings.General]}" 
                                  FontSize="14" FontWeight="Bold"
                                  Foreground="{DynamicResource ThemeTextPrimaryBrush}"
                                  Margin="0,0,0,8"/>
                        
                        <Grid ColumnDefinitions="200,*">
                            <TextBlock Grid.Column="0" Text="{Binding L[Settings.LanguageLabel]}" 
                                      FontSize="11" VerticalAlignment="Center"
                                      Foreground="{DynamicResource ThemeTextSecondaryBrush}"/>
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding AvailableLanguages}"
                                      SelectedItem="{Binding Language}"
                                      HorizontalAlignment="Stretch"
                                      Background="{DynamicResource ThemeCardBackgroundBrush}"
                                      BorderBrush="{DynamicResource ThemeBorderBrush}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}"/>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </Grid>
                        
                        <Grid ColumnDefinitions="200,*">
                            <TextBlock Grid.Column="0" Text="{Binding L[Settings.AutoSaveLabel]}" 
                                      FontSize="11" VerticalAlignment="Center"
                                      Foreground="{DynamicResource ThemeTextSecondaryBrush}"/>
                            <CheckBox Grid.Column="1" Content="{Binding L[Settings.AutoSaveContent]}"
                                     IsChecked="{Binding AutoSaveResults}"
                                     FontSize="11"/>
                        </Grid>
                        
                        <Grid ColumnDefinitions="200,*">
                            <TextBlock Grid.Column="0" Text="{Binding L[Settings.Notifications]}" 
                                      FontSize="11" VerticalAlignment="Center"
                                      Foreground="{DynamicResource ThemeTextSecondaryBrush}"/>
                            <CheckBox Grid.Column="1" Content="{Binding L[Settings.NotificationsContent]}"
                                     IsChecked="{Binding ShowNotifications}"
                                     FontSize="11"/>
                        </Grid>
                        
                        <Grid ColumnDefinitions="200,*">
                            <TextBlock Grid.Column="0" Text="{Binding L[Settings.EmailRecipientLabel]}" 
                                      FontSize="11" VerticalAlignment="Center"
                                      Foreground="{DynamicResource ThemeTextSecondaryBrush}"/>
                            <TextBox Grid.Column="1"
                                    Text="{Binding ReportRecipientEmail}"
                                    Watermark="{Binding L[Settings.EmailHint]}"
                                    Background="{DynamicResource ThemeCardBackgroundBrush}"
                                    BorderBrush="{DynamicResource ThemeBorderBrush}"
                                    Padding="8,4"/>
                        </Grid>

                        <Grid ColumnDefinitions="200,*">
                            <TextBlock Grid.Column="0" Text="{Binding L[Settings.EmailWhenLabel]}" 
                                      FontSize="11" VerticalAlignment="Center"
                                      Foreground="{DynamicResource ThemeTextSecondaryBrush}"/>
                            <CheckBox Grid.Column="1"
                                     Content="{Binding L[Settings.EmailLongTests]}"
                                     IsChecked="{Binding EmailSendOnlyForLongRunningTests}"
                                     FontSize="11"/>
                        </Grid>

                        <Grid ColumnDefinitions="200,*">
                            <TextBlock Grid.Column="0" Text="{Binding L[Settings.CertificateAttachment]}" 
                                      FontSize="11" VerticalAlignment="Center"
                                      Foreground="{DynamicResource ThemeTextSecondaryBrush}"/>
                            <CheckBox Grid.Column="1"
                                     Content="{Binding L[Settings.CertificateAttachmentContent]}"
                                     IsChecked="{Binding EmailIncludeCertificateAttachment}"
                                     FontSize="11"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Test Settings -->
                <Border Background="{DynamicResource ThemeCardBackgroundBrush}"
                       BorderBrush="{DynamicResource ThemeBorderBrush}"
                       BorderThickness="1"
                       CornerRadius="8"
                       Padding="16">
                    <StackPanel Spacing="10">
                        <TextBlock Text="{Binding L[Settings.TestSettings]}" 
                                  FontSize="14" FontWeight="Bold"
                                  Foreground="{DynamicResource ThemeTextPrimaryBrush}"
                                  Margin="0,0,0,8"/>
                        
                        <Grid ColumnDefinitions="200,*">
                            <TextBlock Grid.Column="0" Text="{Binding L[Settings.DefaultTest]}" 
                                      FontSize="11" VerticalAlignment="Center"
                                      Foreground="{DynamicResource ThemeTextSecondaryBrush}"/>
                            <ComboBox Grid.Column="1" SelectedIndex="0"
                                      HorizontalAlignment="Stretch"
                                      Background="{DynamicResource ThemeCardBackgroundBrush}"
                                      BorderBrush="{DynamicResource ThemeBorderBrush}">
                                <ComboBoxItem Content="{Binding L[Settings.DefaultTestQuick]}"/>
                                <ComboBoxItem Content="{Binding L[Settings.DefaultTestFull]}"/>
                                <ComboBoxItem Content="{Binding L[Settings.DefaultTestSanitize]}"/>
                            </ComboBox>
                        </Grid>
                        
                        <Grid ColumnDefinitions="200,*">
                            <TextBlock Grid.Column="0" Text="{Binding L[Settings.SmartCacheTTL]}" 
                                      FontSize="11" VerticalAlignment="Center"
                                      Foreground="{DynamicResource ThemeTextSecondaryBrush}"/>
                            <TextBox Grid.Column="1" 
                                    Text="{Binding SmartCacheTtl}"
                                    Background="{DynamicResource ThemeCardBackgroundBrush}"
                                    BorderBrush="{DynamicResource ThemeBorderBrush}"
                                    Padding="8,4"/>
                        </Grid>
                        
                        <Grid ColumnDefinitions="200,*">
                            <TextBlock Grid.Column="0" Text="{Binding L[Settings.UsbRecoveryRetry]}" 
                                      FontSize="11" VerticalAlignment="Center"
                                      Foreground="{DynamicResource ThemeTextSecondaryBrush}"/>
                            <TextBox Grid.Column="1"
                                    Text="{Binding UsbRecoveryRetryCount}"
                                    Background="{DynamicResource ThemeCardBackgroundBrush}"
                                    BorderBrush="{DynamicResource ThemeBorderBrush}"
                                    Padding="8,4"/>
                        </Grid>
                          
                        <Grid ColumnDefinitions="200,*">
                            <TextBlock Grid.Column="0" Text="{Binding L[Settings.TestTimeoutLabel]}" 
                                      FontSize="11" VerticalAlignment="Center"
                                      Foreground="{DynamicResource ThemeTextSecondaryBrush}"/>
                            <TextBox Grid.Column="1" 
                                    Text="{Binding TestTimeout}"
                                    Background="{DynamicResource ThemeCardBackgroundBrush}"
                                    BorderBrush="{DynamicResource ThemeBorderBrush}"
                                    Padding="8,4"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Storage Settings -->
                <Border Background="{DynamicResource ThemeCardBackgroundBrush}"
                       BorderBrush="{DynamicResource ThemeBorderBrush}"
                       BorderThickness="1"
                       CornerRadius="8"
                       Padding="16">
                    <StackPanel Spacing="10">
                        <TextBlock Text="{Binding L[Settings.Storage]}" 
                                  FontSize="14" FontWeight="Bold"
                                  Foreground="{DynamicResource ThemeTextPrimaryBrush}"
                                  Margin="0,0,0,8"/>
                        
                        <Grid ColumnDefinitions="200,*">
                            <TextBlock Grid.Column="0" Text="{Binding L[Settings.Database]}" 
                                      FontSize="11" VerticalAlignment="Center"
                                      Foreground="{DynamicResource ThemeTextSecondaryBrush}"/>
                            <TextBlock Grid.Column="1" 
                                      Text="{Binding L[Settings.DatabasePath]}"
                                      FontSize="10"
                                      FontFamily="Consolas"
                                      Foreground="{DynamicResource ThemeTextMutedBrush}"
                                      VerticalAlignment="Center"/>
                        </Grid>
                        
                        <Grid ColumnDefinitions="200,*">
                            <TextBlock Grid.Column="0" Text="{Binding L[SettingsView.DbBackend]}"
                                      FontSize="11" VerticalAlignment="Center"
                                      Foreground="{DynamicResource ThemeTextSecondaryBrush}"/>
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding AvailableDatabaseProviders}"
                                      SelectedItem="{Binding DatabaseProvider}"
                                      HorizontalAlignment="Stretch"
                                      Background="{DynamicResource ThemeCardBackgroundBrush}"
                                      BorderBrush="{DynamicResource ThemeBorderBrush}"/>
                        </Grid>

                        <Grid ColumnDefinitions="200,*">
                            <TextBlock Grid.Column="0" Text="{Binding L[SettingsView.ConnectionString]}"
                                      FontSize="11" VerticalAlignment="Center"
                                      Foreground="{DynamicResource ThemeTextSecondaryBrush}"/>
                            <TextBox Grid.Column="1"
                                    Text="{Binding DatabaseConnectionString}"
                                    Watermark="Data Source=DiskChecker.db"
                                    Background="{DynamicResource ThemeCardBackgroundBrush}"
                                    BorderBrush="{DynamicResource ThemeBorderBrush}"
                                    Padding="8,4"/>
                        </Grid>

                        <TextBlock Text="{Binding L[SettingsView.DbChangeNote]}"
                                   TextWrapping="Wrap"
                                   FontSize="10"
                                   Foreground="{DynamicResource ThemeTextMutedBrush}"/>

                        <Button Content="Test spojení"
                                Command="{Binding TestDatabaseConnectionCommand}"
                                HorizontalAlignment="Left"
                                Background="{DynamicResource ThemeSecondaryBackgroundBrush}"
                                Foreground="{DynamicResource ThemeTextPrimaryBrush}"
                                BorderBrush="{DynamicResource ThemeBorderBrush}"
                                Padding="12,6"/>

                        <Grid ColumnDefinitions="200,*">
                            <TextBlock Grid.Column="0" Text="{Binding L[Settings.DatabaseSize]}" 
                                      FontSize="11" VerticalAlignment="Center"
                                      Foreground="{DynamicResource ThemeTextSecondaryBrush}"/>
                            <TextBlock Grid.Column="1" 
                                      Text="{Binding DatabaseSize}"
                                      FontSize="11"
                                      Foreground="{DynamicResource ThemeTextSecondaryBrush}"
                                      VerticalAlignment="Center"/>
                        </Grid>
                        
                        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
                            <Button Content="{Binding L[Settings.OpenFolder]}"
                                   Command="{Binding OpenDataFolderCommand}"
                                   Background="{DynamicResource ThemeSecondaryBackgroundBrush}"
                                   Foreground="{DynamicResource ThemeTextPrimaryBrush}"
                                   BorderBrush="{DynamicResource ThemeBorderBrush}"
                                   CornerRadius="6"
                                   Padding="10,6"
                                   FontSize="10"/>
                            <Button Content="{Binding L[Settings.ClearCache]}"
                                   Command="{Binding ClearCacheCommand}"
                                   Background="{DynamicResource ThemeSecondaryBackgroundBrush}"
                                   Foreground="{DynamicResource ThemeTextPrimaryBrush}"
                                   BorderBrush="{DynamicResource ThemeBorderBrush}"
                                   CornerRadius="6"
                                   Padding="10,6"
                                   FontSize="10"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Backup Settings -->
                <Border Background="{DynamicResource ThemeCardBackgroundBrush}"
                       BorderBrush="{DynamicResource ThemeBorderBrush}"
                       BorderThickness="1"
                       CornerRadius="8"
                       Padding="16">
                    <StackPanel Spacing="10">
                        <TextBlock Text="{Binding L[Settings.BackupRestore]}" 
                                  FontSize="14" FontWeight="Bold"
                                  Foreground="{DynamicResource ThemeTextPrimaryBrush}"
                                  Margin="0,0,0,8"/>
                        
                        <Grid ColumnDefinitions="200,*">
                            <TextBlock Grid.Column="0" Text="{Binding L[Settings.AutoBackupLabel]}" 
                                      FontSize="11" VerticalAlignment="Center"
                                      Foreground="{DynamicResource ThemeTextSecondaryBrush}"/>
                            <CheckBox Grid.Column="1" Content="{Binding L[Settings.AutoBackupContent]}"
                                     IsChecked="{Binding AutoBackup}"
                                     FontSize="11"/>
                        </Grid>
                        
                        <Grid ColumnDefinitions="200,*">
                            <TextBlock Grid.Column="0" Text="{Binding L[Settings.LastBackup]}" 
                                      FontSize="11" VerticalAlignment="Center"
                                      Foreground="{DynamicResource ThemeTextSecondaryBrush}"/>
                            <TextBlock Grid.Column="1" 
                                      Text="{Binding LastBackup, StringFormat='{}{0:dd.MM.yyyy HH:mm}'}"
                                      FontSize="11"
                                      Foreground="{DynamicResource ThemeTextSecondaryBrush}"
                                      VerticalAlignment="Center"/>
                        </Grid>
                        
                        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
                            <Button Content="{Binding L[Settings.CreateBackup]}"
                                   Command="{Binding CreateBackupCommand}"
                                   Background="{DynamicResource ThemePrimaryBrush}"
                                   Foreground="White"
                                   CornerRadius="6"
                                   Padding="12,6"
                                   FontWeight="SemiBold"
                                   FontSize="10"/>
                            <Button Content="{Binding L[Settings.RestoreBackup]}"
                                   Command="{Binding RestoreBackupCommand}"
                                   Background="{DynamicResource ThemeSecondaryBackgroundBrush}"
                                   Foreground="{DynamicResource ThemeTextPrimaryBrush}"
                                   BorderBrush="{DynamicResource ThemeBorderBrush}"
                                   CornerRadius="6"
                                   Padding="12,6"
                                   FontSize="10"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- About Section -->
                <Border Background="{DynamicResource ThemeCardBackgroundBrush}"
                       BorderBrush="{DynamicResource ThemeBorderBrush}"
                       BorderThickness="1"
                       CornerRadius="8"
                       Padding="16">
                    <StackPanel Spacing="6">
                        <TextBlock Text="{Binding L[Settings.About]}" 
                                  FontSize="14" FontWeight="Bold"
                                  Foreground="{DynamicResource ThemeTextPrimaryBrush}"
                                  Margin="0,0,0,8"/>
                        
                        <TextBlock FontSize="11" Foreground="{DynamicResource ThemeTextSecondaryBrush}">
                            <Run Text="{Binding L[Settings.AboutVersion]}"/>
                        </TextBlock>
                        <TextBlock FontSize="10" Foreground="{DynamicResource ThemeTextMutedBrush}">
                            <Run Text="{Binding L[Settings.AboutDesc]}"/>
                        </TextBlock>
                        <TextBlock FontSize="10" Foreground="{DynamicResource ThemeTextMutedBrush}">
                            <Run Text="{Binding L[Settings.AboutCopyright]}"/>
                        </TextBlock>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- ========== STATUS BAR ========== -->
        <Border Grid.Row="2" Classes="StatusBar">
            <StackPanel Orientation="Horizontal" Margin="16,0" Spacing="12">
                <Button Content="{Binding L[Settings.SaveButton]}"
                       Command="{Binding SaveSettingsCommand}"
                       Background="{DynamicResource ThemeSuccessBrush}"
                       Foreground="White"
                       CornerRadius="6"
                       Padding="12,4"
                       FontWeight="SemiBold"
                       FontSize="10"/>
                <Button Content="{Binding L[Settings.ResetButton]}"
                       Command="{Binding ResetSettingsCommand}"
                       Background="{DynamicResource ThemeSecondaryBackgroundBrush}"
                       Foreground="{DynamicResource ThemeTextPrimaryBrush}"
                       BorderBrush="{DynamicResource ThemeBorderBrush}"
                       CornerRadius="6"
                       Padding="12,4"
                       FontSize="10"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
