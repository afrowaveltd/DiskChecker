<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:DiskChecker.UI.Avalonia.ViewModels"
             xmlns:converters="using:DiskChecker.UI.Avalonia.Converters"
             xmlns:dg="clr-namespace:Avalonia.Controls;assembly=Avalonia.Controls.DataGrid"
             x:Class="DiskChecker.UI.Avalonia.Views.DiskComparisonView"
             Background="{DynamicResource ThemeBackgroundBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ========== HEADER ========== -->
        <Border Grid.Row="0" Background="{DynamicResource ThemePanelBrush}"
                BorderBrush="{DynamicResource ThemeBorderBrush}"
                BorderThickness="0,0,0,1" Padding="20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="⚖️ Porovnání Disků"
                               FontSize="28" FontWeight="Bold"
                               Foreground="#1a1a1a" Margin="0,0,0,5"/>
                    <TextBlock Text="Srovnání parametrů a stavu vybraných disků"
                               FontSize="13" Foreground="#444444"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="🔄 Porovnat vybrané"
                            Command="{Binding CompareCommand}"
                            IsEnabled="{Binding CanCompare}"
                            Background="#27AE60" Foreground="White"
                            FontWeight="Bold" Padding="15,8" Margin="0,0,10,0"
                            Cursor="Hand">
                        <Button.Styles>
                            <Style Selector="Button">
                                <Setter Property="BorderThickness" Value="0"/>
                            </Style>
                        </Button.Styles>
                    </Button>
                    <Button Content="📊 Exportovat"
                            Command="{Binding ExportCommand}"
                            IsEnabled="{Binding HasComparison}"
                            Background="#3498DB" Foreground="White"
                            FontWeight="Bold" Padding="15,8" Margin="0,0,10,0"
                            Cursor="Hand">
                        <Button.Styles>
                            <Style Selector="Button">
                                <Setter Property="BorderThickness" Value="0"/>
                            </Style>
                        </Button.Styles>
                    </Button>
                    <Button Content="🏠 Zpět"
                            Command="{Binding NavigateBackCommand}"
                            Background="#666666" Foreground="White"
                            FontWeight="Bold" Padding="15,8"
                            Cursor="Hand">
                        <Button.Styles>
                            <Style Selector="Button">
                                <Setter Property="BorderThickness" Value="0"/>
                            </Style>
                        </Button.Styles>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ========== DISK SELECTION ========== -->
        <Border Grid.Row="1" Background="#F8F9FA" Padding="20,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Disk 1 Selection -->
                <StackPanel Grid.Column="0">
                    <TextBlock Text="🔍 Disk 1" FontSize="12" FontWeight="Bold" Margin="0,0,0,8"/>
                    <ComboBox ItemsSource="{Binding AvailableDisks}"
                              SelectedItem="{Binding SelectedDisk1}"
                              Width="280" HorizontalAlignment="Left">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding DisplayName}" FontWeight="Bold"/>
                                    <TextBlock Text=" (" Foreground="#888"/>
                                    <TextBlock Text="{Binding SerialNumber}" Foreground="#666" FontFamily="Consolas" FontSize="10"/>
                                    <TextBlock Text=")" Foreground="#888"/>
                                </StackPanel>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>

                <!-- VS Label -->
                <TextBlock Grid.Column="1" Text="VS" FontSize="24" FontWeight="Bold"
                          Foreground="#999" VerticalAlignment="Center" Margin="20,10,20,0"/>

                <!-- Disk 2 Selection -->
                <StackPanel Grid.Column="2">
                    <TextBlock Text="🔍 Disk 2" FontSize="12" FontWeight="Bold" Margin="0,0,0,8"/>
                    <ComboBox ItemsSource="{Binding AvailableDisks}"
                              SelectedItem="{Binding SelectedDisk2}"
                              Width="280" HorizontalAlignment="Right">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding DisplayName}" FontWeight="Bold"/>
                                    <TextBlock Text=" (" Foreground="#888"/>
                                    <TextBlock Text="{Binding SerialNumber}" Foreground="#666" FontFamily="Consolas" FontSize="10"/>
                                    <TextBlock Text=")" Foreground="#888"/>
                                </StackPanel>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ========== COMPARISON RESULTS ========== -->
        <ScrollViewer Grid.Row="2">
            <StackPanel Margin="20">
                <!-- Comparison Grid -->
                <Panel IsVisible="{Binding HasComparison}">
                    <Border Background="White" BorderBrush="#DEE2E6" BorderThickness="1" CornerRadius="8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Header Row -->
                            <Border Grid.Row="0" Grid.ColumnSpan="4" Background="#F0F0F0" Padding="10,5"
                                    BorderBrush="#DEE2E6" BorderThickness="0,0,0,1">
                                <TextBlock Text="📊 Základní informace" FontWeight="Bold" FontSize="14"/>
                            </Border>

                            <!-- Labels Column -->
                            <StackPanel Grid.Row="1" Grid.RowSpan="8" Grid.Column="0" Margin="10,5">
                                <Grid Margin="0,3">
                                    <TextBlock Text="Model:" FontSize="11"/>
                                </Grid>
                                <Grid Margin="0,3">
                                    <TextBlock Text="Sériové číslo:" FontSize="11"/>
                                </Grid>
                                <Grid Margin="0,3">
                                    <TextBlock Text="Kapacita:" FontSize="11"/>
                                </Grid>
                                <Grid Margin="0,3">
                                    <TextBlock Text="Typ disku:" FontSize="11"/>
                                </Grid>
                                <Grid Margin="0,3">
                                    <TextBlock Text="Firmware:" FontSize="11"/>
                                </Grid>
                                <Grid Margin="0,3">
                                    <TextBlock Text="Celkové hodnocení:" FontSize="11" FontWeight="Bold"/>
                                </Grid>
                                <Grid Margin="0,3">
                                    <TextBlock Text="Skóre:" FontSize="11"/>
                                </Grid>
                                <Grid Margin="0,3">
                                    <TextBlock Text="Poslední test:" FontSize="11"/>
                                </Grid>
                            </StackPanel>

                            <!-- Disk 1 Column -->
                            <StackPanel Grid.Row="1" Grid.RowSpan="8" Grid.Column="1" Margin="5">
                                <Grid Margin="0,3">
                                    <TextBlock Text="{Binding Disk1.ModelName}" FontSize="11" FontWeight="Bold"/>
                                </Grid>
                                <Grid Margin="0,3">
                                    <TextBlock Text="{Binding Disk1.SerialNumber}" FontSize="10" FontFamily="Consolas"/>
                                </Grid>
                                <Grid Margin="0,3">
                                    <TextBlock Text="{Binding Disk1.CapacityText}" FontSize="11"/>
                                </Grid>
                                <Grid Margin="0,3">
                                    <TextBlock Text="{Binding Disk1.DiskType}" FontSize="11"/>
                                </Grid>
                                <Grid Margin="0,3">
                                    <TextBlock Text="{Binding Disk1.Firmware}" FontSize="11"/>
                                </Grid>
                                <Grid Margin="0,3">
                                    <TextBlock Text="{Binding Disk1.OverallGrade}" FontSize="14" FontWeight="Bold"
                                               Foreground="{Binding Disk1.GradeColor}"/>
                                </Grid>
                                <Grid Margin="0,3">
                                    <TextBlock Text="{Binding Disk1.OverallScore, StringFormat={}{0:F0}%}" FontSize="11"/>
                                </Grid>
                                <Grid Margin="0,3">
                                    <TextBlock Text="{Binding Disk1.LastTested, StringFormat={}{0:dd.MM.yyyy}}" FontSize="10"/>
                                </Grid>
                            </StackPanel>

                            <!-- Winner Indicators -->
                            <StackPanel Grid.Row="1" Grid.RowSpan="8" Grid.Column="2" Margin="5">
                                <Grid Margin="0,3">
                                    <TextBlock Text="{Binding Disk1.ModelName}" FontSize="11" FontWeight="Bold"/>
                                </Grid>
                                <Grid Margin="0,3">
                                    <TextBlock Text="{Binding Disk1.SerialNumber}" FontSize="10" FontFamily="Consolas"/>
                                </Grid>
                                <Grid Margin="0,3">
                                    <TextBlock Text="{Binding Disk1.CapacityText}" FontSize="11"/>
                                </Grid>
                                <Grid Margin="0,3">
                                    <TextBlock Text="{Binding Disk1.DiskType}" FontSize="11"/>
                                </Grid>
                                <Grid Margin="0,3">
                                    <TextBlock Text="{Binding Disk1.Firmware}" FontSize="11"/>
                                </Grid>
                                <Grid Margin="0,3">
                                    <TextBlock Text="{Binding Disk1.OverallGrade}" FontSize="14" FontWeight="Bold"
                                               Foreground="{Binding Disk1.GradeColor}"/>
                                </Grid>
                                <Grid Margin="0,3">
                                    <TextBlock Text="{Binding Disk1.OverallScore, StringFormat={}{0:F0}%}" FontSize="11"/>
                                </Grid>
                                <Grid Margin="0,3">
                                    <TextBlock Text="{Binding Disk1.LastTested, StringFormat={}{0:dd.MM.yyyy}}" FontSize="10"/>
                                </Grid>
                            </StackPanel>

                            <!-- Win Indicator Column -->
                            <StackPanel Grid.Row="1" Grid.RowSpan="8" Grid.Column="3" Margin="5">
                                <!-- Winner indicators would go here -->
                            </StackPanel>

                            <!-- SMART Metrics Section -->
                            <Border Grid.Row="9" Grid.ColumnSpan="4" Background="#F0F0F0" Padding="10,5"
                                    BorderBrush="#DEE2E6" BorderThickness="1,1,0,1">
                                <TextBlock Text="📈 SMART Metriky" FontWeight="Bold" FontSize="14"/>
                            </Border>

                            <!-- SMART Labels -->
                            <StackPanel Grid.Row="10" Grid.RowSpan="6" Grid.Column="0" Margin="10,5">
                                <Grid Margin="0,3">
                                    <TextBlock Text="Teplota:" FontSize="11"/>
                                </Grid>
                                <Grid Margin="0,3">
                                    <TextBlock Text="Provozní hodiny:" FontSize="11"/>
                                </Grid>
                                <Grid Margin="0,3">
                                    <TextBlock Text="Reallocated sektory:" FontSize="11"/>
                                </Grid>
                                <Grid Margin="0,3">
                                    <TextBlock Text="Pending sektory:" FontSize="11"/>
                                </Grid>
                                <Grid Margin="0,3">
                                    <TextBlock Text="Chyby čtení:" FontSize="11"/>
                                </Grid>
                                <Grid Margin="0,3">
                                    <TextBlock Text="Počet startů:" FontSize="11"/>
                                </Grid>
                            </StackPanel>

                            <!-- Disk 1 SMART -->
                            <StackPanel Grid.Row="10" Grid.RowSpan="6" Grid.Column="1" Margin="5">
                                <Grid Margin="0,3">
                                    <TextBlock Text="{Binding Disk1.Temperature, StringFormat={}{0}°C}" FontSize="11"/>
                                </Grid>
                                <Grid Margin="0,3">
                                    <TextBlock Text="{Binding Disk1.PowerOnHours, StringFormat={}{0}h}" FontSize="11"/>
                                </Grid>
                                <Grid Margin="0,3">
                                    <TextBlock Text="{Binding Disk1.ReallocatedSectors}" FontSize="11"/>
                                </Grid>
                                <Grid Margin="0,3">
                                    <TextBlock Text="{Binding Disk1.PendingSectors}" FontSize="11"/>
                                </Grid>
                                <Grid Margin="0,3">
                                    <TextBlock Text="{Binding Disk1.ReadErrors}" FontSize="11"/>
                                </Grid>
                                <Grid Margin="0,3">
                                    <TextBlock Text="{Binding Disk1.PowerCycles}" FontSize="11"/>
                                </Grid>
                            </StackPanel>

                            <!-- Disk 2 SMART -->
                            <StackPanel Grid.Row="10" Grid.RowSpan="6" Grid.Column="2" Margin="5">
                                <Grid Margin="0,3">
                                    <TextBlock Text="{Binding Disk2.Temperature, StringFormat={}{0}°C}" FontSize="11"/>
                                </Grid>
                                <Grid Margin="0,3">
                                    <TextBlock Text="{Binding Disk2.PowerOnHours, StringFormat={}{0}h}" FontSize="11"/>
                                </Grid>
                                <Grid Margin="0,3">
                                    <TextBlock Text="{Binding Disk2.ReallocatedSectors}" FontSize="11"/>
                                </Grid>
                                <Grid Margin="0,3">
                                    <TextBlock Text="{Binding Disk2.PendingSectors}" FontSize="11"/>
                                </Grid>
                                <Grid Margin="0,3">
                                    <TextBlock Text="{Binding Disk2.ReadErrors}" FontSize="11"/>
                                </Grid>
                                <Grid Margin="0,3">
                                    <TextBlock Text="{Binding Disk2.PowerCycles}" FontSize="11"/>
                                </Grid>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Panel>

                <!-- Recommendation -->
                <Panel IsVisible="{Binding HasComparison}" Margin="0,20,0,0">
                    <Border Background="#E8F5E9" BorderBrush="#27AE60" BorderThickness="1" CornerRadius="8" Padding="15">
                        <StackPanel>
                            <TextBlock Text="🏆 Doporučení:" FontWeight="Bold" FontSize="14" Margin="0,0,0,5"/>
                            <TextBlock Text="{Binding Recommendation}" TextWrapping="Wrap" FontSize="12"/>
                        </StackPanel>
                    </Border>
                </Panel>

                <!-- Empty State -->
                <Panel IsVisible="{Binding !HasComparison}">
                    <Border Background="#F8F9FA" BorderBrush="#DEE2E6" BorderThickness="1" CornerRadius="8" Padding="40">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="⚖️" FontSize="48" HorizontalAlignment="Center"/>
                            <TextBlock Text="Vyberte dva disky k porovnání" FontSize="18" FontWeight="Bold"
                                       HorizontalAlignment="Center" Margin="0,10,0,5"/>
                            <TextBlock Text="Zvolte disky z rozbalovacích seznamů nahoře"
                                       FontSize="12" Foreground="#666" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Panel>
            </StackPanel>
        </ScrollViewer>

        <!-- ========== STATUS BAR ========== -->
        <Border Grid.Row="3" Background="#F0F0F0" Padding="20,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="{Binding StatusMessage}" FontSize="11"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Panel IsVisible="{Binding IsComparing}">
                        <TextBlock Text="⏳ Porovnávám..." FontSize="11" Foreground="#E67E22"/>
                    </Panel>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>