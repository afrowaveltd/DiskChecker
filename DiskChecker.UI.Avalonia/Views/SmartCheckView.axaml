<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:DiskChecker.UI.Avalonia.ViewModels"
             xmlns:dg="clr-namespace:Avalonia.Controls;assembly=Avalonia.Controls.DataGrid"
             x:Class="DiskChecker.UI.Avalonia.Views.SmartCheckView"
             Background="{DynamicResource ThemeBackgroundBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ========== HEADER ========== -->
        <Border Grid.Row="0" Background="{DynamicResource ThemePanelBrush}" BorderBrush="{DynamicResource ThemeBorderBrush}" BorderThickness="0,0,0,1" Padding="20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="🔧 SMART Kontrola" 
                               FontSize="28" FontWeight="Bold" Foreground="#1a1a1a" Margin="0,0,0,5"/>
                    <TextBlock Text="Technické parametry a stav disku" 
                               FontSize="13" Foreground="#444444"/>
                    <TextBlock Text="{Binding StatusMessage}" FontSize="11" Foreground="#333333" Margin="0,4,0,0"/>
                </StackPanel>

                <Button Grid.Column="1"
                        Content="🏠 Zpět"
                        Command="{Binding $parent[UserControl].DataContext.NavigationService.NavigateToDiskSelectionCommand}"
                        Background="#666666"
                        Foreground="White"
                        VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- ========== DISK SELECTION & INFO ========== -->
        <Border Grid.Row="1" Background="{DynamicResource ThemePanelBrush}" BorderBrush="{DynamicResource ThemeBorderBrush}" BorderThickness="1" Margin="20,12,20,0" Padding="15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Disk Selection -->
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Vyberte disk:" FontSize="11" Foreground="#444444" Margin="0,0,0,5"/>
                    <ComboBox ItemsSource="{Binding Disks}" 
                              SelectedItem="{Binding SelectedDisk}"
                              Width="400" HorizontalAlignment="Left">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding DisplayName}" FontWeight="Bold"/>
                                    <TextBlock Text=" - " Foreground="#888888"/>
                                    <TextBlock Text="{Binding DisplayPath}" Foreground="#666666"/>
                                </StackPanel>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>

                <!-- Grade Display -->
                <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                    <TextBlock FontSize="16" FontWeight="Bold" Foreground="#007ACC" Margin="0,0,0,4">
                        <TextBlock.Text>
                            <MultiBinding StringFormat="Známka: {0}">
                                <Binding Path="Grade"/>
                            </MultiBinding>
                        </TextBlock.Text>
                    </TextBlock>
                    <TextBlock FontSize="14" FontWeight="Bold" Foreground="#27AE60">
                        <TextBlock.Text>
                            <MultiBinding StringFormat="Skóre: {0}/100">
                                <Binding Path="Score"/>
                            </MultiBinding>
                        </TextBlock.Text>
                    </TextBlock>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ========== SMART DATA & TABLES ========== -->
        <Grid Grid.Row="2" Margin="20,12,20,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>

            <!-- SMART Overview -->
            <Grid Grid.Column="0" Margin="0,0,10,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="{DynamicResource ThemePanelBrush}" BorderBrush="{DynamicResource ThemeBorderBrush}" BorderThickness="1" Padding="10" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="ℹ️ Základní informace" FontSize="12" FontWeight="Bold" Foreground="#333333" Margin="0,0,0,8"/>
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Disk:" FontSize="11" Foreground="#444444"/>
                            <TextBlock Grid.Column="1" Text="{Binding DiskName}" FontSize="11" FontWeight="Bold" HorizontalAlignment="Right"/>
                        </Grid>
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Cesta:" FontSize="11" Foreground="#444444"/>
                            <TextBlock Grid.Column="1" Text="{Binding DiskPath}" FontSize="11" HorizontalAlignment="Right"/>
                        </Grid>
                        <Separator Margin="0,6"/>
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Sériové číslo:" FontSize="11" Foreground="#444444"/>
                            <TextBlock Grid.Column="1" Text="{Binding SerialNumber}" FontSize="11" FontWeight="Bold" HorizontalAlignment="Right"/>
                        </Grid>
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Firmware:" FontSize="11" Foreground="#444444"/>
                            <TextBlock Grid.Column="1" Text="{Binding FirmwareVersion}" FontSize="11" FontWeight="Bold" HorizontalAlignment="Right"/>
                        </Grid>
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Teplota:" FontSize="11" Foreground="#444444"/>
                            <TextBlock Grid.Column="1" Text="{Binding Temperature}" FontSize="11" FontWeight="Bold" HorizontalAlignment="Right"/>
                        </Grid>
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Provozní hodiny:" FontSize="11" Foreground="#444444"/>
                            <TextBlock Grid.Column="1" Text="{Binding PowerOnHours}" FontSize="11" FontWeight="Bold" HorizontalAlignment="Right"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Grid.Row="1" Background="{DynamicResource ThemePanelBrush}" BorderBrush="{DynamicResource ThemeBorderBrush}" BorderThickness="1" Padding="10">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        
                        <TextBlock Grid.Row="0" Text="⚠️ Kritické SMART atributy" FontSize="12" FontWeight="Bold" Foreground="#333333" Margin="0,0,0,8"/>
                        
                        <dg:DataGrid Grid.Row="1" ItemsSource="{Binding SmartAttributes}" IsReadOnly="True" HeadersVisibility="Column">
                            <dg:DataGrid.Columns>
                                <dg:DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="40"/>
                                <dg:DataGridTextColumn Header="Název" Binding="{Binding Name}" Width="*"/>
                                <dg:DataGridTextColumn Header="Hodnota" Binding="{Binding RawValue}" Width="80"/>
                            </dg:DataGrid.Columns>
                        </dg:DataGrid>
                    </Grid>
                </Border>
            </Grid>

            <!-- Self-Test Log -->
            <Grid Grid.Column="1" Margin="10,0,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="{DynamicResource ThemePanelBrush}" BorderBrush="{DynamicResource ThemeBorderBrush}" BorderThickness="1" Padding="10" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="⏱️ Stav self-testu" FontSize="12" FontWeight="Bold" Foreground="#333333" Margin="0,0,0,8"/>
                        <TextBlock Text="Spusťte self-test pro kontrolu zdraví disku" FontSize="11" Foreground="#27AE60"/>
                    </StackPanel>
                </Border>

                <Border Grid.Row="1" Background="{DynamicResource ThemePanelBrush}" BorderBrush="{DynamicResource ThemeBorderBrush}" BorderThickness="1" Padding="10" Margin="0,0,0,10">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        
                        <TextBlock Grid.Row="0" Text="📝 Historie self-testů" FontSize="12" FontWeight="Bold" Foreground="#333333" Margin="0,0,0,8"/>
                        
                        <dg:DataGrid Grid.Row="1" ItemsSource="{Binding SelfTestLog}" IsReadOnly="True" HeadersVisibility="Column">
                            <dg:DataGrid.Columns>
                                <dg:DataGridTextColumn Header="#" Binding="{Binding Number}" Width="30"/>
                                <dg:DataGridTextColumn Header="Typ" Binding="{Binding TestType}" Width="*"/>
                                <dg:DataGridTextColumn Header="Stav" Binding="{Binding Status}" Width="*"/>
                                <dg:DataGridTextColumn Header="Hodin" Binding="{Binding LifeTimeHours}" Width="60"/>
                            </dg:DataGrid.Columns>
                        </dg:DataGrid>
                    </Grid>
                </Border>

                <StackPanel Grid.Row="2" Orientation="Horizontal">
                    <Button Content="▶️ Spustit Extended Self-Test" 
                            Command="{Binding RunSelfTestCommand}"
                            IsEnabled="{Binding !IsChecking}"
                            Background="#27AE60" Foreground="White" 
                            Padding="15,10" Margin="0,0,10,0">
                        <Button.Styles>
                            <Style Selector="Button">
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="Cursor" Value="Hand"/>
                            </Style>
                        </Button.Styles>
                    </Button>
                    
                    <Button Content="🔁 Obnovit data" 
                            Command="{Binding RefreshCommand}"
                            IsEnabled="{Binding !IsChecking}"
                            Background="#004B93" Foreground="White" 
                            Padding="15,10">
                        <Button.Styles>
                            <Style Selector="Button">
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="Cursor" Value="Hand"/>
                            </Style>
                        </Button.Styles>
                    </Button>
                </StackPanel>
            </Grid>
        </Grid>

        <!-- ========== STATUS BAR ========== -->
        <TextBlock Grid.Row="3" Text="{Binding StatusMessage}" 
                   Background="#F0F0F0" Padding="20,8" 
                   FontSize="11" Foreground="#333333"
                   TextTrimming="CharacterEllipsis"/>
    </Grid>
</UserControl>
