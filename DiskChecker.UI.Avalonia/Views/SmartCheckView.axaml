<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:DiskChecker.UI.Avalonia.ViewModels"
             xmlns:dg="clr-namespace:Avalonia.Controls;assembly:Avalonia.Controls.DataGrid"
             xmlns:converters="using:DiskChecker.UI.Avalonia.Converters"
             x:Class="DiskChecker.UI.Avalonia.Views.SmartCheckView"
             Background="{DynamicResource ThemeBackgroundBrush}">
    
    <UserControl.Resources>
        <converters:FileSystemToBrushConverter x:Key="FileSystemToBrushConverter"/>
        <converters:BytesToHumanReadableConverter x:Key="BytesToHumanReadableConverter"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ========== HEADER ========== -->
        <Border Grid.Row="0" 
                Classes="PageHeader">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel>
                    <TextBlock Text="🔧 SMART Kontrola" Classes="PageTitle"/>
                    <TextBlock Text="Komplexní přehled zdraví a parametrů disku" Classes="PageSubtitle"/>
                    <TextBlock Text="{Binding StatusMessage}" Classes="PageMetaText" Margin="0,2,0,0"/>
                </StackPanel>
                <Button Grid.Column="1"
                        Content="← Zpět"
                        Command="{Binding $parent[UserControl].DataContext.NavigationService.NavigateToDiskSelectionCommand}"
                        Background="{DynamicResource ThemeSecondaryBackgroundBrush}"
                        Foreground="{DynamicResource ThemeTextPrimaryBrush}"
                        BorderBrush="{DynamicResource ThemeBorderBrush}"
                        VerticalAlignment="Center"
                        CornerRadius="6"
                        Padding="14,8"
                        FontWeight="SemiBold"/>
            </Grid>
        </Border>

        <!-- ========== DISK SELECTION ========== -->
        <Border Grid.Row="1" Padding="16,8">
            <Grid ColumnDefinitions="*,Auto,Auto">
                <!-- Disk Selection -->
                <StackPanel>
                    <TextBlock Text="Vyberte disk:" FontSize="10" Foreground="{DynamicResource ThemeTextMutedBrush}" Margin="0,0,0,4"/>
                    <ComboBox ItemsSource="{Binding Disks}" 
                              SelectedItem="{Binding SelectedDisk}"
                              Width="500" HorizontalAlignment="Left"
                              IsEnabled="{Binding !IsChecking}"
                              Padding="10,6"
                              Background="{DynamicResource ThemeCardBackgroundBrush}"
                              BorderBrush="{DynamicResource ThemeBorderBrush}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold"/>
                                    <TextBlock Text="(" Foreground="{DynamicResource ThemeTextMutedBrush}"/>
                                    <TextBlock Text="{Binding CapacityText}" Foreground="{DynamicResource ThemeTextSecondaryBrush}"/>
                                    <TextBlock Text=")" Foreground="{DynamicResource ThemeTextMutedBrush}"/>
                                </StackPanel>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>

                <!-- Grade Display -->
                <Border Background="{DynamicResource ThemeCardBackgroundBrush}" 
                        BorderBrush="{DynamicResource ThemeSuccessBrush}"
                        BorderThickness="2"
                        CornerRadius="8" Padding="16,8" Margin="12,0">
                    <StackPanel>
                        <TextBlock Text="Celkové hodnocení" FontSize="9" 
                                  Foreground="{DynamicResource ThemeTextMutedBrush}" 
                                  HorizontalAlignment="Center"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,2,0,0">
                            <TextBlock Text="{Binding Grade}" FontSize="28" FontWeight="Bold"
                                      Foreground="{DynamicResource ThemeSuccessBrush}"/>
                            <TextBlock Text=" (" FontSize="14" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding Score}" FontSize="14" FontWeight="Bold"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="%)" FontSize="14" VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Health Status -->
                <Border Background="{DynamicResource ThemePanelBackgroundBrush}" 
                        BorderBrush="{DynamicResource ThemeBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="8" Padding="12,8" Margin="8,0">
                    <StackPanel>
                        <TextBlock Text="Stav disku" FontSize="9" 
                                  Foreground="{DynamicResource ThemeTextMutedBrush}" 
                                  HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding HealthStatus}" FontSize="13" FontWeight="Bold"
                                  Foreground="{DynamicResource ThemeSuccessBrush}"
                                  HorizontalAlignment="Center" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- ========== MAIN CONTENT ========== -->
        <Grid Grid.Row="2" Margin="16,0,16,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.2*"/>
                <ColumnDefinition Width="1.8*"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT COLUMN: Drive Info & Critical Attributes -->
            <Grid Grid.Column="0" Margin="0,0,8,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Drive Information -->
                <Border Grid.Row="0" 
                       Background="{DynamicResource ThemeCardBackgroundBrush}"
                       BorderBrush="{DynamicResource ThemeBorderBrush}"
                       BorderThickness="1"
                       CornerRadius="8"
                       Padding="14"
                       Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock Text="📋 Informace o disku" FontSize="12" FontWeight="Bold" 
                                  Foreground="{DynamicResource ThemeTextPrimaryBrush}" Margin="0,0,0,8"/>
                        
                        <Grid Margin="0,2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Model:" FontSize="10" Foreground="{DynamicResource ThemeTextMutedBrush}"/>
                            <TextBlock Grid.Column="1" Text="{Binding DeviceModel}" FontSize="11" FontWeight="SemiBold" TextWrapping="Wrap"/>
                        </Grid>
                        <Grid Margin="0,2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Sériové č.:" FontSize="10" Foreground="{DynamicResource ThemeTextMutedBrush}"/>
                            <TextBlock Grid.Column="1" Text="{Binding SerialNumber}" FontSize="11" FontFamily="Consolas"/>
                        </Grid>
                        <Grid Margin="0,2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Firmware:" FontSize="10" Foreground="{DynamicResource ThemeTextMutedBrush}"/>
                            <TextBlock Grid.Column="1" Text="{Binding FirmwareVersion}" FontSize="11"/>
                        </Grid>
                        <Grid Margin="0,2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Typ:" FontSize="10" Foreground="{DynamicResource ThemeTextMutedBrush}"/>
                            <TextBlock Grid.Column="1" Text="{Binding DeviceType}" FontSize="11"/>
                        </Grid>
                        <Grid Margin="0,2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Cesta:" FontSize="10" Foreground="{DynamicResource ThemeTextMutedBrush}"/>
                            <TextBlock Grid.Column="1" Text="{Binding DiskPath}" FontSize="10" FontFamily="Consolas" Foreground="{DynamicResource ThemeTextMutedBrush}"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- SMART Functions -->
                <Border Grid.Row="1" 
                       Background="{DynamicResource ThemePrimaryLightBrush}"
                       BorderBrush="{DynamicResource ThemePrimaryBrush}"
                       BorderThickness="1"
                       CornerRadius="8"
                       Padding="14"
                       Margin="0,0,0,8">
                    <StackPanel Spacing="8">
                        <TextBlock Text="🔧 SMART Funkce" FontSize="12" FontWeight="Bold" 
                                  Foreground="{DynamicResource ThemeTextPrimaryBrush}" Margin="0,0,0,6"/>
                        <Grid ColumnDefinitions="*,Auto">
                            <ComboBox ItemsSource="{Binding SmartFeatures}"
                                      SelectedIndex="0"
                                      SelectedItem="{Binding SelectedSmartFeature}"
                                      HorizontalAlignment="Stretch"
                                      IsEnabled="{Binding !IsSelfTestRunning}"
                                      Background="{DynamicResource ThemeCardBackgroundBrush}"
                                      Foreground="{DynamicResource ThemeTextPrimaryBrush}"
                                      BorderBrush="{DynamicResource ThemeBorderBrush}"
                                      Padding="10,6"/>
                            <Button Grid.Column="1" Content="▶ Spustit"
                                    Command="{Binding RunSmartFeatureCommand}"
                                    IsEnabled="{Binding !IsSelfTestRunning}"
                                    Background="{DynamicResource ThemeSuccessBrush}" 
                                    Foreground="White"
                                    FontWeight="SemiBold" 
                                    Padding="12,6" Margin="8,0,0,0"
                                    CornerRadius="6">
                                <Button.Styles>
                                    <Style Selector="Button:pointerover">
                                        <Setter Property="Opacity" Value="0.9"/>
                                    </Style>
                                </Button.Styles>
                            </Button>
                        </Grid>
                        <TextBlock Text="{Binding SmartFeatureDescription}" 
                                  FontSize="9" Foreground="{DynamicResource ThemeTextSecondaryBrush}"
                                  TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <!-- Self-Test Result -->
                <Border Grid.Row="2" 
                       Background="{DynamicResource ThemeWarningBackgroundBrush}"
                       BorderBrush="{DynamicResource ThemeWarningBorderBrush}"
                       BorderThickness="2"
                       CornerRadius="8"
                       Padding="12"
                       Margin="0,0,0,8"
                       IsVisible="{Binding HasSelfTestResult}">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Text="{Binding SelfTestResult}"
                                  FontSize="12" FontWeight="Bold" 
                                  Foreground="{Binding SelfTestResultColor}"
                                  TextWrapping="Wrap"
                                  VerticalAlignment="Center"/>
                        <Button Grid.Column="1" Content="✕"
                                Command="{Binding ClearSelfTestResultCommand}"
                                Background="Transparent" Foreground="{DynamicResource ThemeTextSecondaryBrush}"
                                FontSize="12" Padding="4"
                                BorderThickness="0"/>
                    </Grid>
                </Border>

                <!-- Health Metrics -->
                <Border Grid.Row="3" 
                       Background="{DynamicResource ThemeCardBackgroundBrush}"
                       BorderBrush="{DynamicResource ThemeBorderBrush}"
                       BorderThickness="1"
                       CornerRadius="8"
                       Padding="14"
                       Margin="0,0,0,8">
                    <StackPanel Spacing="6">
                        <TextBlock Text="📊 Zdravotní metriky" FontSize="12" FontWeight="Bold" 
                                  Foreground="{DynamicResource ThemeTextPrimaryBrush}" Margin="0,0,0,8"/>
                        
                        <!-- Temperature -->
                        <Grid ColumnDefinitions="90,*,Auto" Margin="0,2">
                            <TextBlock Grid.Column="0" Text="🌡️ Teplota:" FontSize="10" Foreground="{DynamicResource ThemeTextMutedBrush}"/>
                            <TextBlock Grid.Column="1" Text="{Binding Temperature}" FontSize="11" FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="2" Text="{Binding TemperatureStatus}" FontSize="9" Foreground="{Binding TempColor}"/>
                        </Grid>
                        
                        <!-- Power On Hours -->
                        <Grid ColumnDefinitions="90,*,Auto" Margin="0,2">
                            <TextBlock Grid.Column="0" Text="⏱️ Provozní hod:" FontSize="10" Foreground="{DynamicResource ThemeTextMutedBrush}"/>
                            <TextBlock Grid.Column="1" Text="{Binding PowerOnHours}" FontSize="11" FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="2" Text="{Binding LifetimeStatus}" FontSize="9" Foreground="{DynamicResource ThemeTextMutedBrush}"/>
                        </Grid>
                        
                        <!-- Power Cycles -->
                        <Grid ColumnDefinitions="90,*" Margin="0,2">
                            <TextBlock Grid.Column="0" Text="🔄 Cykly:" FontSize="10" Foreground="{DynamicResource ThemeTextMutedBrush}"/>
                            <TextBlock Grid.Column="1" Text="{Binding PowerCycles}" FontSize="11"/>
                        </Grid>
                        
                        <Border Height="1" Background="{DynamicResource ThemeBorderBrush}" Margin="0,6"/>
                        
                        <!-- Critical sectors -->
                        <TextBlock Text="⚠️ Kritické atributy:" FontSize="10" FontWeight="SemiBold" Margin="0,4,0,4"/>
                        
                        <Grid ColumnDefinitions="130,*" Margin="0,2">
                            <TextBlock Grid.Column="0" Text="Přemapované sektory:" FontSize="9" Foreground="{DynamicResource ThemeTextMutedBrush}"/>
                            <TextBlock Grid.Column="1" Text="{Binding ReallocatedSectors}" FontSize="9" FontWeight="SemiBold"/>
                        </Grid>
                        <Grid ColumnDefinitions="130,*" Margin="0,2">
                            <TextBlock Grid.Column="0" Text="Čekající sektory:" FontSize="9" Foreground="{DynamicResource ThemeTextMutedBrush}"/>
                            <TextBlock Grid.Column="1" Text="{Binding PendingSectors}" FontSize="9" FontWeight="SemiBold"/>
                        </Grid>
                        <Grid ColumnDefinitions="130,*" Margin="0,2">
                            <TextBlock Grid.Column="0" Text="Neopravitelné chyby:" FontSize="9" Foreground="{DynamicResource ThemeTextMutedBrush}"/>
                            <TextBlock Grid.Column="1" Text="{Binding UncorrectableErrors}" FontSize="9" FontWeight="SemiBold"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Cache Controls -->
                <Border Grid.Row="4"
                       Background="{DynamicResource ThemePanelBackgroundBrush}"
                       BorderBrush="{DynamicResource ThemeBorderBrush}"
                       BorderThickness="1"
                       CornerRadius="8"
                       Padding="10">
                    <StackPanel Spacing="6">
                        <TextBlock Text="⚙️ Nastavení cache" FontSize="10" FontWeight="Bold"
                                  Foreground="{DynamicResource ThemeTextPrimaryBrush}" Margin="0,0,0,4"/>
                        <WrapPanel Orientation="Horizontal">
                            <Button Content="🧹 Vymazat disk"
                                    Command="{Binding ClearCacheForSelectedCommand}"
                                    IsEnabled="{Binding SelectedDisk}"
                                    FontSize="9" Padding="6,3"
                                    Background="{DynamicResource ThemeSecondaryBackgroundBrush}"
                                    Foreground="{DynamicResource ThemeTextPrimaryBrush}"
                                    BorderBrush="{DynamicResource ThemeBorderBrush}"/>
                            <Button Content="🧰 Vymazat vše"
                                    Command="{Binding ClearAllSmartCacheCommand}"
                                    FontSize="9" Padding="6,3"
                                    Background="{DynamicResource ThemeSecondaryBackgroundBrush}"
                                    Foreground="{DynamicResource ThemeTextPrimaryBrush}"
                                    BorderBrush="{DynamicResource ThemeBorderBrush}"/>
                        </WrapPanel>
                        <TextBlock Text="{Binding SmartCacheInfo}" FontSize="8" Foreground="{DynamicResource ThemeTextMutedBrush}"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- RIGHT COLUMN: SMART Output & Self-Tests -->
            <Grid Grid.Column="1" Margin="8,0,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- SMART Data Output -->
                <Border Grid.Row="0" 
                       Background="{DynamicResource ThemeCardBackgroundBrush}"
                       BorderBrush="{DynamicResource ThemeBorderBrush}"
                       BorderThickness="1"
                       CornerRadius="8"
                       Padding="10">
                    <Grid RowDefinitions="Auto,*">
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,6">
                            <TextBlock Text="📊 SMART Data Output" FontSize="11" FontWeight="Bold"
                                      Foreground="{DynamicResource ThemeTextPrimaryBrush}"/>
                            <Button Content="🔄 Obnovit" 
                                    Command="{Binding RefreshRawOutputCommand}"
                                    FontSize="9" Padding="6,2" Margin="10,0,0,0"
                                    Background="{DynamicResource ThemeInfoBrush}" 
                                    Foreground="White"
                                    CornerRadius="4">
                                <Button.Styles>
                                    <Style Selector="Button:pointerover">
                                        <Setter Property="Opacity" Value="0.9"/>
                                    </Style>
                                </Button.Styles>
                            </Button>
                        </StackPanel>
                        
                        <Border Grid.Row="1" Background="{DynamicResource ThemeCodeBackgroundBrush}" CornerRadius="6" Padding="10">
                            <ScrollViewer>
                                <TextBox Text="{Binding RawSmartOutput}" 
                                         IsReadOnly="True"
                                         AcceptsReturn="True"
                                         TextWrapping="NoWrap"
                                         FontFamily="Consolas"
                                         FontSize="10"
                                         Background="Transparent"
                                         Foreground="{DynamicResource ThemeCodeForegroundBrush}"
                                         BorderThickness="0"
                                         MinHeight="180"/>
                            </ScrollViewer>
                        </Border>
                    </Grid>
                </Border>

                <!-- Self-Tests -->
                <Border Grid.Row="1" 
                       Background="{DynamicResource ThemeCardBackgroundBrush}"
                       BorderBrush="{DynamicResource ThemeBorderBrush}"
                       BorderThickness="1"
                       CornerRadius="8"
                       Padding="10"
                       Margin="0,8,0,0">
                    <Grid RowDefinitions="Auto,Auto,Auto,*,Auto">
                        <TextBlock Grid.Row="0" Text="🔧 Self-testy" 
                                  FontSize="11" FontWeight="Bold"
                                  Foreground="{DynamicResource ThemeTextPrimaryBrush}" Margin="0,0,0,6"/>
                        
                        <!-- Test buttons -->
                        <WrapPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
                            <Button Content="▶️ Krátký test" 
                                    Command="{Binding RunShortTestCommand}"
                                    IsEnabled="{Binding CanRunSelfTest}"
                                    Background="{DynamicResource ThemeSuccessBrush}" 
                                    Foreground="White" 
                                    FontWeight="SemiBold" 
                                    Padding="10,6"
                                    CornerRadius="6"/>
                            <Button Content="🔍 Rozšířený test" 
                                    Command="{Binding RunLongTestCommand}"
                                    IsEnabled="{Binding CanRunSelfTest}"
                                    Background="{DynamicResource ThemeInfoBrush}" 
                                    Foreground="White" 
                                    FontWeight="SemiBold" 
                                    Padding="10,6"
                                    CornerRadius="6"/>
                            <Button Content="⏹️ Přerušit" 
                                    Command="{Binding AbortTestCommand}"
                                    IsEnabled="{Binding IsSelfTestRunning}"
                                    Background="{DynamicResource ThemeDangerBrush}" 
                                    Foreground="White" 
                                    FontWeight="SemiBold" 
                                    Padding="10,6"
                                    CornerRadius="6"/>
                            <Button Content="🔁 Obnovit" 
                                    Command="{Binding RefreshCommand}"
                                    IsEnabled="{Binding !IsChecking}"
                                    Background="{DynamicResource ThemeSecondaryBackgroundBrush}"
                                    Foreground="{DynamicResource ThemeTextPrimaryBrush}"
                                    BorderBrush="{DynamicResource ThemeBorderBrush}"
                                    FontWeight="SemiBold" 
                                    Padding="10,6"
                                    CornerRadius="6"/>
                        </WrapPanel>
                        
                        <!-- Self-test progress -->
                        <Border Grid.Row="2" 
                               Background="{DynamicResource ThemePrimaryLightBrush}" 
                               BorderBrush="{DynamicResource ThemeSuccessBrush}"
                               BorderThickness="1"
                               CornerRadius="6" 
                               Padding="10"
                               Margin="0,0,0,8"
                               IsVisible="{Binding IsSelfTestRunning}">
                            <StackPanel>
                                <TextBlock Text="{Binding SelfTestTypeText}" FontSize="11" FontWeight="Bold"
                                          Foreground="{DynamicResource ThemeSuccessBrush}"/>
                                <TextBlock Text="{Binding SelfTestProgressText}" FontSize="10" Foreground="{DynamicResource ThemeTextSecondaryBrush}" Margin="0,2,0,6"/>
                                <ProgressBar Value="{Binding SelfTestProgress}" Maximum="100" Height="6"
                                           Background="{DynamicResource ThemeBorderLightBrush}" Foreground="{DynamicResource ThemeSuccessBrush}"/>
                            </StackPanel>
                        </Border>
                        
                        <!-- NVMe specific -->
                        <Panel Grid.Row="3" IsVisible="{Binding IsNvMe}" Margin="0,0,0,8">
                            <StackPanel Spacing="4">
                                <TextBlock Text="💎 NVMe specifické:" FontSize="10" FontWeight="SemiBold"
                                          Foreground="{DynamicResource ThemeTextPrimaryBrush}"/>
                                <Grid ColumnDefinitions="100,*" Margin="0,2">
                                    <TextBlock Grid.Column="0" Text="Využití životnosti:" FontSize="9" Foreground="{DynamicResource ThemeTextMutedBrush}"/>
                                    <TextBlock Grid.Column="1" Text="{Binding NvMePercentageUsed}" FontSize="9"/>
                                </Grid>
                                <Grid ColumnDefinitions="100,*" Margin="0,2">
                                    <TextBlock Grid.Column="0" Text="Media chyby:" FontSize="9" Foreground="{DynamicResource ThemeTextMutedBrush}"/>
                                    <TextBlock Grid.Column="1" Text="{Binding NvMeMediaErrors}" FontSize="9"/>
                                </Grid>
                                <Grid ColumnDefinitions="100,*" Margin="0,2">
                                    <TextBlock Grid.Column="0" Text="Nebezpečné vyp:" FontSize="9" Foreground="{DynamicResource ThemeTextMutedBrush}"/>
                                    <TextBlock Grid.Column="1" Text="{Binding NvMeUnsafeShutdowns}" FontSize="9"/>
                                </Grid>
                            </StackPanel>
                        </Panel>
                        
                        <!-- Self-test log -->
                        <DataGrid Grid.Row="4"
                                     ItemsSource="{Binding SelfTestLog}" 
                                     IsReadOnly="True" 
                                     HeadersVisibility="Column"
                                     AutoGenerateColumns="False"
                                     MaxHeight="120"
                                     GridLinesVisibility="Horizontal"
                                     Background="{DynamicResource ThemeCardBackgroundBrush}"
                                     BorderBrush="{DynamicResource ThemeBorderBrush}"
                                     BorderThickness="1">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="#" Binding="{Binding Number}" Width="25"/>
                                <DataGridTextColumn Header="Typ" Binding="{Binding TestTypeName}" Width="80"/>
                                <DataGridTextColumn Header="Stav" Binding="{Binding StatusName}" Width="*"/>
                                <DataGridTextColumn Header="Hod." Binding="{Binding FormattedHours}" Width="50"/>
                                <DataGridTextColumn Header="Progress" Binding="{Binding FormattedProgress}" Width="55"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <!-- ========== STATUS BAR ========== -->
        <Border Grid.Row="3" Classes="StatusBar">
            <StackPanel Orientation="Horizontal" Margin="16,0" Spacing="8">
                <TextBlock Text="{Binding StatusMessage}" Classes="StatusText"/>
                <TextBlock Text="|" Foreground="{DynamicResource ThemeTextMutedBrush}" VerticalAlignment="Center"/>
                <TextBlock Text="Počet disků: " FontSize="10" Foreground="{DynamicResource ThemeTextMutedBrush}" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding Disks.Count}" FontSize="10" FontWeight="Bold"
                          Foreground="{DynamicResource ThemeTextPrimaryBrush}" VerticalAlignment="Center"/>
                <Panel IsVisible="{Binding IsChecking}">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <ProgressBar Width="50" Height="3" IsIndeterminate="True" VerticalAlignment="Center"
                                   Background="{DynamicResource ThemeBorderLightBrush}"
                                   Foreground="{DynamicResource ThemePrimaryBrush}"/>
                        <TextBlock Text="Načítám..." FontSize="10" Foreground="{DynamicResource ThemeWarningBrush}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Panel>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>