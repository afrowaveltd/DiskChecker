<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="DiskChecker.UI.Avalonia.Views.InputDialogWindow"
        Title="{Binding DialogTitle}"
        Width="450"
        SizeToContent="Height"
        MinHeight="180"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource ThemeBackgroundBrush}"
        CanResize="False">
    
    <Border Background="{DynamicResource ThemeBackgroundBrush}" 
            BorderBrush="{DynamicResource ThemeBorderBrush}" 
            BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <!-- Header -->
            <Border Grid.Row="0" 
                    Background="{DynamicResource ThemePrimaryLightBrush}"
                    Padding="16,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <Border Grid.Column="0" 
                            Background="{DynamicResource ThemeCardBackgroundBrush}"
                            CornerRadius="8"
                            Padding="10"
                            Margin="0,0,12,0">
                        <TextBlock Text="✎" 
                                   FontSize="22"
                                   Foreground="{DynamicResource ThemePrimaryBrush}"/>
                    </Border>
                    
                    <TextBlock Grid.Column="1" 
                               Text="{Binding DialogTitle}" 
                               FontSize="16" 
                               FontWeight="Bold"
                               Foreground="{DynamicResource ThemeTextPrimaryBrush}"
                               VerticalAlignment="Center"/>
                </Grid>
            </Border>
            
            <!-- Content -->
            <Border Grid.Row="1" Padding="20,16">
                <StackPanel Spacing="12">
                    <TextBlock Text="{Binding Message}" 
                               FontSize="13" 
                               Foreground="{DynamicResource ThemeTextSecondaryBrush}"
                               TextWrapping="Wrap"/>
                    
                    <TextBox Text="{Binding InputText}"
                             Watermark="{Binding Placeholder}"
                             FontSize="13"
                             Padding="10,7"
                             CornerRadius="8"
                             BorderBrush="{DynamicResource ThemeBorderBrush}"
                             BorderThickness="1">
                        <TextBox.Styles>
                            <Style Selector="TextBox:focus">
                                <Setter Property="BorderBrush" Value="{DynamicResource ThemePrimaryBrush}"/>
                            </Style>
                        </TextBox.Styles>
                    </TextBox>
                </StackPanel>
            </Border>
            
            <!-- Buttons -->
            <Border Grid.Row="2" 
                    Background="{DynamicResource ThemeSecondaryBackgroundBrush}"
                    Padding="16,12">
                <StackPanel Orientation="Horizontal" 
                            HorizontalAlignment="Right" 
                            Spacing="10">
                    
                    <Button Content="Zrušit"
                            Command="{Binding CancelCommand}"
                            Background="{DynamicResource ThemeCardBackgroundBrush}"
                            Foreground="{DynamicResource ThemeTextSecondaryBrush}"
                            BorderBrush="{DynamicResource ThemeBorderBrush}"
                            BorderThickness="1"
                            Padding="16,8"
                            CornerRadius="8"
                            Cursor="Hand"/>
                    
                    <Button Content="OK"
                            Command="{Binding OkCommand}"
                            Background="{DynamicResource ThemePrimaryBrush}"
                            Foreground="White"
                            BorderThickness="0"
                            Padding="18,8"
                            CornerRadius="8"
                            FontWeight="SemiBold"
                            Cursor="Hand">
                        <Button.Styles>
                            <Style Selector="Button:pointerover">
                                <Setter Property="Background" Value="{DynamicResource ThemePrimaryHoverBrush}"/>
                            </Style>
                        </Button.Styles>
                    </Button>
                    
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>