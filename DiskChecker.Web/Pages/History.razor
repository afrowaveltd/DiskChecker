@page "/history"
@using DiskChecker.Core.Models
@using DiskChecker.Application.Services
@inject DiskCheckerService DiskCheckerService
@inject HistoryService HistoryService

<h1>Historie testů</h1>

@if (isLoading)
{
    <p>Načítám historii...</p>
}
else
{
    <div class="row mb-3">
        <div class="col">
            <label>Kritéria filtru:</label>
            <div class="input-group">
                <input class="form-control" @bind="filterSerial" placeholder="Sériové číslo" />
                <select class="form-select" @bind="filterGrade">
                    <option value="">Všechny známky</option>
                    <option value="A">A</option>
                    <option value="B">B</option>
                    <option value="C">C</option>
                    <option value="D">D</option>
                    <option value="E">E</option>
                    <option value="F">F</option>
                </select>
                <button class="btn btn-primary" @onclick="LoadHistory">Hledat</button>
            </div>
        </div>
    </div>

    <div class="table-responsive">
        <table class="table table-striped">
            <thead>
                <tr>
                    <th>Datum</th>
                    <th>Disk</th>
                    <th>Typ</th>
                    <th>Známka</th>
                    <th>Skóre</th>
                    <th>Rychlost (MB/s)</th>
                    <th>Akce</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in history.Items)
                {
                    <tr>
                        <td>@item.TestDate.ToString("G")</td>
                        <td>@item.DriveName</td>
                        <td>@item.TestType</td>
                        <td><span class="badge @(GetGradeColor(item.Grade))">@item.Grade</span></td>
                        <td>@item.Score.ToString("F1")</td>
                        <td>@item.AverageSpeed.ToString("F1")</td>
                        <td>
                            <button class="btn btn-sm btn-outline-primary" @onclick="(() => ViewDetails(item.TestId))">Detail</button>
                            <button class="btn btn-sm btn-outline-secondary" @onclick="(() => CompareWithSelected(item.TestId))">Porovnat</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (history.TotalPages > 1)
    {
        <nav aria-label="Stránkování">
            <ul class="pagination">
                <li class="page-item @(history.PageIndex == 0 ? "disabled" : "")">
                    <button class="page-link" @onclick="PrevPage">Předchozí</button>
                </li>
                <li class="page-item disabled">
                    <span class="page-link">Stránka @(history.PageIndex + 1) z @history.TotalPages</span>
                </li>
                <li class="page-item @(history.PageIndex == history.TotalPages - 1 ? "disabled" : "")">
                    <button class="page-link" @onclick="NextPage">Další</button>
                </li>
            </ul>
        </nav>
    }
}

<div class="modal fade" @onclick="CloseModal" @style="display: @modalDisplay" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content" @onclick="StopPropagation">
            <div class="modal-header">
                <h5 class="modal-title">Detail testu</h5>
                <button type="button" class="btn-close" @onclick="CloseModal"></button>
            </div>
            <div class="modal-body" id="testDetails">
                @if (selectedTest != null)
                {
                    <div class="mb-3">
                        <h6>@selectedTest.DriveName</h6>
                        <p class="text-muted">@selectedTest.SerialNumber</p>
                    </div>
                    <div class="row">
                        <div class="col-md-6">
                            <p><strong>Datum:</strong> @selectedTest.TestDate.ToString("G")</p>
                            <p><strong>Typ:</strong> @selectedTest.TestType</p>
                            <p><strong>Známka:</strong> <span class="badge @(GetGradeColor(selectedTest.Grade))">@selectedTest.Grade</span></p>
                            <p><strong>Skóre:</strong> @selectedTest.Score.ToString("F1")</p>
                        </div>
                        <div class="col-md-6">
                            <p><strong>Průměrná rychlost:</strong> @selectedTest.AverageSpeed.ToString("F1") MB/s</p>
                            <p><strong>Maximální rychlost:</strong> @selectedTest.PeakSpeed.ToString("F1") MB/s</p>
                            <p><strong>Minimální rychlost:</strong> @selectedTest.MinSpeed.ToString("F1") MB/s</p>
                            <p><strong>Chyby:</strong> @selectedTest.ErrorCount</p>
                        </div>
                    </div>
                    @if (selectedTest.SmartaData != null)
                    {
                        <hr />
                        <h6>SMART data</h6>
                        <div class="row">
                            <div class="col-md-6">
                                <p><strong>Naběhané hodiny:</strong> @selectedTest.SmartaData.PowerOnHours</p>
                                <p><strong>Reallocated:</strong> @selectedTest.SmartaData.ReallocatedSectorCount</p>
                                <p><strong>Pending:</strong> @selectedTest.SmartaData.PendingSectorCount</p>
                                <p><strong>Teplota:</strong> @selectedTest.SmartaData.Temperature.ToString("F1") °C</p>
                            </div>
                        </div>
                    }
                }
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" @onclick="CloseModal">Zavřít</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" @onclick="CloseCompareModal" @style="display: @compareModalDisplay" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content" @onclick="StopPropagation">
            <div class="modal-header">
                <h5 class="modal-title">Porovnání disků</h5>
                <button type="button" class="btn-close" @onclick="CloseCompareModal"></button>
            </div>
            <div class="modal-body" id="compareDetails">
                @if (comparison != null && comparison.Count > 0)
                {
                    <div class="table-responsive">
                        <table class="table table-bordered">
                            <thead>
                                <tr>
                                    <th>Parametr</th>
                                    <th>@compareDrive1Name</th>
                                    <th>@compareDrive2Name</th>
                                    <th>Rozdíl</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var comp in comparison)
                                {
                                    <tr>
                                        <td><strong>@comp.Label</strong></td>
                                        <td>@comp.Value1</td>
                                        <td>@comp.Value2</td>
                                        <td>@GetComparisonDiff(comp)</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <p>Nebylo vybráno žádné porovnání.</p>
                }
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" @onclick="CloseCompareModal">Zavřít</button>
            </div>
        </div>
    </div>
</div>

@code {
    private bool isLoading = true;
    private PagedResult<TestHistoryItem> history = new();
    private TestHistoryItem? selectedTest;
    private string modalDisplay = "none";
    private string compareModalDisplay = "none";
    private List<CompareItem>? comparison;
    private Guid? firstCompareTestId;
    private string compareDrive1Name = "";
    private string compareDrive2Name = "";

    private string filterSerial = "";
    private string filterGrade = "";

    protected override async Task OnInitializedAsync()
    {
        await LoadHistory();
    }

    private async Task LoadHistory()
    {
        isLoading = true;
        StateHasChanged();

        var gradeFilter = string.IsNullOrWhiteSpace(filterGrade) 
            ? (QualityGrade?)null 
            : Enum.Parse<QualityGrade>(filterGrade);

        history = await HistoryService.GetHistoryAsync(
            pageSize: 20,
            pageIndex: 0,
            driveSerial: filterSerial,
            gradeFilter: gradeFilter);

        isLoading = false;
        StateHasChanged();
    }

    private string GetGradeColor(QualityGrade grade)
    {
        return grade switch
        {
            QualityGrade.A or QualityGrade.B => "bg-success",
            QualityGrade.C => "bg-warning text-dark",
            QualityGrade.D or QualityGrade.E or QualityGrade.F => "bg-danger",
            _ => "bg-secondary"
        };
    }

    private string GetComparisonDiff(CompareItem item)
    {
        if (double.TryParse(item.Value1, out var v1) && double.TryParse(item.Value2, out var v2))
        {
            var diff = v1 - v2;
            var sign = diff > 0 ? "+" : (diff < 0 ? "" : "");
            return $"{sign}{diff:F1}";
        }
        return "";
    }

    private async Task ViewDetails(Guid testId)
    {
        selectedTest = await HistoryService.GetTestByIdAsync(testId);
        modalDisplay = "block";
        StateHasChanged();
    }

    private void CloseModal()
    {
        modalDisplay = "none";
        selectedTest = null;
        StateHasChanged();
    }

    private void StopPropagation(EventArgs e)
    {
    }

    private async Task CompareWithSelected(Guid testId)
    {
        if (firstCompareTestId is null)
        {
            firstCompareTestId = testId;
            compareDrive1Name = selectedTest?.DriveName ?? "Test 1";
            return;
        }

        var test1 = await HistoryService.GetTestByIdAsync(firstCompareTestId.Value);
        var test2 = await HistoryService.GetTestByIdAsync(testId);

        if (test1 != null && test2 != null)
        {
            comparison = await HistoryService.CompareTestsAsync(firstCompareTestId.Value, testId);
            compareDrive1Name = test1.DriveName;
            compareDrive2Name = test2.DriveName;
            compareModalDisplay = "block";
        }

        firstCompareTestId = null;
        StateHasChanged();
    }

    private void CloseCompareModal()
    {
        compareModalDisplay = "none";
        comparison = null;
        firstCompareTestId = null;
        StateHasChanged();
    }

    private async Task PrevPage()
    {
        if (history.PageIndex > 0)
        {
            var gradeFilter = string.IsNullOrWhiteSpace(filterGrade)
                ? (QualityGrade?)null
                : Enum.Parse<QualityGrade>(filterGrade);

            history = await HistoryService.GetHistoryAsync(
                pageSize: 20,
                pageIndex: history.PageIndex - 1,
                driveSerial: filterSerial,
                gradeFilter: gradeFilter);
            StateHasChanged();
        }
    }

    private async Task NextPage()
    {
        if (history.PageIndex < history.TotalPages - 1)
        {
            var gradeFilter = string.IsNullOrWhiteSpace(filterGrade)
                ? (QualityGrade?)null
                : Enum.Parse<QualityGrade>(filterGrade);

            history = await HistoryService.GetHistoryAsync(
                pageSize: 20,
                pageIndex: history.PageIndex + 1,
                driveSerial: filterSerial,
                gradeFilter: gradeFilter);
            StateHasChanged();
        }
    }
}
