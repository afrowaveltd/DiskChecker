@page "/surface-test"
@using System.Globalization
@using DiskChecker.Core.Models
@using DiskChecker.Core.Interfaces
@using DiskChecker.Core.Services
@using DiskChecker.Application.Services
@using DiskChecker.Web.Components
@inject DiskCheckerService DiskCheckerService
@inject ISurfaceTestService SurfaceTestService
@inject SmartCheckService SmartCheckService
@inject ITestReportExporter ReportExporter
@inject IPdfReportExporter PdfReportExporter
@inject IReportEmailService ReportEmailService
@implements IDisposable

<h3>Povrchový test disku</h3>

@if (!IsRunningAsAdmin && SelectedProfile == SurfaceTestProfile.FullDiskSanitization)
{
    <div class="warning-box" style="margin-bottom: 20px;">
        <strong>⚠️ VAROVÁNÍ: Nedostatečná oprávnění</strong>
        <p>Aplikace NEBĚŽÍ s administrátorskými právy.</p>
        <p>Pro test "Kompletní vymazání disku" jsou vyžadována admin práva pro:</p>
        <ul>
            <li>Formátování disku pomocí diskpart</li>
            <li>Přímý přístup k diskovým sektorům</li>
            <li>Vymazání všech dat</li>
        </ul>
        <p><strong>Řešení:</strong> Restartujte aplikaci jako administrátor nebo vyberte jiný profil testu.</p>
    </div>
}

@if (IsLoading)
{
    <p>Načítám data...</p>
}
else if (!string.IsNullOrWhiteSpace(ErrorMessage))
{
    <div class="error-message">@ErrorMessage</div>
}
else
{
    @if (ShowAutoDetection && !string.IsNullOrWhiteSpace(SelectedPath))
    {
        <DiskDetectionWizard 
            AvailableDisks="Drives"
            OnDiskSelected="HandleAutoDetectedDisk" />
    }

    <div class="test-controls">
        @if (Drives.Count == 0)
        {
            <p>Žádné disky nebyly nalezeny.</p>
        }
        else
        {
            <div class="form-group">
                <label>Výběr disku</label>
                <div class="disk-selection">
                    <select @bind="SelectedPath" disabled="@IsRunning">
                        <option value="">-- Vyberte disk --</option>
                        @foreach (var drive in Drives)
                        {
                            <option value="@drive.Path">@drive.Name - @FormatBytes(drive.TotalSize) (@drive.Path)</option>
                        }
                    </select>
                    <button class="btn btn-info" @onclick="() => ShowAutoDetection = !ShowAutoDetection" disabled="@IsRunning">
                        🔍 Auto-detekce
                    </button>
                </div>
            </div>

            @if (!string.IsNullOrWhiteSpace(SelectedPath))
            {
                <div class="form-group">
                    <label>Profil testu</label>
                    <select @bind="SelectedProfile" disabled="@IsRunning">
                        <option value="@SurfaceTestProfile.HddFull">HDD - Úplný test (zápis + ověřování)</option>
                        <option value="@SurfaceTestProfile.SsdQuick">SSD - Rychlý test (čtení)</option>
                        <option value="@SurfaceTestProfile.FullDiskSanitization">⚠️ Kompletní vymazání disku (sanitizace)</option>
                    </select>
                </div>

                @if (SelectedProfile == SurfaceTestProfile.HddFull || SelectedProfile == SurfaceTestProfile.FullDiskSanitization)
                {
                    <div class="form-group warning-box">
                        <label>
                            <input type="checkbox" @bind="ConfirmDestructive" @bind:event="onchange" disabled="@IsRunning" />
                            <span class="warning-text">⚠️ VAROVÁNÍ: Tento test SMAŽE všechna data na vybraném disku! Potvrďte, že rozumíte riziku.</span>
                        </label>
                    </div>

                    @if (SelectedProfile == SurfaceTestProfile.FullDiskSanitization)
                    {
                        <div class="info-box">
                            <strong>ℹ️ Kompletní vymazání disku</strong>
                            <p>Tento režim provede:</p>
                            <ul>
                                <li>Úplné přepsání všech dat nulovými hodnotami</li>
                                <li>Ověření všech sektorů</li>
                                <li>Detekci vadných sektorů</li>
                                <li>Příprava disku pro prodej nebo likvidaci</li>
                            </ul>
                            <p class="warning-text">⚠️ Tento proces může trvat několik hodin v závislosti na velikosti disku!</p>
                        </div>
                    }
                }

                <button class="btn btn-primary" @onclick="RunTestAsync" disabled="@IsRunDisabled">
                    @if (IsRunning) { <span>⏱️ Test běží...</span> } else { <span>▶️ Spustit test</span> }
                </button>
            }
        }
    </div>

    @if (IsRunning)
    {
        <div class="test-progress">
            <h4>Průběh testu</h4>
            <div class="progress-bar-container">
                <div class="progress-bar" style="width: @ProgressPercent.ToString("F1", CultureInfo.InvariantCulture)%"></div>
            </div>
            <p class="progress-text">@ProgressPercent.ToString("F1")% - @FormatBytes(TotalBytesProcessed) / @(SelectedDrive?.TotalSize > 0 ? FormatBytes(SelectedDrive.TotalSize) : "?")</p>
            
            <!-- Live Speed Chart -->
            <LiveSpeedChart Samples="SamplesList" IsRunning="IsRunning" />
            
            <!-- Legacy Stats Chart -->
            <SurfaceTestChart 
                Samples="SamplesList"
                CurrentThroughput="CurrentThroughput"
                AverageThroughput="AverageThroughput"
                PeakThroughput="PeakThroughput"
                MinThroughput="MinThroughput" />
        </div>
    }

    @if (CurrentSmartData != null)
    {
        <div class="smart-data">
            <h4>SMART data testovaného disku</h4>
            <table class="info-table">
                <tbody>
                    <tr><td><strong>Model</strong></td><td>@CurrentSmartData.DeviceModel</td></tr>
                    @if (!string.IsNullOrWhiteSpace(CurrentSmartData.ModelFamily))
                    {
                        <tr><td><strong>Rodina</strong></td><td>@CurrentSmartData.ModelFamily</td></tr>
                    }
                    <tr><td><strong>Sériové číslo</strong></td><td>@CurrentSmartData.SerialNumber</td></tr>
                    @if (!string.IsNullOrWhiteSpace(CurrentSmartData.FirmwareVersion))
                    {
                        <tr><td><strong>Firmware</strong></td><td>@CurrentSmartData.FirmwareVersion</td></tr>
                    }
                    <tr><td><strong>Teplota</strong></td><td class="@GetTemperatureClass()">@CurrentSmartData.Temperature.ToString("F1") °C</td></tr>
                    <tr><td><strong>Odpracováno</strong></td><td>@CurrentSmartData.PowerOnHours h</td></tr>
                </tbody>
            </table>
        </div>
    }

    @if (Result != null)
    {
        <div class="test-result">
            <h4>📊 Výsledek testu</h4>
            <table class="result-table">
                <tbody>
                    <tr><td>Testováno</td><td><strong>@FormatBytes(Result.TotalBytesTested)</strong></td></tr>
                    <tr><td>Průměrná rychlost</td><td><strong>@Result.AverageSpeedMbps.ToString("F1") MB/s</strong></td></tr>
                    <tr><td>Maximální rychlost</td><td><strong>@Result.PeakSpeedMbps.ToString("F1") MB/s</strong></td></tr>
                    <tr><td>Minimální rychlost</td><td><strong>@Result.MinSpeedMbps.ToString("F1") MB/s</strong></td></tr>
                    <tr><td>Chyby</td><td class="@(Result.ErrorCount > 0 ? "error" : "success")"><strong>@Result.ErrorCount</strong></td></tr>
                    <tr><td>Vzorky</td><td>@Result.Samples.Count</td></tr>
                </tbody>
            </table>

            @if (Result.ErrorCount == 0)
            {
                <div class="success-message">✅ Test byl úspěšný!</div>
            }
            else
            {
                <div class="error-message">⚠️ Test skončil s @Result.ErrorCount chybou(ami)!</div>
            }

            @if (!string.IsNullOrWhiteSpace(Result.Notes))
            {
                <p class="notes">@Result.Notes</p>
            }
        </div>
    }
}

@code {
    [SupplyParameterFromQuery]
    public string? Path { get; set; }

    private IReadOnlyList<CoreDriveInfo> Drives = Array.Empty<CoreDriveInfo>();
    private CoreDriveInfo? SelectedDrive;
    private string? SelectedPath;
    private SurfaceTestProfile SelectedProfile = SurfaceTestProfile.HddFull;
    private bool ConfirmDestructive;
    private bool IsLoading = true;
    private bool IsRunning;
    private bool ShowAutoDetection;
    private double ProgressPercent;
    private double CurrentThroughput;
    private double AverageThroughput;
    private double PeakThroughput = double.MinValue;
    private double MinThroughput = double.MaxValue;
    private long TotalBytesProcessed;
    private string? ErrorMessage;
    private SurfaceTestResult? Result;
    private SmartaData? CurrentSmartData;
    private System.Threading.Timer? _smartUpdateTimer;
    private List<SurfaceTestSample> SamplesList = new();

    private bool IsRunningAsAdmin
    {
        get
        {
            if (!System.Runtime.InteropServices.RuntimeInformation.IsOSPlatform(System.Runtime.InteropServices.OSPlatform.Windows))
                return true; // On Linux, assume sufficient privileges

            var identity = System.Security.Principal.WindowsIdentity.GetCurrent();
            var principal = new System.Security.Principal.WindowsPrincipal(identity);
            return principal.IsInRole(System.Security.Principal.WindowsBuiltInRole.Administrator);
        }
    }

    protected override async Task OnInitializedAsync()
    {
        Drives = await DiskCheckerService.ListDrivesAsync();
        SelectedPath = Drives.FirstOrDefault(d => d.Path == Path)?.Path ?? Drives.FirstOrDefault()?.Path;
        SelectedDrive = Drives.FirstOrDefault(d => d.Path == SelectedPath);
        IsLoading = false;
    }

    /// <summary>
    /// Handles disk selected from auto-detection wizard.
    /// </summary>
    private async Task HandleAutoDetectedDisk(DiskDetectionService.DiskIdentifier disk)
    {
        // Refresh disk list to get the latest info
        Drives = await DiskCheckerService.ListDrivesAsync();
        
        // Find the disk in our current list
        var selectedDisk = Drives.FirstOrDefault(d => d.Path == disk.Path);
        if (selectedDisk != null)
        {
            SelectedPath = disk.Path;
            SelectedDrive = selectedDisk;
            ShowAutoDetection = false;
            await InvokeAsync(StateHasChanged);
        }
        else
        {
            ErrorMessage = "Disk nebyl nalezen. Prosím zkuste znovu.";
        }
    }

    private bool IsRunDisabled => IsRunning || string.IsNullOrWhiteSpace(SelectedPath) ||
        ((SelectedProfile == SurfaceTestProfile.HddFull || SelectedProfile == SurfaceTestProfile.FullDiskSanitization) && !ConfirmDestructive);

    private async Task RunTestAsync()
    {
        ErrorMessage = null;
        Result = null;
        ProgressPercent = 0;
        CurrentThroughput = 0;
        AverageThroughput = 0;
        PeakThroughput = double.MinValue;
        MinThroughput = double.MaxValue;
        TotalBytesProcessed = 0;
        SamplesList.Clear();

        var drive = Drives.FirstOrDefault(d => d.Path == SelectedPath);
        SelectedDrive = drive;
        if (drive == null)
        {
            ErrorMessage = "Disk nebyl nalezen.";
            return;
        }

        // Load initial SMART data
        var initialSmartCheck = await SmartCheckService.RunAsync(drive);
        if (initialSmartCheck != null)
        {
            CurrentSmartData = initialSmartCheck.SmartaData;
        }

        IsRunning = true;

        // Start periodic SMART data refresh
        _smartUpdateTimer = new System.Threading.Timer(async _ =>
        {
            if (IsRunning && drive != null)
            {
                try
                {
                    var smartCheck = await SmartCheckService.RunAsync(drive);
                    if (smartCheck != null)
                    {
                        CurrentSmartData = smartCheck.SmartaData;
                        await InvokeAsync(StateHasChanged);
                    }
                }
                catch { /* Ignore SMART refresh errors */ }
            }
        }, null, TimeSpan.FromSeconds(5), TimeSpan.FromSeconds(5));

        var request = new SurfaceTestRequest
        {
            Drive = drive,
            Technology = SelectedProfile == SurfaceTestProfile.HddFull ? DriveTechnology.Hdd : DriveTechnology.Ssd,
            Profile = SelectedProfile,
            Operation = SelectedProfile == SurfaceTestProfile.HddFull ? SurfaceTestOperation.WriteZeroFill : SurfaceTestOperation.ReadOnly,
            SecureErase = false,
            AllowDeviceWrite = ConfirmDestructive,
            MaxBytesToTest = null // Test full disk
        };

        var progress = new Progress<SurfaceTestProgress>(update =>
        {
            ProgressPercent = update.PercentComplete;
            CurrentThroughput = update.CurrentThroughputMbps;
            TotalBytesProcessed = update.BytesProcessed;
            
            // Calculate running average
            if (update.CurrentThroughputMbps > 0)
            {
                PeakThroughput = Math.Max(PeakThroughput, update.CurrentThroughputMbps);
                MinThroughput = Math.Min(MinThroughput, update.CurrentThroughputMbps);
            }
            
            _ = InvokeAsync(StateHasChanged);
        });

        try
        {
            Result = await SurfaceTestService.RunAsync(request, progress);
            
            // Calculate final stats
            if (Result.Samples.Any())
            {
                SamplesList = Result.Samples.ToList();
                AverageThroughput = Result.AverageSpeedMbps;
                PeakThroughput = Result.PeakSpeedMbps;
                MinThroughput = Result.MinSpeedMbps;
            }
        }
        catch (Exception ex)
        {
            ErrorMessage = $"Chyba během testu: {ex.Message}";
        }
        finally
        {
            IsRunning = false;
            _smartUpdateTimer?.Dispose();
            _smartUpdateTimer = null;
        }
    }

    private string GetTemperatureClass() => CurrentSmartData?.Temperature switch
    {
        < 35 => "temp-cool",
        < 45 => "temp-normal",
        < 55 => "temp-warm",
        < 65 => "temp-hot",
        _ => "temp-critical"
    };

    private static string FormatBytes(long bytes)
    {
        string[] sizes = { "B", "KB", "MB", "GB", "TB" };
        int i = 0;
        double b = bytes;
        while (b >= 1024 && i < sizes.Length - 1)
        {
            b /= 1024;
            i++;
        }
        return $"{b:F1} {sizes[i]}";
    }

    void IDisposable.Dispose() => _smartUpdateTimer?.Dispose();
}
