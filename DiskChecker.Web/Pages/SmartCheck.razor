@page "/smart-check"
@using DiskChecker.Core.Models
@using DiskChecker.Application.Services
@inject DiskCheckerService DiskCheckerService
@inject SmartCheckService SmartCheckService

<h3>SMART kontrola</h3>

@if (IsLoading)
{
    <p>Načítám data...</p>
}
else if (!string.IsNullOrWhiteSpace(ErrorMessage))
{
    <p class="error">@ErrorMessage</p>
}
else
{
    if (Drives.Count == 0)
    {
        <p>Žádné disky nebyly nalezeny.</p>
    }
    else
    {
        <p>Vyberte disk pro SMART kontrolu:</p>
        <ul>
            @foreach (var drive in Drives)
            {
                <li>
                    <a href="@($"/smart-check?path={Uri.EscapeDataString(drive.Path)}")">@drive.Name (@drive.Path)</a>
                </li>
            }
        </ul>
    }
}

@if (Result != null)
{
    <h4>Výsledek</h4>
    <table class="table">
        <tbody>
            <tr><td>Model</td><td>@(Result.SmartaData.DeviceModel ?? "Neznámý")</td></tr>
            <tr><td>Sériové číslo</td><td>@(Result.SmartaData.SerialNumber ?? "Neznámé")</td></tr>
            <tr><td>Firmware</td><td>@(Result.SmartaData.FirmwareVersion ?? "Neznámý")</td></tr>
            <tr><td>Naběhané hodiny</td><td>@Result.SmartaData.PowerOnHours</td></tr>
            <tr><td>Reallocated</td><td>@Result.SmartaData.ReallocatedSectorCount</td></tr>
            <tr><td>Pending</td><td>@Result.SmartaData.PendingSectorCount</td></tr>
            <tr><td>Uncorrectable</td><td>@Result.SmartaData.UncorrectableErrorCount</td></tr>
            <tr><td>Teplota</td><td>@Result.SmartaData.Temperature.ToString("F1") °C</td></tr>
            @if (Result.SmartaData.WearLevelingCount.HasValue)
            {
                <tr><td>Wear leveling</td><td>@Result.SmartaData.WearLevelingCount.Value %</td></tr>
            }
        </tbody>
    </table>

    <p><strong>Známka:</strong> @Result.Rating.Grade | <strong>Skóre:</strong> @Result.Rating.Score.ToString("F1")</p>

    @if (Result.Rating.Warnings.Count > 0)
    {
        <p><strong>Upozornění:</strong></p>
        <ul>
            @foreach (var warning in Result.Rating.Warnings)
            {
                <li>@warning</li>
            }
        </ul>
    }
}

@code {
    [SupplyParameterFromQuery]
    public string? Path { get; set; }

    private IReadOnlyList<CoreDriveInfo> Drives = Array.Empty<CoreDriveInfo>();
    private SmartCheckResult? Result;
    private bool IsLoading = true;
    private string? ErrorMessage;

    protected override async Task OnInitializedAsync()
    {
        Drives = await DiskCheckerService.ListDrivesAsync();

        if (!string.IsNullOrWhiteSpace(Path))
        {
            var drive = Drives.FirstOrDefault(d => d.Path == Path);
            if (drive == null)
            {
                ErrorMessage = "Disk nebyl nalezen.";
            }
            else
            {
                await RunSmartCheckAsync(drive);
            }
        }

        IsLoading = false;
    }

    private async Task RunSmartCheckAsync(CoreDriveInfo drive)
    {
        IsLoading = true;
        ErrorMessage = null;
        Result = await SmartCheckService.RunAsync(drive);
        if (Result == null)
        {
            ErrorMessage = "SMART data se nepodařilo načíst.";
        }
        IsLoading = false;
    }
}
