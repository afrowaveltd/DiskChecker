@page "/"
@using DiskChecker.Core.Models
@using DiskChecker.Application.Services
@inject DiskCheckerService DiskCheckerService

<h1>DiskChecker - Kontrola disků</h1>

@if (Drives.Count == 0)
{
    <p>Nenačítám disky...</p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>Název</th>
                <th>Cesta</th>
                <th>Velikost</th>
                <th>Akce</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var drive in Drives)
            {
                <tr>
                    <td>@drive.Name</td>
                    <td>@drive.Path</td>
                    <td>@FormatBytes(drive.TotalSize)</td>
                    <td>
                        <a class="btn" href="@($"/smart-check?path={Uri.EscapeDataString(drive.Path)}")">SMART</a>
                        <a class="btn" href="@($"/surface-test?path={Uri.EscapeDataString(drive.Path)}")">Test</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private IReadOnlyList<CoreDriveInfo> Drives = Array.Empty<CoreDriveInfo>();

    protected override async Task OnInitializedAsync()
    {
        Drives = await DiskCheckerService.ListDrivesAsync();
    }

    private string FormatBytes(long bytes)
    {
        string[] sizes = { "B", "KB", "MB", "GB", "TB" };
        int i = 0;
        double b = bytes;
        while (b >= 1024)
        {
            b /= 1024;
            i++;
        }
        return $"{b:F1} {sizes[i]}";
    }
}
