    padding-bottom: 15px;
    margin-bottom: 20px;
}

.detection-header h4 {
    margin: 0 0 5px 0;
    color: #333;
}

.help-text {
    color: #666;
    font-size: 0.9em;
    margin: 0;
}

.step-content {
    padding: 20px;
    border-radius: 6px;
    text-align: center;
}

.step-content.warning {
    background: #fff3cd;
    border-left: 4px solid #ffc107;
}

.step-content.info {
    background: #d1ecf1;
    border-left: 4px solid #17a2b8;
}

.step-content.neutral {
    background: #e2e3e5;
    border-left: 4px solid #6c757d;
}

.step-content.success {
    background: #d4edda;
    border-left: 4px solid #28a745;
}

.step-content.error {
    background: #f8d7da;
    border-left: 4px solid #dc3545;
}

.step-icon {
    font-size: 2em;
    margin-bottom: 10px;
}

.step-content h5 {
    margin: 10px 0;
    color: #333;
}

.step-content p {
    color: #555;
    margin: 8px 0;
}

.hint {
    font-size: 0.9em;
    color: #666;
    font-style: italic;
}

.disk-list {
    text-align: left;
    background: rgba(255,255,255,0.7);
    padding: 10px;
    border-radius: 4px;
    margin: 15px auto;
    max-width: 300px;
}

.disk-list h6 {
    margin: 0 0 8px 0;
    font-weight: 600;
}

.disk-list ul {
    list-style: none;
    padding: 0;
    margin: 0;
}

.disk-list li {
    padding: 5px 0;
    color: #555;
    font-size: 0.95em;
}

.detection-progress {
    margin: 20px 0;
}

.progress-bar {
    width: 100%;
    height: 20px;
    background: #e0e0e0;
    border-radius: 4px;
    overflow: hidden;
}

.progress-bar > div {
    height: 100%;
    background: linear-gradient(90deg, #17a2b8 0%, #138496 100%);
    transition: width 0.3s ease;
}

.progress-text {
    font-size: 0.9em;
    color: #555;
    margin-top: 8px;
}

.detected-disk {
    background: white;
    padding: 15px;
    border-radius: 4px;
    text-align: left;
    margin: 15px auto;
    max-width: 300px;
    border: 1px solid #28a745;
}

.detected-disk p {
    margin: 8px 0;
    color: #333;
}

.detected-disk strong {
    color: #28a745;
}

.button-group {
    display: flex;
    gap: 10px;
    justify-content: center;
    margin-top: 15px;
}

.btn-warning {
    background: #ffc107;
    color: #333;
}

.btn-warning:hover {
    background: #e0a800;
}

.btn-success {
    background: #28a745;
}

.btn-success:hover {
    background: #218838;
}

.btn-secondary {
    background: #6c757d;
}

.btn-secondary:hover {
    background: #5a6268;
}
</style>
