@using DiskChecker.Core.Models

<div class="surface-test-chart">
    <canvas @ref="chartCanvas"></canvas>
    <div class="chart-stats">
        <div class="stat">
            <label>Aktuální rychlost</label>
            <span class="value">@CurrentThroughput.ToString("F1") MB/s</span>
        </div>
        <div class="stat">
            <label>Průměr</label>
            <span class="value">@AverageThroughput.ToString("F1") MB/s</span>
        </div>
        <div class="stat">
            <label>Maximum</label>
            <span class="value">@PeakThroughput.ToString("F1") MB/s</span>
        </div>
        <div class="stat">
            <label>Minimum</label>
            <span class="value">@MinThroughput.ToString("F1") MB/s</span>
        </div>
    </div>
</div>

@code {
    [Parameter]
    public List<SurfaceTestSample> Samples { get; set; } = new();

    [Parameter]
    public double CurrentThroughput { get; set; }

    [Parameter]
    public double AverageThroughput { get; set; }

    [Parameter]
    public double PeakThroughput { get; set; }

    [Parameter]
    public double MinThroughput { get; set; }

    private ElementReference chartCanvas;

    protected override async Task OnParametersSetAsync()
    {
        // Chart will be updated when samples change
        if (Samples.Count > 0)
        {
            await RenderChartAsync();
        }
    }

    private async Task RenderChartAsync()
    {
        // Chart.js implementation or Canvas drawing
        // This will be implemented with Chart.js library
        await Task.CompletedTask;
    }
}

<style>
.surface-test-chart {
    display: flex;
    flex-direction: column;
    gap: 20px;
    padding: 20px;
    border: 1px solid #ddd;
    border-radius: 8px;
    background: #f9f9f9;
}

canvas {
    width: 100%;
    height: 300px;
}

.chart-stats {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
    gap: 15px;
}

.stat {
    background: white;
    padding: 15px;
    border-radius: 6px;
    text-align: center;
    border-left: 4px solid #4A90E2;
}

.stat label {
    display: block;
    font-size: 0.9em;
    color: #666;
    margin-bottom: 8px;
    font-weight: 500;
}

.stat .value {
    display: block;
    font-size: 1.5em;
    font-weight: bold;
    color: #4A90E2;
}
</style>
